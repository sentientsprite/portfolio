---
import { site } from '../config/site';

const year = new Date().getFullYear();
const sourceUrl = `${site.social.github}/portfolio`;
---

<footer class="border-t border-neutral-800 bg-neutral-950">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <div class="text-center sm:text-left">
        <p class="text-sm text-neutral-500">
          &copy; {year} {site.name}. All rights reserved.
        </p>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 inline-block text-xs text-neutral-600 hover:text-emerald-400 transition-colors"
        >
          View site source on GitHub
        </a>
      </div>
      <div class="flex gap-4">
        <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-500 hover:text-emerald-400 transition-colors">GitHub</a>
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-500 hover:text-emerald-400 transition-colors">LinkedIn</a>
        <a href={`mailto:${site.email}`} class="text-sm text-neutral-500 hover:text-emerald-400 transition-colors">Email</a>
      </div>
    </div>
  </div>
</footer>
