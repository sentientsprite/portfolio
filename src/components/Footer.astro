---
import { site } from '../config/site';
import { withBase } from '../lib/url';

const year = new Date().getFullYear();
const sourceUrl = `${site.social.github}/portfolio`;

const footerLinks = [
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="relative mt-24 border-t border-neutral-900">
  <!-- Soft glow accent along the top edge -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href={withBase('/')} class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-emerald-500/15 text-sm text-emerald-400 ring-1 ring-emerald-400/30">
            RK
          </span>
          <span class="text-neutral-100">{site.name}</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-neutral-500">
          {site.description}
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-8 gap-y-3" aria-label="Footer">
        {
          footerLinks.map((link) => (
            <a href={withBase(link.href)} class="nav-link">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-neutral-900 pt-6 sm:flex-row">
      <div class="text-center sm:text-left">
        <p class="text-sm text-neutral-500">&copy; {year} {site.name}. All rights reserved.</p>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 inline-block text-xs text-neutral-600 transition-colors hover:text-emerald-400"
        >
          View site source on GitHub
        </a>
      </div>
      <div class="flex gap-5">
        <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="nav-link">GitHub</a>
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="nav-link">LinkedIn</a>
        <a href={site.social.x} target="_blank" rel="noopener noreferrer" class="nav-link">X</a>
        <a href={`mailto:${site.email}`} class="nav-link">Email</a>
      </div>
    </div>
  </div>
</footer>
