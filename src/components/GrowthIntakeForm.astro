---
/**
 * GrowthIntakeForm.astro — "Book a free consult" offer + qualification intake.
 *
 * Static-site friendly: on submit it composes a structured email (mailto) to
 * Raymond with all answers pre-filled, so there is no backend dependency or
 * stored secret. After submit it shows an inline confirmation that explains the
 * consult steps. Anchor id="intake" so CTAs can deep-link to it.
 */
import { site } from '../config/site';

interface Props {
  variant?: 'default' | 'cinematic';
}

const { variant = 'default' } = Astro.props;
const cinema = variant === 'cinematic';

const needs = [
  'New website or landing page',
  'Lead capture + CRM setup',
  'Booking / scheduling flow',
  'Email & SMS follow-up automation',
  'ROI / attribution dashboard',
  'Not sure yet — help me scope it',
];

const timelines = ['ASAP', 'Next 1–3 months', '3–6 months', 'Just exploring'];
const budgets = ['Not sure yet', 'Under $2k', '$2k–$5k', '$5k–$15k', '$15k+'];

const consultSteps = [
  {
    title: 'We schedule your consult',
    body: 'I reply by email to confirm fit, answer quick questions, and schedule a time if the project makes sense.',
  },
  {
    title: 'We meet for an hour',
    body: 'We talk through your business, current tools, lead flow, follow-up, and where the system is breaking down.',
  },
  {
    title: 'You get a next-step recommendation',
    body: 'I outline a practical build path or explain why a smaller fix is enough. Hiring me to build it is optional.',
  },
];

const field = cinema
  ? 'intake-field'
  : 'w-full rounded-lg border border-neutral-800 bg-neutral-950/80 px-3 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-600 focus:border-emerald-500/40 focus:outline-none focus:ring-1 focus:ring-emerald-500/30';
const checkLabel = cinema
  ? 'flex cursor-pointer items-center gap-2.5 border border-[#262626] bg-[#050505] px-3 py-2.5 text-sm text-neutral-300 transition hover:border-[#404040]'
  : 'flex cursor-pointer items-center gap-2.5 rounded-lg border border-neutral-800 bg-neutral-950/60 px-3 py-2.5 text-sm text-neutral-300 transition hover:border-emerald-500/30 hover:text-neutral-100';
const checkInput = cinema ? 'intake-check h-4 w-4 shrink-0' : 'h-4 w-4 shrink-0 accent-emerald-500';
const submitBtn = cinema
  ? 'btn-cinema btn-cinema-primary disabled:cursor-not-allowed disabled:opacity-60'
  : 'inline-flex items-center gap-2 rounded-full bg-emerald-500 px-7 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-emerald-400 disabled:cursor-not-allowed disabled:opacity-60';
const stepBadge = cinema
  ? 'grid h-7 w-7 place-items-center border border-[#333] text-sm font-bold text-[#d4a853]'
  : 'grid h-7 w-7 place-items-center rounded-full bg-emerald-500/10 text-sm font-bold text-emerald-400 ring-1 ring-emerald-500/20';
const stepCard = cinema
  ? 'border border-[#1a1a1a] bg-[#050505] p-4'
  : 'rounded-xl border border-neutral-800 bg-neutral-950/50 p-4';
const stepCardAlt = cinema
  ? 'border border-[#1a1a1a] bg-[#050505] p-4'
  : 'rounded-xl border border-neutral-800 bg-neutral-950/40 p-4';
const okBadge = cinema
  ? 'mt-0.5 grid h-9 w-9 shrink-0 place-items-center border border-[#333] text-[#d4a853]'
  : 'mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-full bg-emerald-500/15 text-emerald-400 ring-1 ring-emerald-500/30';
const mailLink = cinema ? 'text-[#d4a853] hover:text-[#f5c77a]' : 'text-emerald-400 hover:text-emerald-300';
---

<section
  id="intake"
  class:list={[
    cinema ? 'intake-cinema' : 'glow-card scroll-mt-24 overflow-hidden rounded-2xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/[0.08] via-neutral-900/50 to-neutral-950 p-6 sm:p-9',
  ]}
  data-intake
  data-email={site.email}
  data-intake-cinema={cinema ? '' : undefined}
>
  <p class:list={[cinema ? 'cinema-section-label mb-2' : 'text-xs font-semibold uppercase tracking-[0.3em] text-emerald-400']}>
    Free consult
  </p>
  <h2 class:list={[cinema ? 'font-display mt-2 text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl' : 'mt-2 text-2xl font-bold tracking-tight text-neutral-100 sm:text-3xl']}>
    Book a free consult
  </h2>
  <p class="mt-3 max-w-2xl text-sm leading-relaxed text-neutral-400">
    A free, no-obligation consult to talk through your business and marketing system.
    Share a few details below and I’ll follow up by email. The goal is to identify
    where leads are getting lost and whether a website, automation, booking, or
    reporting fix is the right next step.
  </p>

  <form class="mt-7 grid gap-5" data-intake-form novalidate>
    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="intake-name" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Name
        </label>
        <input
          id="intake-name"
          name="name"
          type="text"
          required
          maxlength="80"
          autocomplete="name"
          placeholder="Your name"
          class={field}
        />
      </div>
      <div>
        <label for="intake-email" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Email
        </label>
        <input
          id="intake-email"
          name="email"
          type="email"
          required
          maxlength="120"
          autocomplete="email"
          placeholder="you@business.com"
          class={field}
        />
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="intake-business" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Business name <span class="text-neutral-600">(optional)</span>
        </label>
        <input
          id="intake-business"
          name="business"
          type="text"
          maxlength="120"
          autocomplete="organization"
          placeholder="Company or brand"
          class={field}
        />
      </div>
      <div>
        <label for="intake-website" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Current website <span class="text-neutral-600">(optional)</span>
        </label>
        <input
          id="intake-website"
          name="website"
          type="text"
          maxlength="160"
          autocomplete="url"
          placeholder="example.com"
          class={field}
        />
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="intake-type" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Type of business
        </label>
        <input
          id="intake-type"
          name="businessType"
          type="text"
          maxlength="120"
          placeholder="e.g. HVAC, dental, gym, e-commerce, SaaS"
          class={field}
        />
      </div>
      <div>
        <label for="intake-tools" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Tools you use today <span class="text-neutral-600">(optional)</span>
        </label>
        <input
          id="intake-tools"
          name="tools"
          type="text"
          maxlength="200"
          placeholder="e.g. Squarespace, Mailchimp, HubSpot, Calendly"
          class={field}
        />
      </div>
    </div>

    <fieldset>
      <legend class="mb-2 block text-xs font-medium text-neutral-400">What are you hoping to improve? (pick any)</legend>
      <div class="grid gap-2 sm:grid-cols-2">
        {needs.map((need) => (
          <label class={checkLabel}>
            <input type="checkbox" name="needs" value={need} class={checkInput} />
            <span>{need}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <div>
      <label for="intake-bottleneck" class="mb-1.5 block text-xs font-medium text-neutral-400">
        Where are leads getting lost right now?
      </label>
      <textarea
        id="intake-bottleneck"
        name="bottleneck"
        rows="4"
        maxlength="2000"
        placeholder="e.g. We get traffic but few leads, follow-up is manual, we can't tell which channels deserve attention…"
        class={field}
      ></textarea>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="intake-timeline" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Timeline
        </label>
        <select
          id="intake-timeline"
          name="timeline"
          class={field}
        >
          {timelines.map((t) => <option value={t}>{t}</option>)}
        </select>
      </div>
      <div>
        <label for="intake-budget" class="mb-1.5 block text-xs font-medium text-neutral-400">
          Budget range
        </label>
        <select
          id="intake-budget"
          name="budget"
          class={field}
        >
          {budgets.map((b) => <option value={b}>{b}</option>)}
        </select>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-4 pt-1">
      <button
        type="submit"
        class={submitBtn}
        data-intake-submit
      >
        Request my free consult
        <span aria-hidden="true">&rarr;</span>
      </button>
      <p class="text-xs text-neutral-500" data-intake-status aria-live="polite"></p>
    </div>
    <p class="text-[11px] leading-relaxed text-neutral-600">
      Free and no-obligation. Submitting opens your email app with the details pre-filled and sends to {site.email}.
      Prefer to write directly? Email me anytime.
    </p>
  </form>

  <!-- Confirmation state (revealed after submit) -->
  <div class="hidden" data-intake-success>
    <div class="flex items-start gap-3">
      <span class={okBadge}>&check;</span>
      <div>
        <h3 class="text-lg font-semibold text-neutral-100" data-intake-success-title>Your consult request is on its way</h3>
        <p class="mt-1 text-sm text-neutral-400">
          I’ll reply by email to schedule your free hour. Here’s exactly what happens next.
        </p>
      </div>
    </div>

    <ol class="mt-6 grid gap-3 sm:grid-cols-3">
      {
        consultSteps.map((step, i) => (
          <li class={stepCard}>
            <span class={stepBadge}>
              {i + 1}
            </span>
            <p class="mt-3 text-sm font-semibold text-neutral-100">{step.title}</p>
            <p class="mt-1 text-xs leading-relaxed text-neutral-500">{step.body}</p>
          </li>
        ))
      }
    </ol>

    <p class="mt-5 text-xs text-neutral-500">
      Didn’t see your email app open?{' '}
      <a href={`mailto:${site.email}`} class={mailLink}>Email me directly</a>.
    </p>
  </div>

  <!-- Static "what happens after" reference, always visible below the form -->
  <div class="mt-8 border-t border-neutral-800 pt-6" data-intake-howitworks>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">What happens after you submit</p>
    <ol class="mt-4 grid gap-3 sm:grid-cols-3">
      {
        consultSteps.map((step, i) => (
          <li class={stepCardAlt}>
            <span class={stepBadge}>
              {i + 1}
            </span>
            <p class="mt-3 text-sm font-semibold text-neutral-100">{step.title}</p>
            <p class="mt-1 text-xs leading-relaxed text-neutral-500">{step.body}</p>
          </li>
        ))
      }
    </ol>
    <p class="mt-4 text-xs text-neutral-600">
      No pressure and no obligation — whether you hire me for the work is entirely your call.
    </p>
  </div>
</section>

<script>
  function initIntake() {
    document.querySelectorAll<HTMLElement>('[data-intake]').forEach((root) => {
      const form = root.querySelector<HTMLFormElement>('[data-intake-form]');
      const status = root.querySelector('[data-intake-status]');
      const success = root.querySelector<HTMLElement>('[data-intake-success]');
      const successTitle = root.querySelector('[data-intake-success-title]');
      const howItWorks = root.querySelector<HTMLElement>('[data-intake-howitworks]');
      const email = root.dataset.email ?? '';
      if (!form || form.dataset.bound) return;
      form.dataset.bound = 'true';

      const setStatus = (msg: string, tone: 'muted' | 'ok' | 'warn') => {
        if (!status) return;
        status.textContent = msg;
        status.className =
          tone === 'ok'
            ? root.hasAttribute('data-intake-cinema')
              ? 'text-xs text-[#d4a853]'
              : 'text-xs text-emerald-400'
            : tone === 'warn'
              ? 'text-xs text-amber-400'
              : 'text-xs text-neutral-500';
      };

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const name = String(data.get('name') ?? '').trim();
        const fromEmail = String(data.get('email') ?? '').trim();

        if (!name || !fromEmail) {
          setStatus('Please add your name and email so I can reach out to schedule.', 'warn');
          return;
        }

        const business = String(data.get('business') ?? '').trim();
        const website = String(data.get('website') ?? '').trim();
        const businessType = String(data.get('businessType') ?? '').trim();
        const tools = String(data.get('tools') ?? '').trim();
        const bottleneck = String(data.get('bottleneck') ?? '').trim();
        const timeline = String(data.get('timeline') ?? '').trim();
        const budget = String(data.get('budget') ?? '').trim();
        const selectedNeeds = data.getAll('needs').map(String);

        const lines = [
          `Name: ${name}`,
          `Email: ${fromEmail}`,
          business ? `Business: ${business}` : null,
          businessType ? `Type of business: ${businessType}` : null,
          website ? `Website: ${website}` : null,
          tools ? `Tools used: ${tools}` : null,
          '',
          'Hoping to improve:',
          selectedNeeds.length ? selectedNeeds.map((n) => `  - ${n}`).join('\n') : '  - (not specified)',
          '',
          `Where leads are getting lost:\n${bottleneck || '  (not specified)'}`,
          '',
          `Timeline: ${timeline}`,
          `Budget: ${budget}`,
        ].filter((l) => l !== null);

        const subject = `Free consult request — ${business || name}`;
        const body = lines.join('\n');
        const mailto = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

        window.location.href = mailto;

        if (success) {
          if (successTitle) {
            const first = name.split(/\s+/)[0];
            successTitle.textContent = `Thanks, ${first} — your consult request is on its way`;
          }
          form.classList.add('hidden');
          howItWorks?.classList.add('hidden');
          success.classList.remove('hidden');
          success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          setStatus('Opening your email app… if nothing happens, email me directly.', 'ok');
        }
      });
    });
  }

  initIntake();
  document.addEventListener('astro:page-load', initIntake);
</script>
