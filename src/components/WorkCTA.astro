---
import { withBase } from '../lib/url';
import { site } from '../config/site';

interface Props {
  /** Project name, used to personalize the custom-build email subject. */
  projectName: string;
}

const { projectName } = Astro.props;
const customSubject = encodeURIComponent(`Custom version of ${projectName}`);
const customBody = encodeURIComponent(
  `Hi Raymond,\n\nI saw the ${projectName} demo and want a version tailored to my business.\n\nHere's what I'm working with:`,
);
const mailto = `mailto:${site.email}?subject=${customSubject}&body=${customBody}`;
---

<section class="mt-14 border border-[#1a1a1a] bg-[#0a0a0a] p-8 text-center sm:p-12" data-animate>
  <p class="cinema-section-label mb-3">Want this in your stack?</p>
  <h2 class="font-display mx-auto mt-2 max-w-xl text-2xl font-extrabold tracking-tight text-neutral-100 sm:text-3xl">
    Let's wire it into your business
  </h2>
  <p class="mx-auto mt-3 max-w-lg text-neutral-500">
    Book a free consult — or email me for a custom build based on this exact demo.
  </p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
    <a href={withBase('/contact#intake')} class="btn-cinema btn-cinema-primary">
      Book a consult
    </a>
    <a href={mailto} class="btn-cinema btn-cinema-ghost">
      Request a custom build
    </a>
  </div>
</section>
