---
import type { MergedProject } from '../../lib/github';
import { withBase, resolveDemoUrl } from '../../lib/url';

interface Props {
  project: MergedProject;
  index?: string;
}

const { project, index = '01' } = Astro.props;
const detailUrl = withBase(`/work/${project.slug}`);
const demoUrl = resolveDemoUrl({ demoPath: project.demoPath, demoUrl: project.demoUrl });
const thumb = project.screenshot ? withBase(project.screenshot) : withBase('/images/me.png');
---

<section class="media-strip">
  <div class="media-strip-grid">
    <div
      class="media-frame"
      data-animate
      data-demo-lazy={demoUrl ? '' : undefined}
      data-demo-src={demoUrl ?? undefined}
      data-demo-title={`${project.displayName} live demo`}
    >
      {
        demoUrl ? (
          <div class="demo-poster h-full" data-demo-poster>
            {project.screenshot && (
              <img src={thumb} alt="" class="mb-2 max-h-24 w-auto opacity-40 grayscale" loading="lazy" />
            )}
            <p>Demo loads when in view</p>
            <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="btn-cinema btn-cinema-ghost text-[0.65rem]">
              Open live demo &nearr;
            </a>
          </div>
        ) : project.screenshot ? (
          <img src={thumb} alt="" class="h-full w-full object-cover" loading="lazy" />
        ) : (
          <div class="media-placeholder">
            <span>Live demo</span>
          </div>
        )
      }
    </div>

    <div data-animate>
      <p class="strip-index">Featured · {index}</p>
      <h2 class="strip-title">{project.displayName}</h2>
      <p class="strip-desc">{project.description}</p>
      <a href={detailUrl} class="btn-cinema btn-cinema-ghost mt-8 inline-flex">
        Walk this module &rarr;
      </a>
    </div>
  </div>
</section>
