---
import { site } from '../../config/site';
import { withBase } from '../../lib/url';

interface Props {
  photoSrc?: string;
}

/** Prefer public/images/me.png when added; falls back to site headshot. */
const { photoSrc = withBase('/images/me.png') } = Astro.props;
const fallbackSrc = withBase(`/${site.photo}`);
---

<section class="flashlight-hero" data-flashlight-hero>
  <div class="flashlight-stage" aria-hidden="true">
    <div class="flashlight-photo flashlight-photo--dim">
      <img
        src={photoSrc}
        data-fallback={fallbackSrc}
        alt=""
        width="400"
        height="533"
        decoding="async"
        fetchpriority="high"
        onerror="this.onerror=null;this.src=this.dataset.fallback"
      />
    </div>
    <div class="flashlight-photo flashlight-photo--lit">
      <img
        src={photoSrc}
        data-fallback={fallbackSrc}
        alt=""
        width="400"
        height="533"
        decoding="async"
        fetchpriority="high"
        onerror="this.onerror=null;this.src=this.dataset.fallback"
      />
    </div>
  </div>
  <div class="flashlight-vignette" aria-hidden="true"></div>

  <div class="flashlight-content">
    <p class="hero-eyebrow">{site.title}</p>
    <h1 class="hero-title">I build systems that turn traffic into revenue.</h1>
    <p class="hero-lede">
      Conversion sites, CRM workflows, booking flows, and attribution dashboards — wired together so
      leads get captured, followed up, and measured.
    </p>
    <div class="hero-actions">
      <a href={withBase('/contact')} class="btn-cinema btn-cinema-primary">Start a project</a>
      <a href={withBase('/work')} class="btn-cinema btn-cinema-ghost">View work</a>
    </div>
  </div>
</section>
