---
import { site } from '../../config/site';
import { withBase } from '../../lib/url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? current === '/' : current === href || current.startsWith(`${href}/`);

const primaryLinks = [
  { href: '/work', label: 'Work' },
  { href: '/overview', label: 'Overview' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/contact', label: 'Contact' },
];

const moreLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/resume', label: 'Resume' },
  { href: '/store', label: 'Store' },
];

const mobileLinks = [...primaryLinks.slice(0, 3), ...moreLinks, primaryLinks[3]!];
---

<header id="cinema-nav" class="cinema-nav">
  <a href={withBase('/')} class="font-display text-sm font-bold tracking-tight text-neutral-100">
    {site.name.split(' ')[0]}
  </a>

  <nav class="cinema-nav-links" aria-label="Main">
    {
      primaryLinks.map((link) => (
        <a
          href={withBase(link.href)}
          class="text-neutral-300"
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <details id="cinema-mobile-menu" class="cinema-nav-menu">
    <summary class="cinema-nav-toggle" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </summary>
    <nav class="cinema-nav-dropdown" aria-label="Mobile">
      {
        mobileLinks.map((link) => (
          <a href={withBase(link.href)} aria-current={isActive(link.href) ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
      <a href={withBase('/contact')} class="cinema-nav-cta">Start a project</a>
    </nav>
  </details>
</header>

<script>
  function initCinemaNav() {
    const header = document.getElementById('cinema-nav');
    const menu = document.getElementById('cinema-mobile-menu');
    if (!header || header.dataset.navBound) return;
    header.dataset.navBound = 'true';

    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 20);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    menu?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => menu.removeAttribute('open')),
    );
  }

  initCinemaNav();
  document.addEventListener('astro:page-load', initCinemaNav);
</script>
