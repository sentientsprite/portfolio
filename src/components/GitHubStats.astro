---
import type { GitHubStats } from '../lib/github';

interface Props {
  stats: GitHubStats;
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
  <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-5 text-center">
    <p class="font-display text-3xl font-bold text-[#f5c77a]">{stats.publicRepos}</p>
    <p class="mt-1 text-xs uppercase tracking-wider text-neutral-600">Repositories</p>
  </div>
  <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-5 text-center">
    <p class="font-display text-3xl font-bold text-[#f5c77a]">{stats.totalStars}</p>
    <p class="mt-1 text-xs uppercase tracking-wider text-neutral-600">Total stars</p>
  </div>
  <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-5 text-center">
    <p class="font-display text-3xl font-bold text-[#f5c77a]">{stats.topLanguages.length}</p>
    <p class="mt-1 text-xs uppercase tracking-wider text-neutral-600">Languages</p>
  </div>
  <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-5 text-center">
    <p class="font-display text-3xl font-bold text-[#f5c77a]">{stats.recentRepos.length}</p>
    <p class="mt-1 text-xs uppercase tracking-wider text-neutral-600">Recent updates</p>
  </div>
</div>

{
  stats.topLanguages.length > 0 && (
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {stats.topLanguages.map(({ language, count }) => (
        <span class="tech-pill">{language} ({count})</span>
      ))}
    </div>
  )
}
