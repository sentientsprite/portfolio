---
import type { GitHubStats } from '../lib/github';

interface Props {
  stats: GitHubStats;
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
  <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-5 text-center">
    <p class="text-3xl font-bold text-emerald-400">{stats.publicRepos}</p>
    <p class="mt-1 text-sm text-neutral-500">Repositories</p>
  </div>
  <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-5 text-center">
    <p class="text-3xl font-bold text-emerald-400">{stats.totalStars}</p>
    <p class="mt-1 text-sm text-neutral-500">Total Stars</p>
  </div>
  <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-5 text-center">
    <p class="text-3xl font-bold text-emerald-400">{stats.topLanguages.length}</p>
    <p class="mt-1 text-sm text-neutral-500">Languages</p>
  </div>
  <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-5 text-center">
    <p class="text-3xl font-bold text-emerald-400">{stats.recentRepos.length}</p>
    <p class="mt-1 text-sm text-neutral-500">Recent Updates</p>
  </div>
</div>

{
  stats.topLanguages.length > 0 && (
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {stats.topLanguages.map(({ language, count }) => (
        <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-sm text-emerald-400">
          {language} ({count})
        </span>
      ))}
    </div>
  )
}
