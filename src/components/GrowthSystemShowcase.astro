---
import type { MergedProject } from '../lib/github';
import { growthSystemById } from '../data/growth-systems';
import { withBase, resolveDemoUrl, slugify } from '../lib/url';
import ProjectCard from './ProjectCard.astro';

interface Props {
  systemId: string;
  systemProject: MergedProject;
  modules: MergedProject[];
}

const { systemId, systemProject, modules } = Astro.props;
const system = growthSystemById[systemId];
const demoUrl = resolveDemoUrl({ demoPath: systemProject.demoPath, demoUrl: systemProject.demoUrl });
const detailUrl = withBase(`/work/${systemProject.slug}`);
---

<section class="mb-16 overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/5 via-neutral-900/60 to-neutral-950" data-animate>
  <!-- Mobile: condensed, sales-focused card -->
  <div class="p-7 lg:hidden">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">Integrated growth stack</p>
    <h2 class="mt-3 text-2xl font-bold tracking-tight text-neutral-100">{system.name}</h2>
    <p class="mt-3 text-sm leading-relaxed text-neutral-400">{system.salesPitch}</p>

    <div class="mt-5 grid grid-cols-2 gap-2.5">
      {
        system.outcomes.map((outcome) => (
          <div class="rounded-xl border border-neutral-800 bg-neutral-950/50 p-3 text-center">
            <b class="block text-xl font-bold text-emerald-400">{outcome.value}</b>
            <span class="mt-0.5 block text-[11px] text-neutral-500">{outcome.label}</span>
          </div>
        ))
      }
    </div>

    <div class="mt-6 flex flex-col gap-2.5">
      <a
        href={detailUrl}
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-emerald-500 px-5 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-emerald-400"
      >
        See the full growth system &rarr;
      </a>
      {
        demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-neutral-700 px-5 py-3 text-sm font-medium text-neutral-300 transition hover:border-emerald-500/30 hover:text-emerald-400"
          >
            Open live demo &nearr;
          </a>
        )
      }
    </div>
  </div>

  <!-- Desktop: full integrated showcase -->
  <div class="hidden gap-0 lg:grid lg:grid-cols-[1.1fr_0.9fr]">
    <div class="border-b border-neutral-800 p-8 lg:border-b-0 lg:border-r lg:p-10">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">Integrated growth stack</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-neutral-100 sm:text-4xl">{system.name}</h2>
      <p class="mt-4 max-w-xl text-neutral-400">{system.pitch}</p>

      <div class="mt-8 space-y-3">
        {
          system.modules.map((mod, index) => {
            const project = modules.find((p) => p.name === mod.repoName);
            if (!project) return null;
            const href = withBase(`/work/${project.slug}`);
            return (
              <a
                href={href}
                class="group flex items-start gap-4 rounded-xl border border-neutral-800 bg-neutral-950/40 p-4 transition hover:border-emerald-500/30 hover:bg-emerald-500/5"
              >
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-emerald-500/10 text-sm font-bold text-emerald-400 ring-1 ring-emerald-500/20">
                  {index + 1}
                </span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="text-sm font-semibold text-neutral-100 group-hover:text-emerald-300">{mod.stageLabel}</span>
                    <span class="rounded-full bg-neutral-800 px-2 py-0.5 text-[11px] text-neutral-400">{project.displayName}</span>
                  </div>
                  <p class="mt-1 text-sm text-neutral-500">{mod.ownerBenefit}</p>
                </div>
                <span class="text-emerald-400 opacity-0 transition group-hover:opacity-100">&rarr;</span>
              </a>
            );
          })
        }
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        {
          demoUrl && (
            <a
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-neutral-950 transition hover:bg-emerald-400"
            >
              Open benefit showcase &nearr;
            </a>
          )
        }
        <a
          href={detailUrl}
          class="inline-flex items-center gap-2 rounded-lg border border-neutral-700 px-5 py-2.5 text-sm font-medium text-neutral-300 transition hover:border-emerald-500/30 hover:text-emerald-400"
        >
          System overview
        </a>
      </div>
    </div>

    <div class="p-8 lg:p-10">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">What the owner sees</p>
      <div class="mt-5 grid grid-cols-2 gap-3">
        {
          system.outcomes.map((outcome) => (
            <div class="rounded-xl border border-neutral-800 bg-neutral-950/50 p-4 text-center">
              <b class="block text-2xl font-bold text-emerald-400">{outcome.value}</b>
              <span class="mt-1 block text-xs text-neutral-500">{outcome.label}</span>
            </div>
          ))
        }
      </div>

      <div class="mt-6 rounded-xl border border-neutral-800 bg-neutral-950/50 p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">Tracked pipeline</p>
        <div class="mt-4 flex flex-col items-center gap-0">
          <div class="w-full rounded-lg border border-neutral-800 bg-neutral-900 px-4 py-3 text-center text-sm text-neutral-300">Traffic / SEO / Ads</div>
          <div class="h-5 w-px bg-gradient-to-b from-neutral-700 to-emerald-500/60"></div>
          <div class="w-full rounded-lg border border-emerald-500/20 bg-emerald-500/5 px-4 py-3 text-center text-sm text-emerald-300">Landing page + form capture</div>
          <div class="h-5 w-px bg-gradient-to-b from-emerald-500/60 to-emerald-500/60"></div>
          <div class="w-full rounded-lg border border-emerald-500/20 bg-emerald-500/5 px-4 py-3 text-center text-sm text-emerald-300">CRM sync + lead score</div>
          <div class="h-5 w-px bg-gradient-to-b from-emerald-500/60 to-neutral-700"></div>
          <div class="grid w-full grid-cols-2 gap-2">
            <div class="rounded-lg border border-neutral-800 bg-neutral-900 px-3 py-3 text-center text-xs text-neutral-400">Book via scheduler</div>
            <div class="rounded-lg border border-neutral-800 bg-neutral-900 px-3 py-3 text-center text-xs text-neutral-400">Nurture via email</div>
          </div>
          <div class="h-5 w-px bg-gradient-to-b from-neutral-700 to-emerald-500/60"></div>
          <div class="w-full rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-center text-sm font-medium text-emerald-300">Revenue + attribution dashboard</div>
        </div>
      </div>
    </div>
  </div>
</section>

{
  modules.length > 0 && (
    <section class="mb-16">
      <h3 class="mb-2 text-xl font-semibold text-neutral-100" data-animate>System modules</h3>
      <p class="mb-6 max-w-2xl text-sm text-neutral-500" data-animate>
        Each layer is a live, interactive demo. Together they form a full-stack integration from first click to booked revenue.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {modules.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )
}
