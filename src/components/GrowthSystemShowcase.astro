---
import type { MergedProject } from '../lib/github';
import { growthSystemById } from '../data/growth-systems';
import { withBase, resolveDemoUrl } from '../lib/url';
import ProjectCard from './ProjectCard.astro';

interface Props {
  systemId: string;
  systemProject: MergedProject;
  modules: MergedProject[];
}

const { systemId, systemProject, modules } = Astro.props;
const system = growthSystemById[systemId];
const demoUrl = resolveDemoUrl({ demoPath: systemProject.demoPath, demoUrl: systemProject.demoUrl });
const detailUrl = withBase(`/work/${systemProject.slug}`);
---

<section class="showcase-cinema mb-16" data-animate>
  <div class="grid gap-0 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="border-b border-[#1a1a1a] p-7 lg:border-b-0 lg:border-r lg:p-10">
      <p class="cinema-section-label mb-3">Lead-to-revenue stack</p>
      <h2 class="font-display text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl">
        {system.name}
      </h2>
      <p class="mt-4 max-w-xl text-neutral-500">{system.pitch}</p>

      <div class="mt-8 space-y-0 divide-y divide-[#1a1a1a]">
        {
          system.modules.map((mod, index) => {
            const project = modules.find((p) => p.name === mod.repoName);
            if (!project) return null;
            const href = withBase(`/work/${project.slug}`);
            return (
              <a href={href} class="showcase-module group flex items-start gap-4 p-4">
                <span class="font-display text-sm font-bold text-[#525252]">{String(index + 1).padStart(2, '0')}</span>
                <div class="min-w-0 flex-1">
                  <h4 class="text-sm font-semibold text-neutral-100 transition-colors group-hover:text-[#f5c77a]">
                    {mod.stageLabel}
                  </h4>
                  <p class="mt-0.5 text-xs text-neutral-500">{project.displayName}</p>
                  <p class="mt-1 text-sm text-neutral-600">{mod.ownerBenefit}</p>
                </div>
                <span class="text-[#d4a853] opacity-0 transition group-hover:opacity-100">&rarr;</span>
              </a>
            );
          })
        }
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        {
          demoUrl && (
            <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="btn-cinema btn-cinema-primary">
              Open live stack &nearr;
            </a>
          )
        }
        <a href={detailUrl} class="btn-cinema btn-cinema-ghost">
          Walk the stack
        </a>
      </div>
    </div>

    <div class="p-7 lg:p-10">
      <p class="cinema-section-label mb-3">Owner view</p>
      <div class="grid grid-cols-2 gap-3">
        {
          system.outcomes.map((outcome) => (
            <div class="showcase-metric border border-[#1a1a1a] bg-[#050505] p-4 text-center">
              <b class="block text-2xl font-bold">{outcome.value}</b>
              <span class="mt-1 block text-xs text-neutral-600">{outcome.label}</span>
            </div>
          ))
        }
      </div>

      <div class="mt-6 border border-[#1a1a1a] bg-[#050505] p-5">
        <p class="text-xs font-medium uppercase tracking-wider text-neutral-600">Tracked pipeline</p>
        <div class="mt-4 flex flex-col items-center gap-0">
          <div class="w-full border border-[#1a1a1a] bg-[#0a0a0a] px-4 py-3 text-center text-sm text-neutral-400">
            Traffic / SEO / Ads
          </div>
          <div class="h-4 w-px bg-[#262626]"></div>
          <div class="showcase-pipeline-active w-full px-4 py-3 text-center text-sm">Landing page + capture</div>
          <div class="h-4 w-px bg-[#262626]"></div>
          <div class="showcase-pipeline-active w-full px-4 py-3 text-center text-sm">CRM sync + lead score</div>
          <div class="h-4 w-px bg-[#262626]"></div>
          <div class="grid w-full grid-cols-2 gap-2">
            <div class="border border-[#1a1a1a] bg-[#0a0a0a] px-3 py-3 text-center text-xs text-neutral-500">Book via scheduler</div>
            <div class="border border-[#1a1a1a] bg-[#0a0a0a] px-3 py-3 text-center text-xs text-neutral-500">Nurture via email</div>
          </div>
          <div class="h-4 w-px bg-[#262626]"></div>
          <div class="showcase-pipeline-active w-full px-4 py-3 text-center text-sm font-medium">Attribution dashboard</div>
        </div>
      </div>
    </div>
  </div>
</section>

{
  modules.length > 0 && (
    <section class="mb-16">
      <p class="cinema-section-label" data-animate>Stack modules</p>
      <p class="mb-6 max-w-xl text-sm text-neutral-500" data-animate>
        Each opens as a live demo — simulated data where noted.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {modules.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )
}
