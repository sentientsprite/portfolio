---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
}

const { title, subtitle, eyebrow } = Astro.props;
---

<div class="mb-10">
  {eyebrow && <p class="cinema-section-label mb-3" data-animate>{eyebrow}</p>}
  <h2 class="font-display text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl" data-animate>
    {title}
  </h2>
  {subtitle && <p class="mt-3 max-w-2xl text-neutral-500" data-animate>{subtitle}</p>}
</div>
