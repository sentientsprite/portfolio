---
/**
 * JellyButton.astro — squishy 3D "gel" call-to-action button.
 * Styles live in global.css (`.jelly-btn`) as the site-wide primary CTA theme.
 */
interface Props {
  label: string;
  href?: string;
  eyebrow?: string;
  class?: string;
  external?: boolean;
  size?: 'sm' | 'md' | 'block';
  as?: 'a' | 'button';
  type?: 'button' | 'submit';
  disabled?: boolean;
  download?: boolean | string;
  suffix?: string;
  id?: string;
  'data-intake-submit'?: boolean;
}

const {
  href = '#',
  label,
  eyebrow,
  class: className,
  external = false,
  size = 'md',
  as = 'a',
  type = 'button',
  disabled = false,
  download,
  suffix,
  id,
  'data-intake-submit': dataIntakeSubmit,
} = Astro.props;

const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
const sizeClass =
  size === 'sm' ? 'jelly-btn--sm' : size === 'block' ? 'jelly-btn--block' : '';
const classes = ['jelly-btn', sizeClass, className];
---

{
  as === 'button' ? (
    <button
      id={id}
      type={type}
      disabled={disabled}
      class:list={classes}
      data-jelly
      data-intake-submit={dataIntakeSubmit || undefined}
    >
      <span class="jelly-btn__base" aria-hidden="true" />
      <span class="jelly-btn__body">
        <span class="jelly-btn__label">
          {eyebrow && <span class="jelly-btn__eyebrow">{eyebrow}</span>}
          <span class="jelly-btn__text">{label}</span>
        </span>
        {suffix && <span class="jelly-btn__suffix" aria-hidden="true">{suffix}</span>}
      </span>
    </button>
  ) : (
    <a
      id={id}
      href={href}
      download={download}
      target={target}
      rel={rel}
      class:list={classes}
      data-jelly
    >
      <span class="jelly-btn__base" aria-hidden="true" />
      <span class="jelly-btn__body">
        <span class="jelly-btn__label">
          {eyebrow && <span class="jelly-btn__eyebrow">{eyebrow}</span>}
          <span class="jelly-btn__text">{label}</span>
        </span>
        {suffix && <span class="jelly-btn__suffix" aria-hidden="true">{suffix}</span>}
      </span>
    </a>
  )
}
