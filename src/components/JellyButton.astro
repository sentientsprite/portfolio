---
/**
 * JellyButton.astro — squishy 3D "gel" call-to-action button.
 *
 * Inspired by the tactile jelly button on area21.io: glossy highlight, soft
 * drop shadow, and an elastic squish-and-wobble on hover/press. Renders as an
 * anchor so it works as a primary CTA link. Honors prefers-reduced-motion.
 */
interface Props {
  href: string;
  label: string;
  /** Optional sublabel shown above the main label. */
  eyebrow?: string;
  /** Pass-through extra classes for layout (margins, etc.). */
  class?: string;
  /** Open in a new tab. */
  external?: boolean;
}

const { href, label, eyebrow, class: className, external = false } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={['jelly-btn', className]}
  data-jelly
>
  <span class="jelly-btn__body">
    <span class="jelly-btn__shine" aria-hidden="true"></span>
    <span class="jelly-btn__label">
      {eyebrow && <span class="jelly-btn__eyebrow">{eyebrow}</span>}
      <span class="jelly-btn__text">{label}</span>
    </span>
  </span>
</a>

<style>
  .jelly-btn {
    --jelly-from: #34d399;
    --jelly-to: #059669;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    background: none;
    text-decoration: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
  }

  .jelly-btn__body {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.05rem 2.4rem;
    border-radius: 999px;
    background: linear-gradient(160deg, var(--jelly-from) 0%, var(--jelly-to) 100%);
    box-shadow:
      0 1px 0 1px rgba(255, 255, 255, 0.35) inset,
      0 -10px 18px -8px rgba(2, 44, 34, 0.85) inset,
      0 14px 28px -10px rgba(5, 150, 105, 0.7),
      0 6px 14px -6px rgba(0, 0, 0, 0.55);
    transform-origin: center bottom;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
    will-change: transform;
  }

  /* Glossy top highlight — the "wet jelly" sheen */
  .jelly-btn__shine {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 6px;
    height: 42%;
    border-radius: 999px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.55),
      rgba(255, 255, 255, 0)
    );
    pointer-events: none;
    filter: blur(0.3px);
  }

  .jelly-btn__label {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.05;
    color: #032018;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .jelly-btn__eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .jelly-btn__text {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  /* Hover: swell + lift */
  @media (hover: hover) {
    .jelly-btn:hover .jelly-btn__body {
      transform: scale(1.06, 0.97) translateY(-2px);
      box-shadow:
        0 1px 0 1px rgba(255, 255, 255, 0.45) inset,
        0 -12px 20px -8px rgba(2, 44, 34, 0.9) inset,
        0 20px 36px -10px rgba(5, 150, 105, 0.8),
        0 10px 20px -6px rgba(0, 0, 0, 0.55);
    }
  }

  /* Press: deep squish */
  .jelly-btn:active .jelly-btn__body {
    transform: scale(0.93, 1.08) translateY(1px);
    transition-duration: 0.12s;
  }

  /* Wobble keyframe fired via JS on click for an extra gel jiggle */
  .jelly-btn.is-wobbling .jelly-btn__body {
    animation: jelly-wobble 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes jelly-wobble {
    0% { transform: scale(0.9, 1.12) translateY(2px); }
    35% { transform: scale(1.08, 0.92) translateY(-3px); }
    60% { transform: scale(0.97, 1.04) translateY(0); }
    80% { transform: scale(1.02, 0.99); }
    100% { transform: scale(1, 1); }
  }

  .jelly-btn:focus-visible {
    outline: none;
  }
  .jelly-btn:focus-visible .jelly-btn__body {
    box-shadow:
      0 0 0 3px rgba(16, 185, 129, 0.45),
      0 1px 0 1px rgba(255, 255, 255, 0.35) inset,
      0 14px 28px -10px rgba(5, 150, 105, 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .jelly-btn__body,
    .jelly-btn:hover .jelly-btn__body,
    .jelly-btn:active .jelly-btn__body {
      transition: box-shadow 0.2s ease;
      transform: none;
      animation: none;
    }
    .jelly-btn.is-wobbling .jelly-btn__body {
      animation: none;
    }
  }
</style>

<script>
  function initJelly() {
    document.querySelectorAll<HTMLElement>('[data-jelly]').forEach((btn) => {
      if (btn.dataset.jellyBound) return;
      btn.dataset.jellyBound = 'true';
      btn.addEventListener('pointerdown', () => {
        const body = btn.querySelector('.jelly-btn__body');
        if (!body) return;
        btn.classList.remove('is-wobbling');
        // Force reflow so the animation can retrigger on rapid clicks.
        void (body as HTMLElement).offsetWidth;
        btn.classList.add('is-wobbling');
      });
      btn.addEventListener('animationend', () => btn.classList.remove('is-wobbling'));
    });
  }

  initJelly();
  document.addEventListener('astro:page-load', initJelly);
</script>
