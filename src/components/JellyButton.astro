---
/**
 * JellyButton.astro — squishy 3D "gel" call-to-action button.
 *
 * Combines three tactile-button ideas into one on-brand CTA:
 *  - a glossy "wet jelly" sheen + elastic squish/wobble (area21-style),
 *  - a 3D "pushable" base the raised cap presses down onto (pushable_button /
 *    3D-button), and
 *  - a pointer-anchored click ripple (reactive-button).
 * Renders as an anchor so it works as a primary CTA link. Honors
 * prefers-reduced-motion.
 */
interface Props {
  href: string;
  label: string;
  /** Optional sublabel shown above the main label. */
  eyebrow?: string;
  /** Pass-through extra classes for layout (margins, etc.). */
  class?: string;
  /** Open in a new tab. */
  external?: boolean;
  /** Visual size. 'sm' for compact placements like the navbar. */
  size?: 'sm' | 'md';
}

const { href, label, eyebrow, class: className, external = false, size = 'md' } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={['jelly-btn', size === 'sm' && 'jelly-btn--sm', className]}
  data-jelly
>
  <span class="jelly-btn__base" aria-hidden="true"></span>
  <span class="jelly-btn__body">
    <span class="jelly-btn__label">
      {eyebrow && <span class="jelly-btn__eyebrow">{eyebrow}</span>}
      <span class="jelly-btn__text">{label}</span>
    </span>
  </span>
</a>

<style>
  .jelly-btn {
    --jelly-from: #34d399;
    --jelly-to: #059669;
    --jelly-deep: #024a36;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0 7px; /* room for the pushable base edge below the cap */
    border: 0;
    background: none;
    text-decoration: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
  }

  /* Solid darker "socket" the cap presses into for a 3D pushable look. */
  .jelly-btn__base {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: linear-gradient(165deg, #056247 0%, var(--jelly-deep) 100%);
    box-shadow: 0 5px 12px -8px rgba(0, 0, 0, 0.6);
    z-index: 0;
  }

  .jelly-btn__body {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.05rem 2.4rem;
    border-radius: 999px;
    overflow: hidden; /* clip the click ripple to the pill */
    /* Glossy "wet jelly" sheen baked into the body: a soft top highlight that
       fades into the base gradient, so there is no hard inner box. */
    background:
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.45) 0%,
        rgba(255, 255, 255, 0.08) 32%,
        rgba(255, 255, 255, 0) 55%
      ),
      linear-gradient(165deg, var(--jelly-from) 0%, var(--jelly-to) 100%);
    box-shadow:
      0 -8px 14px -10px rgba(2, 44, 34, 0.7) inset,
      0 7px 14px -12px rgba(5, 150, 105, 0.7);
    transform: translateY(-4px); /* raised cap floats above the base */
    transform-origin: center bottom;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
    will-change: transform;
  }

  .jelly-btn__label {
    position: relative;
    z-index: 2; /* sit above the ripple */
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.05;
    color: #032018;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .jelly-btn__eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .jelly-btn__text {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  /* Compact variant — navbar and inline placements. */
  .jelly-btn--sm {
    padding: 0 0 5px;
  }
  .jelly-btn--sm .jelly-btn__body {
    padding: 0.5rem 1.25rem;
  }
  .jelly-btn--sm .jelly-btn__eyebrow {
    font-size: 0.5rem;
    letter-spacing: 0.16em;
  }
  .jelly-btn--sm .jelly-btn__text {
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* Pointer-anchored ripple (injected by JS on press). */
  :global(.jelly-btn__ripple) {
    position: absolute;
    z-index: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0) 70%);
    transform: translate(-50%, -50%) scale(0);
    pointer-events: none;
    animation: jelly-ripple 0.6s ease-out forwards;
  }

  @keyframes jelly-ripple {
    to {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0;
    }
  }

  /* Hover: swell + lift further off the base */
  @media (hover: hover) {
    .jelly-btn:hover .jelly-btn__body {
      transform: scale(1.05, 0.97) translateY(-6px);
      box-shadow:
        0 -10px 16px -10px rgba(2, 44, 34, 0.8) inset,
        0 12px 20px -14px rgba(5, 150, 105, 0.85);
    }
  }

  /* Press: deep squish down onto the base */
  .jelly-btn:active .jelly-btn__body {
    transform: scale(0.94, 1.07) translateY(0);
    transition-duration: 0.12s;
    box-shadow: 0 -8px 16px -10px rgba(2, 44, 34, 0.8) inset;
  }

  /* Wobble keyframe fired via JS on click for an extra gel jiggle */
  .jelly-btn.is-wobbling .jelly-btn__body {
    animation: jelly-wobble 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes jelly-wobble {
    0% { transform: scale(0.9, 1.12) translateY(0); }
    35% { transform: scale(1.08, 0.92) translateY(-7px); }
    60% { transform: scale(0.97, 1.04) translateY(-3px); }
    80% { transform: scale(1.02, 0.99) translateY(-4px); }
    100% { transform: scale(1, 1) translateY(-4px); }
  }

  .jelly-btn:focus-visible {
    outline: none;
  }
  .jelly-btn:focus-visible .jelly-btn__body {
    box-shadow:
      0 0 0 3px rgba(16, 185, 129, 0.45),
      0 -8px 14px -10px rgba(2, 44, 34, 0.7) inset,
      0 7px 14px -12px rgba(5, 150, 105, 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .jelly-btn__body,
    .jelly-btn:hover .jelly-btn__body,
    .jelly-btn:active .jelly-btn__body {
      transition: box-shadow 0.2s ease;
      transform: translateY(-4px);
      animation: none;
    }
    .jelly-btn.is-wobbling .jelly-btn__body {
      animation: none;
    }
    :global(.jelly-btn__ripple) {
      animation: none;
      display: none;
    }
  }
</style>

<script>
  function initJelly() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('[data-jelly]').forEach((btn) => {
      if (btn.dataset.jellyBound) return;
      btn.dataset.jellyBound = 'true';

      btn.addEventListener('pointerdown', (event) => {
        const body = btn.querySelector<HTMLElement>('.jelly-btn__body');
        if (!body) return;

        // Re-trigger the wobble even on rapid repeat clicks.
        btn.classList.remove('is-wobbling');
        void body.offsetWidth;
        btn.classList.add('is-wobbling');

        if (reduce) return;

        // Pointer-anchored ripple.
        const rect = body.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height) * 2.2;
        const ripple = document.createElement('span');
        ripple.className = 'jelly-btn__ripple';
        ripple.style.width = ripple.style.height = `${size}px`;
        ripple.style.left = `${(event as PointerEvent).clientX - rect.left}px`;
        ripple.style.top = `${(event as PointerEvent).clientY - rect.top}px`;
        ripple.addEventListener('animationend', () => ripple.remove());
        body.appendChild(ripple);
      });

      btn.addEventListener('animationend', (event) => {
        if ((event as AnimationEvent).animationName === 'jelly-wobble') {
          btn.classList.remove('is-wobbling');
        }
      });
    });
  }

  initJelly();
  document.addEventListener('astro:page-load', initJelly);
</script>
