---
import type { Product } from '../data/products';
import { withBase } from '../lib/url';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="card-cinema group flex flex-col" data-animate>
  <div class="card-cinema-thumb flex items-center justify-center bg-[#050505]">
    <img
      src={withBase(product.image)}
      alt={product.name}
      class="h-24 w-24 transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="card-cinema-body flex flex-1 flex-col">
    <div class="flex items-start justify-between gap-2">
      <h3 class="card-cinema-title">{product.name}</h3>
      <span class="font-display text-lg font-bold text-[#f5c77a]">{product.price}</span>
    </div>
    <p class="card-cinema-desc mt-2 flex-1">{product.description}</p>
    <a
      href={product.checkoutUrl}
      class="btn-cinema btn-cinema-ghost mt-5 inline-flex w-full justify-center"
    >
      Buy now
    </a>
  </div>
</article>
