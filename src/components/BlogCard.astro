---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  tags?: string[];
  type?: 'blog' | 'case-study';
}

const { title, description, href, date, tags = [], type = 'blog' } = Astro.props;
---

<article class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-5 transition-colors hover:border-emerald-500/30">
  {
    type === 'case-study' && (
      <span class="text-xs font-medium text-emerald-400">Case Study</span>
    )
  }
  <time class="block text-xs text-neutral-500" datetime={date}>{date}</time>
  <h3 class="mt-2 text-lg font-semibold text-neutral-100 group-hover:text-emerald-400 transition-colors">
    <a href={withBase(href)}>{title}</a>
  </h3>
  <p class="mt-2 text-sm text-neutral-400 line-clamp-2">{description}</p>
  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="rounded bg-neutral-800 px-2 py-0.5 text-xs text-neutral-500">{tag}</span>
        ))}
      </div>
    )
  }
</article>
