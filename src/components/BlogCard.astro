---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  tags?: string[];
  type?: 'blog' | 'case-study';
  external?: boolean;
  image?: string | null;
  source?: string;
}

const {
  title,
  description,
  href,
  date,
  tags = [],
  type = 'blog',
  external = false,
  image = null,
  source,
} = Astro.props;

const linkHref = external ? href : withBase(href);
const linkAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<article class="card-cinema group flex flex-col" data-animate>
  {
    image && (
      <a href={linkHref} {...linkAttrs} class="card-cinema-thumb block overflow-hidden">
        <img
          src={image}
          alt={title}
          class="aspect-[1200/630] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </a>
    )
  }
  <div class="card-cinema-body flex flex-1 flex-col">
    <div class="flex flex-wrap items-center gap-2">
      {
        type === 'case-study' && (
          <span class="card-cinema-cat text-[#d4a853]">Case study</span>
        )
      }
      {source && <span class="card-cinema-cat text-[#d4a853]">{source}</span>}
      <time class="text-xs text-neutral-600" datetime={date}>{date}</time>
    </div>
    <h3 class="card-cinema-title mt-2">
      <a href={linkHref} {...linkAttrs} class="transition-colors group-hover:text-[#f5c77a]">{title}</a>
    </h3>
    <p class="card-cinema-desc mt-2 flex-1 line-clamp-2">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="tech-pill">{tag}</span>
          ))}
        </div>
      )
    }
    {
      external && (
        <span class="mt-3 text-xs font-medium uppercase tracking-wider text-[#d4a853]">Read on Medium &nearr;</span>
      )
    }
  </div>
</article>
