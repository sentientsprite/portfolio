---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  tags?: string[];
  type?: 'blog' | 'case-study';
  external?: boolean;
  image?: string | null;
  source?: string;
}

const {
  title,
  description,
  href,
  date,
  tags = [],
  type = 'blog',
  external = false,
  image = null,
  source,
} = Astro.props;

const linkHref = external ? href : withBase(href);
const linkAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<article
  class="glow-card group flex flex-col overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 backdrop-blur-sm hover:border-emerald-500/30"
  data-animate
>
  {
    image && (
      <a
        href={linkHref}
        {...linkAttrs}
        class="block w-full overflow-hidden border-b border-neutral-800 bg-neutral-950"
      >
        <img
          src={image}
          alt={title}
          class="aspect-[1200/630] w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center gap-2">
      {
        type === 'case-study' && (
          <span class="text-xs font-medium text-emerald-400">Case Study</span>
        )
      }
      {
        source && (
          <span class="text-xs font-medium text-emerald-400">{source}</span>
        )
      }
      <time class="text-xs text-neutral-500" datetime={date}>{date}</time>
    </div>
    <h3 class="mt-2 text-lg font-semibold text-neutral-100 transition-colors group-hover:text-emerald-400">
      <a href={linkHref} {...linkAttrs}>{title}</a>
    </h3>
    <p class="mt-2 flex-1 text-sm text-neutral-400 line-clamp-2">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="rounded bg-neutral-800 px-2 py-0.5 text-xs text-neutral-500">{tag}</span>
          ))}
        </div>
      )
    }
    {
      external && (
        <span class="mt-3 text-xs font-medium text-emerald-400">Read on Medium &nearr;</span>
      )
    }
  </div>
</article>
