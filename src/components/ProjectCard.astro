---
import type { MergedProject } from '../lib/github';
import { categoryLabels } from '../data/projects';
import { withBase, resolveDemoUrl } from '../lib/url';

interface Props {
  project: MergedProject;
}

const { project } = Astro.props;
const title = project.displayName;
const detailUrl = withBase(`/work/${project.slug}`);
const demoUrl = resolveDemoUrl({ demoPath: project.demoPath, demoUrl: project.demoUrl });
const hasDemo = Boolean(demoUrl);
const hasSource = Boolean(project.htmlUrl);
---

<article
  class="glow-card group relative flex flex-col overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 backdrop-blur-sm hover:border-emerald-500/40"
  data-animate
  data-work-card
  data-preview-src={demoUrl ?? ''}
>
  <div class="relative h-48 w-full overflow-hidden bg-neutral-800/50" data-preview-holder>
    {
      project.screenshot ? (
        <img
          src={withBase(project.screenshot)}
          alt={`Screenshot of ${title}`}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center">
          <span class="text-4xl font-bold text-neutral-700">{title.charAt(0).toUpperCase()}</span>
        </div>
      )
    }

    {
      hasDemo && (
        <span class="absolute left-3 top-3 z-20 rounded-full bg-neutral-950/80 px-2.5 py-1 text-[11px] font-medium text-emerald-400 backdrop-blur">
          Live preview
        </span>
      )
    }

    <div class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center bg-neutral-950/0 opacity-0 transition group-hover:bg-neutral-950/40 group-hover:opacity-100">
      <span class="rounded-lg bg-emerald-500 px-3 py-1.5 text-xs font-semibold text-neutral-950">
        {hasDemo ? 'Hover to preview · Click to explore' : 'View details'}
      </span>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-2">
      <div>
        <span class="text-xs font-medium text-emerald-400">
          {project.growthSystemStage ?? categoryLabels[project.category]}
        </span>
        <h3 class="mt-1 text-lg font-semibold text-neutral-100 transition-colors group-hover:text-emerald-400">
          {title}
        </h3>
      </div>
      {
        project.stars > 0 && (
          <span class="flex items-center gap-1 text-xs text-neutral-500">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            {project.stars}
          </span>
        )
      }
    </div>
    <p class="mt-2 flex-1 text-sm text-neutral-400 line-clamp-3">{project.description}</p>
    {
      project.metrics.length > 0 && (
        <div class="mt-3 grid grid-cols-3 gap-2">
          {project.metrics.slice(0, 3).map((metric) => (
            <div class="rounded-lg border border-neutral-800 bg-neutral-950/50 px-1.5 py-2 text-center">
              <b class="block text-sm font-bold leading-tight text-emerald-400">{metric.value}</b>
              <span class="mt-0.5 block text-[10px] leading-tight text-neutral-500">{metric.label}</span>
            </div>
          ))}
        </div>
      )
    }
    {
      project.techStack.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {project.techStack.map((tech) => (
            <span class="rounded bg-neutral-800 px-2 py-0.5 text-xs text-neutral-400">{tech}</span>
          ))}
        </div>
      )
    }

    <div class="mt-4 flex items-center justify-between">
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-emerald-400 group-hover:text-emerald-300">
        View Work &rarr;
      </span>
      {
        hasSource && (
          <a
            href={project.htmlUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 text-xs text-neutral-500 hover:text-emerald-400"
          >
            GitHub
          </a>
        )
      }
    </div>
  </div>

  <!-- Stretched link: whole card navigates to the detail page -->
  <a href={detailUrl} class="absolute inset-0 z-0" aria-label={`Explore ${title}`}></a>
</article>

<script>
  function initWorkPreviews() {
    document.querySelectorAll('[data-work-card]').forEach((card) => {
      if (card.getAttribute('data-preview-init') === '1') return;
      const src = card.getAttribute('data-preview-src');
      const holder = card.querySelector('[data-preview-holder]');
      if (!src || !holder) return;
      card.setAttribute('data-preview-init', '1');

      let loaded = false;
      const load = () => {
        if (loaded) return;
        loaded = true;
        const iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.setAttribute('scrolling', 'no');
        iframe.setAttribute('tabindex', '-1');
        iframe.setAttribute('aria-hidden', 'true');
        iframe.style.position = 'absolute';
        iframe.style.inset = '0';
        iframe.style.border = '0';
        iframe.style.pointerEvents = 'none';
        iframe.style.opacity = '0';
        iframe.style.transition = 'opacity .25s ease';
        iframe.style.background = '#0a0a0a';

        const w = 1200;
        const scale = holder.clientWidth / w;
        iframe.style.width = w + 'px';
        iframe.style.height = holder.clientHeight / scale + 'px';
        iframe.style.transformOrigin = 'top left';
        iframe.style.transform = 'scale(' + scale + ')';

        holder.appendChild(iframe);
        requestAnimationFrame(() => {
          iframe.style.opacity = '1';
        });
      };

      card.addEventListener('pointerenter', load, { once: true });
    });
  }

  initWorkPreviews();
  document.addEventListener('astro:page-load', initWorkPreviews);
</script>
