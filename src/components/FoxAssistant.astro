---
/**
 * FoxAssistant.astro — animated green fox mascot + FAQ chatbot.
 *
 * The fox is the minimized chat widget. Click it to open the panel; conversation
 * history persists in sessionStorage for the whole browser session (same fox).
 */
import { buildChatbotConfig } from '../lib/chatbot/knowledge';

const chatbot = buildChatbotConfig();
const chatbotJson = JSON.stringify(chatbot);
---

<div id="fox-widget" class="fox-widget">
  <script id="fox-chatbot-config" type="application/json" set:html={chatbotJson}></script>
  <!-- Chat panel (opens above the fox) -->
  <div
    id="fox-chat"
    class="fox-chat"
    role="dialog"
    aria-labelledby="fox-chat-title"
    aria-hidden="true"
    hidden
  >
    <header class="fox-chat-header">
      <div class="fox-chat-heading">
        <p id="fox-chat-title" class="fox-chat-title">Fox Guide</p>
        <p class="fox-chat-sub">FAQ · demos · lead funnel</p>
      </div>
      <button type="button" id="fox-chat-close" class="fox-chat-close" aria-label="Minimize chat">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </header>

    <div id="fox-chat-messages" class="fox-chat-messages" aria-live="polite"></div>

    <form id="fox-chat-form" class="fox-chat-form">
      <label for="fox-chat-input" class="sr-only">Message</label>
      <input
        id="fox-chat-input"
        type="text"
        autocomplete="off"
        placeholder="Ask about services, demos, hiring…"
        maxlength="500"
      />
      <button type="submit" class="fox-chat-send" aria-label="Send message">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </button>
    </form>
  </div>

  <!-- Fox mascot trigger -->
  <button
    id="fox-assistant"
    class="fox-root"
    type="button"
    aria-label="Open chat assistant"
    aria-expanded="false"
    aria-controls="fox-chat"
    title="Chat with the fox guide"
  >
    <span class="fox-bubble" aria-hidden="true">Ask me anything!</span>

    <span class="fox-bob">
      <span class="fox-zzz" aria-hidden="true"><i>z</i><i>z</i><i>z</i></span>

      <svg class="fox-svg" viewBox="0 0 120 120" role="img" aria-hidden="true" focusable="false">
        <ellipse cx="60" cy="114" rx="30" ry="5" fill="#020617" opacity="0.4" />
        <g class="fox-tail">
          <path d="M46 94 C 12 96 6 58 27 47 C 21 61 27 78 48 75 C 52 84 52 91 46 94 Z" fill="#0f9d6f" />
          <path d="M27 47 C 19 53 16 63 18 71 C 10 61 13 50 27 47 Z" fill="#a7f3d0" />
        </g>
        <ellipse cx="62" cy="90" rx="25" ry="24" fill="#10b981" />
        <ellipse cx="62" cy="96" rx="13" ry="15" fill="#d1fae5" />
        <ellipse cx="53" cy="109" rx="6.5" ry="5" fill="#0b5e44" />
        <ellipse cx="71" cy="109" rx="6.5" ry="5" fill="#0b5e44" />
        <g class="fox-head">
          <path class="fox-ear fox-ear-l" d="M37 33 L30 7 L56 25 Z" fill="#10b981" />
          <path class="fox-ear fox-ear-r" d="M83 33 L90 7 L64 25 Z" fill="#10b981" />
          <path d="M39 30 L35 15 L51 26 Z" fill="#6ee7b7" />
          <path d="M81 30 L85 15 L69 26 Z" fill="#6ee7b7" />
          <circle cx="60" cy="50" r="30" fill="#10b981" />
          <ellipse cx="60" cy="62" rx="13" ry="11" fill="#ecfdf5" />
          <g class="fox-eyes">
            <ellipse cx="49" cy="50" rx="8" ry="9.5" fill="#ffffff" />
            <ellipse cx="71" cy="50" rx="8" ry="9.5" fill="#ffffff" />
            <g class="fox-pupils">
              <circle cx="49" cy="51.5" r="4.2" fill="#06281c" />
              <circle cx="71" cy="51.5" r="4.2" fill="#06281c" />
              <circle cx="47.4" cy="49.5" r="1.4" fill="#ffffff" />
              <circle cx="69.4" cy="49.5" r="1.4" fill="#ffffff" />
            </g>
          </g>
          <g class="fox-eyes-closed">
            <path d="M42 51 q7 6.5 15 0" stroke="#06281c" stroke-width="2.4" fill="none" stroke-linecap="round" />
            <path d="M63 51 q7 6.5 15 0" stroke="#06281c" stroke-width="2.4" fill="none" stroke-linecap="round" />
          </g>
          <path class="fox-nose" d="M55.5 60 q4.5 5.5 9 0 q-4.5 4.5 -9 0 Z" fill="#06281c" />
          <path d="M60 65 v4.5" stroke="#64748b" stroke-width="1.2" opacity="0.5" />
        </g>
      </svg>
    </span>
  </button>
</div>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .fox-widget {
    position: fixed;
    right: 22px;
    bottom: 18px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  /* ---- Chat panel ---- */
  .fox-chat {
    width: min(360px, calc(100vw - 32px));
    max-height: min(520px, calc(100vh - 140px));
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    border: 1px solid rgba(16, 185, 129, 0.35);
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(16px);
    box-shadow:
      0 24px 60px -20px rgba(0, 0, 0, 0.85),
      0 0 40px -10px rgba(16, 185, 129, 0.25);
    overflow: hidden;
    transform: translateY(12px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.28s ease,
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fox-widget.is-chat-open .fox-chat {
    transform: translateY(0) scale(1);
    opacity: 1;
    pointer-events: auto;
  }
  .fox-chat[hidden] {
    display: none;
  }
  .fox-widget.is-chat-open .fox-chat[hidden] {
    display: flex;
  }

  .fox-chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(38, 38, 38, 0.9);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), transparent 60%);
  }
  .fox-chat-title {
    font-size: 14px;
    font-weight: 600;
    color: #ecfdf5;
  }
  .fox-chat-sub {
    margin-top: 2px;
    font-size: 11px;
    color: #6ee7b7;
    opacity: 0.8;
  }
  .fox-chat-close {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 10px;
    border: 1px solid rgba(64, 64, 64, 0.8);
    background: rgba(23, 23, 23, 0.8);
    color: #a3a3a3;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .fox-chat-close:hover {
    color: #6ee7b7;
    border-color: rgba(16, 185, 129, 0.4);
  }

  .fox-chat-messages {
    flex: 1;
    min-height: 200px;
    overflow-y: auto;
    padding: 14px 14px 8px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }

  .fox-msg {
    max-width: 92%;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .fox-msg-user {
    align-self: flex-end;
    background: rgba(16, 185, 129, 0.2);
    border: 1px solid rgba(16, 185, 129, 0.35);
    color: #d1fae5;
    border-bottom-right-radius: 4px;
  }
  .fox-msg-bot {
    align-self: flex-start;
    background: rgba(23, 23, 23, 0.9);
    border: 1px solid rgba(64, 64, 64, 0.8);
    color: #d4d4d4;
    border-bottom-left-radius: 4px;
  }
  .fox-msg-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  .fox-msg-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 10px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 500;
    color: #6ee7b7;
    border: 1px solid rgba(16, 185, 129, 0.35);
    background: rgba(16, 185, 129, 0.08);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .fox-msg-link:hover {
    background: rgba(16, 185, 129, 0.18);
    border-color: rgba(16, 185, 129, 0.55);
  }

  .fox-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 14px 10px;
  }
  .fox-chip {
    padding: 6px 11px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 500;
    color: #a7f3d0;
    border: 1px solid rgba(16, 185, 129, 0.3);
    background: rgba(16, 185, 129, 0.06);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .fox-chip:hover {
    background: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.5);
  }

  .fox-lead-form {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .fox-lead-form input,
  .fox-lead-form textarea {
    width: 100%;
    padding: 8px 10px;
    border-radius: 10px;
    border: 1px solid rgba(64, 64, 64, 0.9);
    background: rgba(10, 10, 10, 0.8);
    color: #e5e5e5;
    font-size: 12px;
    font-family: inherit;
    resize: vertical;
  }
  .fox-lead-form input:focus,
  .fox-lead-form textarea:focus {
    outline: 2px solid rgba(16, 185, 129, 0.5);
    outline-offset: 1px;
  }
  .fox-lead-submit {
    padding: 8px 14px;
    border-radius: 9999px;
    border: 0;
    background: #10b981;
    color: #0a0a0a;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .fox-lead-submit:hover {
    background: #34d399;
  }

  .fox-typing {
    align-self: flex-start;
    display: flex;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 14px;
    background: rgba(23, 23, 23, 0.9);
    border: 1px solid rgba(64, 64, 64, 0.8);
  }
  .fox-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6ee7b7;
    animation: fox-dot 1.2s ease-in-out infinite;
  }
  .fox-typing span:nth-child(2) {
    animation-delay: 0.15s;
  }
  .fox-typing span:nth-child(3) {
    animation-delay: 0.3s;
  }
  @keyframes fox-dot {
    0%,
    80%,
    100% {
      opacity: 0.3;
      transform: translateY(0);
    }
    40% {
      opacity: 1;
      transform: translateY(-4px);
    }
  }

  .fox-chat-form {
    display: flex;
    gap: 8px;
    padding: 10px 12px 12px;
    border-top: 1px solid rgba(38, 38, 38, 0.9);
    background: rgba(10, 10, 10, 0.6);
  }
  .fox-chat-form input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 9999px;
    border: 1px solid rgba(64, 64, 64, 0.9);
    background: rgba(23, 23, 23, 0.9);
    color: #e5e5e5;
    font-size: 13px;
    font-family: inherit;
  }
  .fox-chat-form input:focus {
    outline: 2px solid rgba(16, 185, 129, 0.45);
    outline-offset: 1px;
  }
  .fox-chat-send {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 9999px;
    border: 0;
    background: #10b981;
    color: #0a0a0a;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .fox-chat-send:hover {
    background: #34d399;
    transform: scale(1.04);
  }

  /* ---- Fox mascot ---- */
  .fox-root {
    width: 96px;
    height: 96px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    transform: translateX(190px);
    opacity: 0;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.6s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .fox-root.is-running,
  .fox-root.is-seated {
    transform: translateX(0);
    opacity: 1;
  }
  .fox-widget.is-chat-open .fox-root {
    transform: translateX(0) scale(0.92);
  }
  .fox-root.is-seated {
    transition: transform 0.5s ease, opacity 0.4s ease;
  }
  .fox-root:hover {
    transform: translateX(0) translateY(-3px);
  }
  .fox-widget.is-chat-open .fox-root:hover {
    transform: translateX(0) scale(0.92) translateY(-2px);
  }

  .fox-bob {
    position: relative;
    display: block;
    transform-origin: 60% 100%;
  }
  .fox-svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
    filter: drop-shadow(0 6px 14px rgba(16, 185, 129, 0.4));
  }

  .fox-root.is-running .fox-bob {
    animation: fox-scamper 0.26s linear infinite;
  }
  @keyframes fox-scamper {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-7px) rotate(2deg);
    }
  }

  .fox-tail {
    transform-origin: 46px 84px;
  }
  .fox-root.is-running .fox-tail {
    animation: fox-wag 0.26s ease-in-out infinite;
  }
  .fox-root.is-watching .fox-tail {
    animation: fox-wag 1.7s ease-in-out infinite;
  }
  @keyframes fox-wag {
    0%,
    100% {
      transform: rotate(-7deg);
    }
    50% {
      transform: rotate(9deg);
    }
  }

  .fox-ear-r {
    transform-origin: 77px 28px;
  }
  .fox-root.is-watching .fox-ear-r {
    animation: fox-ear 4.5s ease-in-out infinite;
  }
  @keyframes fox-ear {
    0%,
    6%,
    100% {
      transform: rotate(0);
    }
    3% {
      transform: rotate(-8deg);
    }
  }

  .fox-pupils {
    transform: translate(var(--px, 0px), var(--py, 0px));
    transition: transform 0.12s ease-out;
  }

  .fox-eyes-closed {
    opacity: 0;
  }
  .fox-root.is-sleeping .fox-eyes {
    opacity: 0;
  }
  .fox-root.is-sleeping .fox-eyes-closed {
    opacity: 1;
  }
  .fox-widget.is-chat-open .fox-root .fox-eyes-closed {
    opacity: 0;
  }
  .fox-widget.is-chat-open .fox-root .fox-eyes {
    opacity: 1;
  }

  .fox-root.is-sleeping .fox-bob {
    animation: fox-breathe 3.2s ease-in-out infinite;
  }
  @keyframes fox-breathe {
    0%,
    100% {
      transform: scale(1) translateY(0);
    }
    50% {
      transform: scale(1.035) translateY(-1px);
    }
  }

  .fox-zzz {
    position: absolute;
    top: 0;
    right: 6px;
    display: flex;
    align-items: flex-end;
    gap: 1px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .fox-zzz i {
    font-style: normal;
    font-weight: 700;
    color: #6ee7b7;
    line-height: 1;
    opacity: 0;
    text-shadow: 0 0 8px rgba(110, 231, 183, 0.6);
  }
  .fox-zzz i:nth-child(1) {
    font-size: 9px;
  }
  .fox-zzz i:nth-child(2) {
    font-size: 12px;
  }
  .fox-zzz i:nth-child(3) {
    font-size: 15px;
  }
  .fox-root.is-sleeping .fox-zzz {
    opacity: 1;
  }
  .fox-widget.is-chat-open .fox-zzz {
    opacity: 0 !important;
  }
  .fox-root.is-sleeping .fox-zzz i {
    animation: fox-z 2.4s ease-in-out infinite;
  }
  .fox-root.is-sleeping .fox-zzz i:nth-child(2) {
    animation-delay: 0.45s;
  }
  .fox-root.is-sleeping .fox-zzz i:nth-child(3) {
    animation-delay: 0.9s;
  }
  @keyframes fox-z {
    0% {
      opacity: 0;
      transform: translate(0, 4px) scale(0.7);
    }
    30% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate(7px, -14px) scale(1.1);
    }
  }

  .fox-bubble {
    position: absolute;
    bottom: 80%;
    right: 64%;
    white-space: nowrap;
    background: rgba(10, 10, 10, 0.85);
    border: 1px solid rgba(16, 185, 129, 0.4);
    color: #d1fae5;
    font-size: 11px;
    font-weight: 500;
    padding: 6px 10px;
    border-radius: 10px;
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.8);
    opacity: 0;
    transform: translateY(6px) scale(0.96);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }
  .fox-root.is-greeting .fox-bubble,
  .fox-root:hover .fox-bubble {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .fox-widget.is-chat-open .fox-bubble {
    opacity: 0;
  }

  @media (max-width: 480px) {
    .fox-widget {
      right: 12px;
      bottom: 12px;
    }
    .fox-root {
      width: 80px;
      height: 80px;
    }
    .fox-chat {
      width: calc(100vw - 24px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fox-root,
    .fox-bob,
    .fox-tail,
    .fox-ear-r,
    .fox-zzz i,
    .fox-pupils,
    .fox-chat {
      animation: none !important;
      transition: opacity 0.2s ease !important;
    }
    .fox-root {
      transform: translateX(0);
    }
  }
</style>

<script>
  import { respond, greetingMessage } from '../lib/chatbot/engine';

  const STORAGE_KEY = 'rk-chat-history';
  const FOX_KEY = 'rk-fox';

  function readChatbotConfig() {
    const el = document.getElementById('fox-chatbot-config');
    if (!el?.textContent) return null;
    try {
      return JSON.parse(el.textContent);
    } catch {
      return null;
    }
  }

  function initFoxWidget() {
    const chatbot = readChatbotConfig();
    if (!chatbot) return;

    const widget = document.getElementById('fox-widget');
    const root = document.getElementById('fox-assistant');
    const chat = document.getElementById('fox-chat');
    const closeBtn = document.getElementById('fox-chat-close');
    const messagesEl = document.getElementById('fox-chat-messages');
    const form = document.getElementById('fox-chat-form');
    const input = document.getElementById('fox-chat-input');

    if (!widget || !root || !chat || !messagesEl || !form || !input) return;
    if (widget.dataset.foxWidgetInit) return;
    widget.dataset.foxWidgetInit = '1';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SLEEP_AFTER = 5000;
    const INTRO_DELAY = 3000;
    let sleepTimer;
    let greetTimer;
    let awake = false;
    let chatOpen = false;
    let raf = 0;
    let messages = loadHistory();

    function loadHistory() {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch {
        return [];
      }
    }

    function saveHistory() {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(messages));
    }

    function sleep() {
      if (chatOpen) return;
      root.classList.remove('is-watching');
      root.classList.add('is-sleeping');
      awake = false;
    }

    function watch() {
      root.classList.remove('is-sleeping');
      root.classList.add('is-watching');
      awake = true;
      window.clearTimeout(sleepTimer);
      if (!chatOpen) sleepTimer = window.setTimeout(sleep, SLEEP_AFTER);
    }

    function greet(ms) {
      root.classList.add('is-greeting');
      window.clearTimeout(greetTimer);
      greetTimer = window.setTimeout(() => root.classList.remove('is-greeting'), ms);
    }

    function arrive() {
      root.classList.remove('is-running');
      root.classList.add('is-seated');
      greet(2600);
      watch();
    }

    if (sessionStorage.getItem(FOX_KEY)) {
      root.classList.add('is-seated');
      greet(2000);
      requestAnimationFrame(watch);
    } else {
      window.setTimeout(() => {
        sessionStorage.setItem(FOX_KEY, '1');
        if (reduced) return arrive();
        root.classList.add('is-running');
        window.setTimeout(arrive, 1150);
      }, INTRO_DELAY);
    }

    window.addEventListener(
      'pointermove',
      (e) => {
        if (!awake || raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          const r = root.getBoundingClientRect();
          const dx = e.clientX - (r.left + r.width / 2);
          const dy = e.clientY - (r.top + r.height * 0.42);
          const dist = Math.hypot(dx, dy) || 1;
          const max = 2.6;
          root.style.setProperty('--px', `${((dx / dist) * max).toFixed(2)}px`);
          root.style.setProperty('--py', `${((dy / dist) * max).toFixed(2)}px`);
        });
      },
      { passive: true },
    );

    root.addEventListener('pointerenter', () => {
      if (!awake) watch();
    });

    function openChat() {
      chatOpen = true;
      widget.classList.add('is-chat-open');
      chat.hidden = false;
      chat.setAttribute('aria-hidden', 'false');
      root.setAttribute('aria-expanded', 'true');
      watch();
      window.clearTimeout(sleepTimer);

      if (messages.length === 0) {
        const greeting = greetingMessage(chatbot);
        messages.push(greeting);
        saveHistory();
      }
      renderMessages();
      input.focus();
    }

    function closeChat() {
      chatOpen = false;
      widget.classList.remove('is-chat-open');
      chat.setAttribute('aria-hidden', 'true');
      root.setAttribute('aria-expanded', 'false');
      window.setTimeout(() => {
        if (!chatOpen) chat.hidden = true;
      }, 280);
      watch();
    }

    function toggleChat() {
      if (chatOpen) closeChat();
      else openChat();
    }

    root.addEventListener('click', (e) => {
      e.preventDefault();
      toggleChat();
    });
    closeBtn?.addEventListener('click', closeChat);

    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderLeadForm() {
      return `
        <form class="fox-lead-form" data-lead-form>
          <input type="text" name="name" placeholder="Your name" required maxlength="80" />
          <input type="email" name="email" placeholder="Email" required maxlength="120" />
          <textarea name="need" rows="3" placeholder="What are you building? (site, funnel, automation…)" required maxlength="800"></textarea>
          <button type="submit" class="fox-lead-submit">Send to Raymond</button>
        </form>`;
    }

    function renderMessages() {
      messagesEl.innerHTML = '';
      for (const msg of messages) {
        const el = document.createElement('div');
        el.className = `fox-msg fox-msg-${msg.role}`;
        el.innerHTML = escapeHtml(msg.text);

        if (msg.links?.length) {
          const links = document.createElement('div');
          links.className = 'fox-msg-links';
          for (const link of msg.links) {
            const a = document.createElement('a');
            a.className = 'fox-msg-link';
            a.href = link.href;
            a.textContent = link.label;
            if (link.href.startsWith('http') || link.href.startsWith('mailto')) {
              a.target = link.href.startsWith('http') ? '_blank' : '_self';
              if (link.href.startsWith('http')) a.rel = 'noopener noreferrer';
            }
            links.appendChild(a);
          }
          el.appendChild(links);
        }

        if (msg.showLeadForm) {
          const wrap = document.createElement('div');
          wrap.innerHTML = renderLeadForm();
          el.appendChild(wrap.firstElementChild);
        }

        messagesEl.appendChild(el);
      }

      // Quick-reply chips from the latest bot message
      const existingChips = widget.querySelector('.fox-chips');
      existingChips?.remove();
      const lastBot = [...messages].reverse().find((m) => m.role === 'bot');
      if (lastBot?.quickReplies?.length) {
        const chips = document.createElement('div');
        chips.className = 'fox-chips';
        for (const label of lastBot.quickReplies) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'fox-chip';
          btn.textContent = label;
          btn.addEventListener('click', () => sendUserMessage(label));
          chips.appendChild(btn);
        }
        messagesEl.after(chips);
      }

      messagesEl.querySelectorAll('[data-lead-form]').forEach((leadForm) => {
        leadForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const fd = new FormData(leadForm);
          const name = String(fd.get('name') || '').trim();
          const email = String(fd.get('email') || '').trim();
          const need = String(fd.get('need') || '').trim();
          const subject = encodeURIComponent(`Project inquiry from ${name}`);
          const body = encodeURIComponent(
            `Name: ${name}\nEmail: ${email}\n\nProject details:\n${need}\n\n(Sent via portfolio fox chatbot)`,
          );
          window.location.href = `mailto:${chatbot.email}?subject=${subject}&body=${body}`;
          const confirm = {
            id: `bot-${Date.now()}`,
            role: 'bot',
            text: `Opening your email app with a draft to ${chatbot.email}. Raymond typically replies within 1–2 business days.`,
            time: Date.now(),
          };
          messages.push(confirm);
          saveHistory();
          renderMessages();
        });
      });

      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTyping() {
      const el = document.createElement('div');
      el.className = 'fox-typing';
      el.id = 'fox-typing';
      el.innerHTML = '<span></span><span></span><span></span>';
      messagesEl.appendChild(el);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function hideTyping() {
      document.getElementById('fox-typing')?.remove();
    }

    function sendUserMessage(text) {
      const trimmed = text.trim();
      if (!trimmed) return;

      messages.push({
        id: `user-${Date.now()}`,
        role: 'user',
        text: trimmed,
        time: Date.now(),
      });
      saveHistory();
      renderMessages();
      input.value = '';

      if (!chatOpen) openChat();

      showTyping();
      const delay = reduced ? 0 : 400 + Math.random() * 300;
      window.setTimeout(() => {
        hideTyping();
        const reply = respond(trimmed, chatbot);
        messages.push(reply);
        saveHistory();
        renderMessages();
        watch();
      }, delay);
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      sendUserMessage(input.value);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && chatOpen) closeChat();
    });
  }

  initFoxWidget();
  document.addEventListener('astro:page-load', initFoxWidget);
</script>
