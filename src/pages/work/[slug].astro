---
import CinematicLayout from '../../layouts/CinematicLayout.astro';
import { getMergedProjects, type MergedProject } from '../../lib/github';
import { categoryLabels } from '../../data/projects';
import { growthSystemById } from '../../data/growth-systems';
import { withBase, resolveDemoUrl } from '../../lib/url';
import WorkCTA from '../../components/WorkCTA.astro';

export async function getStaticPaths() {
  const projects = await getMergedProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: MergedProject;
}

const { project } = Astro.props;
const allProjects = await getMergedProjects();
const demoUrl = resolveDemoUrl({ demoPath: project.demoPath, demoUrl: project.demoUrl });
const hasDemo = Boolean(demoUrl);
const isMeta = project.category === 'meta';
const hasSource = Boolean(project.htmlUrl);
const displayUrl = demoUrl ? demoUrl.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';

const growthSystem = project.growthSystemId ? growthSystemById[project.growthSystemId] : null;
const systemModules = project.growthSystemId
  ? allProjects.filter((p) => p.growthSystemId === project.growthSystemId)
  : [];
const isGrowthSystemHub = project.slug === 'growth-system';
const heroImage = project.screenshot ? withBase(`/${project.screenshot}`) : null;
---

<CinematicLayout title={project.displayName} description={project.description}>
  <article>
    <header class="project-hero" data-animate>
      <a
        href={withBase('/work')}
        class="mb-8 inline-block font-body text-xs uppercase tracking-[0.2em] text-neutral-600 transition hover:text-neutral-300"
      >
        &larr; All work
      </a>

      {
        growthSystem && !isGrowthSystemHub && (
          <a
            href={withBase('/work/growth-system')}
            class="mb-4 inline-block text-xs uppercase tracking-[0.18em] text-[#d4a853] hover:text-[#f5c77a]"
          >
            {growthSystem.name}
            {project.growthSystemStage ? ` · ${project.growthSystemStage}` : ''}
          </a>
        )
      }

      <p class="project-hero-label">{categoryLabels[project.category]}</p>
      <h1 class="project-hero-title">{project.displayName}</h1>
      <p class="project-hero-desc">{project.description}</p>

      {
        project.techStack.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {project.techStack.map((tech) => (
              <span class="tech-pill">{tech}</span>
            ))}
          </div>
        )
      }

      <div class="mt-8 flex flex-wrap gap-3">
        {
          hasDemo ? (
            <a
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-cinema btn-cinema-primary"
            >
              {isMeta ? 'Visit live site' : 'Open live demo'} &nearr;
            </a>
          ) : (
            <span class="btn-cinema btn-cinema-ghost cursor-default opacity-50">
              Demo coming soon
            </span>
          )
        }
        {
          hasSource && (
            <a
              href={project.htmlUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-cinema btn-cinema-ghost"
            >
              GitHub
            </a>
          )
        }
      </div>
    </header>

    {
      project.metrics.length > 0 && (
        <section class="mx-auto mb-10 max-w-6xl px-[clamp(1.25rem,4vw,3rem)]" data-animate>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {project.metrics.map((metric) => (
              <div class="border border-[#1a1a1a] p-4 text-center">
                <b class="font-display block text-2xl font-bold text-[#f5c77a]">{metric.value}</b>
                <span class="mt-1 block text-xs uppercase tracking-wider text-neutral-600">
                  {metric.label}
                </span>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      hasDemo ? (
        <div class="project-media-full" data-animate>
          <iframe
            src={demoUrl}
            title={`${project.displayName} live demo`}
            loading="lazy"
            class="min-h-[70vh] w-full border-0 bg-white"
          />
        </div>
      ) : heroImage ? (
        <div class="project-media-full" data-animate>
          <img
            src={heroImage}
            alt={`${project.displayName} preview`}
            class="min-h-[40vh] w-full object-cover"
            loading="lazy"
          />
        </div>
      ) : (
        <div
          class="project-media-full flex min-h-[16rem] items-center justify-center"
          data-animate
        >
          <p class="text-sm text-neutral-600">Interactive demo on the way.</p>
        </div>
      )
    }

    {
      project.details && (
        <section class="project-detail-body" data-animate>
          <h2>About this build</h2>
          <p>{project.details}</p>
        </section>
      )
    }

    {
      isGrowthSystemHub && systemModules.length > 0 && (
        <section class="mx-auto max-w-6xl px-[clamp(1.25rem,4vw,3rem)] pb-16" data-animate>
          <p class="cinema-section-label">Modules</p>
          <div class="divide-y divide-[#1a1a1a]">
            {
              systemModules.map((mod, i) => (
                <a href={withBase(`/work/${mod.slug}`)} class="work-row group">
                  <span class="work-row-index">{String(i + 1).padStart(2, '0')}</span>
                  <div class="work-row-body">
                    <h3>{mod.displayName}</h3>
                    <p class="work-row-meta">{mod.growthSystemStage}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      )
    }

    {!isMeta && (
      <div class="px-[clamp(1.25rem,4vw,3rem)] pb-16">
        <WorkCTA projectName={project.displayName} />
      </div>
    )}
  </article>
</CinematicLayout>
