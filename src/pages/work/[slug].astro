---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMergedProjects, type MergedProject } from '../../lib/github';
import { categoryLabels } from '../../data/projects';
import { withBase, resolveDemoUrl } from '../../lib/url';

export async function getStaticPaths() {
  const projects = await getMergedProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: MergedProject;
}

const { project } = Astro.props;
const demoUrl = resolveDemoUrl({ demoPath: project.demoPath, demoUrl: project.demoUrl });
const hasDemo = Boolean(demoUrl);
const isMeta = project.category === 'meta';
const displayUrl = demoUrl
  ? demoUrl.replace(/^https?:\/\//, '').replace(/\/$/, '')
  : '';
---

<BaseLayout title={project.displayName} description={project.description}>
  <div class="mx-auto max-w-5xl px-4 py-12">
    <a
      href={withBase('/work')}
      class="inline-flex items-center gap-1 text-sm text-neutral-400 transition-colors hover:text-emerald-400"
    >
      &larr; Back to Work
    </a>

    <header class="mt-6">
      <span class="text-sm font-medium text-emerald-400">{categoryLabels[project.category]}</span>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-neutral-100">{project.displayName}</h1>
      <p class="mt-3 max-w-2xl text-lg text-neutral-400">{project.description}</p>

      {
        project.techStack.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {project.techStack.map((tech) => (
              <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs text-emerald-400">{tech}</span>
            ))}
          </div>
        )
      }

      <div class="mt-6 flex flex-wrap gap-3">
        {
          hasDemo ? (
            <a
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-neutral-950 transition-colors hover:bg-emerald-400"
            >
              {isMeta ? 'Visit Live Site' : 'Open Live Demo'} &nearr;
            </a>
          ) : (
            <span class="inline-flex items-center gap-2 rounded-lg border border-neutral-800 px-5 py-2.5 text-sm font-medium text-neutral-500">
              Live demo coming soon
            </span>
          )
        }
        <a
          href={project.htmlUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-neutral-700 px-5 py-2.5 text-sm font-medium text-neutral-300 transition-colors hover:border-emerald-500/30 hover:text-emerald-400"
        >
          View Source on GitHub
        </a>
      </div>
    </header>

    {
      hasDemo ? (
        <div class="mt-10 overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 shadow-2xl">
          <div class="flex items-center gap-2 border-b border-neutral-800 bg-neutral-950/60 px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-neutral-700" />
            <span class="h-3 w-3 rounded-full bg-neutral-700" />
            <span class="h-3 w-3 rounded-full bg-neutral-700" />
            <span class="ml-3 flex-1 truncate rounded-md bg-neutral-800 px-3 py-1 text-xs text-neutral-400">
              {displayUrl}
            </span>
            <a
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium text-emerald-400 hover:text-emerald-300"
            >
              Open &nearr;
            </a>
          </div>
          <iframe
            src={demoUrl}
            title={`${project.displayName} live demo`}
            loading="lazy"
            class="h-[70vh] w-full border-0 bg-white"
          />
        </div>
      ) : (
        <div class="mt-10 flex h-64 items-center justify-center rounded-xl border border-dashed border-neutral-800 bg-neutral-900/50">
          <p class="text-sm text-neutral-500">An interactive demo for this project is on the way.</p>
        </div>
      )
    }

    {
      project.details && (
        <section class="mt-10 max-w-3xl">
          <h2 class="text-xl font-semibold text-neutral-100">About this project</h2>
          <p class="mt-3 leading-relaxed text-neutral-400">{project.details}</p>
        </section>
      )
    }

    <div class="mt-12 border-t border-neutral-800 pt-8">
      <a
        href={withBase('/work')}
        class="text-sm font-medium text-emerald-400 transition-colors hover:text-emerald-300"
      >
        &larr; Explore more work
      </a>
    </div>
  </div>
</BaseLayout>
