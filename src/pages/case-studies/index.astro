---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('caseStudies', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Case Studies" description="In-depth research and project case studies.">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading title="Case Studies" subtitle="Detailed breakdowns of projects and results" />
    <div class="grid gap-6 sm:grid-cols-2">
      {studies.map((study) => (
        <BlogCard
          title={study.data.title}
          description={study.data.description}
          href={`case-studies/${study.id}`}
          date={study.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          tags={study.data.tags}
          type="case-study"
        />
      ))}
    </div>
  </div>
</BaseLayout>
