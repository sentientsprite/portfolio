---
import CinematicLayout from '../../layouts/CinematicLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';

const studies = (await getCollection('caseStudies', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<CinematicLayout title="Case Studies" description="In-depth research and project case studies.">
  <div class="work-catalog">
    <header class="work-catalog-header" data-animate>
      <p class="cinema-section-label mb-0">Proof</p>
      <h1 class="work-catalog-title">Case Studies</h1>
      <p class="max-w-xl text-neutral-500">Breakdowns with measurable outcomes — not vanity metrics.</p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2">
      {studies.map((study) => (
        <BlogCard
          title={study.data.title}
          description={study.data.description}
          href={`case-studies/${study.id}`}
          date={study.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
          tags={study.data.tags}
          type="case-study"
          image={study.data.heroImage ? withBase(study.data.heroImage) : null}
        />
      ))}
    </div>
  </div>
</CinematicLayout>
