---
import CinematicLayout from '../layouts/CinematicLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import GitHubStats from '../components/GitHubStats.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import { site } from '../config/site';
import { getMergedProjects, fetchGitHubStats } from '../lib/github';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';
import { fetchMediumPosts } from '../lib/medium';

const projects = await getMergedProjects();
const growthSystem = projects.find((p) => p.slug === 'growth-system');
const selectedWork = growthSystem
  ? [growthSystem, ...projects.filter((p) => p.featured && p.slug !== 'growth-system').slice(0, 2)]
  : projects.filter((p) => p.featured).slice(0, 3);
const stats = await fetchGitHubStats();

const caseStudies = (await getCollection('caseStudies', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const mediumPosts = (await fetchMediumPosts(3)).slice(0, 3);
---

<CinematicLayout
  title="Overview"
  description="Portfolio overview for Raymond King, Marketing Systems Builder: case studies, selected work, writing, and proof of practical business systems."
>
  <div class="work-catalog">
    <header class="work-catalog-header text-center" data-animate>
      <p class="cinema-section-label mb-0">{site.title}</p>
      <h1 class="work-catalog-title mx-auto">{site.name}</h1>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-500">
        I build conversion websites, CRM workflows, follow-up automation, and dashboards that help
        businesses capture leads and understand what's working.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={withBase('/case-studies')} class="btn-cinema btn-cinema-primary">See results</a>
        <a href={withBase('/work')} class="btn-cinema btn-cinema-ghost">View work</a>
        <a href={withBase('/contact')} class="btn-cinema btn-cinema-ghost">Get in touch</a>
      </div>
    </header>

    <section class="border-t border-[#1a1a1a] py-16">
      <SectionHeading eyebrow="About" title="Who I am and what I do" />
      <p class="max-w-3xl leading-relaxed text-neutral-500" data-animate>{site.bio}</p>
      <div class="mt-6 flex flex-wrap gap-2" data-animate>
        {
          site.skills.map((skill) => (
            <span class="tech-pill">{skill}</span>
          ))
        }
      </div>
    </section>

    {
      caseStudies.length > 0 && (
        <section class="border-t border-[#1a1a1a] py-16">
          <SectionHeading eyebrow="Proof" title="Case studies with measurable outcomes" />
          <div class="grid gap-6 sm:grid-cols-2">
            {caseStudies.map((study) => (
              <BlogCard
                title={study.data.title}
                description={study.data.description}
                href={`case-studies/${study.id}`}
                date={study.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
                tags={study.data.tags}
                type="case-study"
              />
            ))}
          </div>
          <div class="mt-8 text-center">
            <a href={withBase('/case-studies')} class="btn-cinema btn-cinema-ghost inline-flex">
              All case studies &rarr;
            </a>
          </div>
        </section>
      )
    }

    {
      selectedWork.length > 0 && (
        <section class="border-t border-[#1a1a1a] py-16">
          <SectionHeading eyebrow="Selected work" title="Growth systems and product builds" />
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {selectedWork.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
          <div class="mt-8 text-center">
            <a href={withBase('/work')} class="btn-cinema btn-cinema-ghost inline-flex">
              Full work index &rarr;
            </a>
          </div>
        </section>
      )
    }

    {
      mediumPosts.length > 0 && (
        <section class="border-t border-[#1a1a1a] py-16">
          <SectionHeading eyebrow="Writing" title="Latest on Medium" />
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {mediumPosts.map((post) => (
              <BlogCard
                title={post.title}
                description={post.snippet}
                href={post.link}
                date={post.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
                tags={post.categories}
                image={post.thumbnail}
                external={true}
                source="Medium"
              />
            ))}
          </div>
          <div class="mt-8 text-center">
            <a href={withBase('/blog')} class="btn-cinema btn-cinema-ghost inline-flex">
              Read the blog &rarr;
            </a>
          </div>
        </section>
      )
    }

    <section class="border-t border-[#1a1a1a] py-16">
      <SectionHeading eyebrow="GitHub" title="Open source and ongoing builds" />
      <GitHubStats stats={stats} />
      <div class="mt-8">
        <ContributionGraph />
      </div>
    </section>

    <section class="border-t border-[#1a1a1a] py-16">
      <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-10 text-center sm:p-14" data-animate>
        <h2 class="font-display text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl">
          Need a system, not just a site?
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-neutral-500">
          Let's map your capture, follow-up, and reporting gaps.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={withBase('/contact')} class="btn-cinema btn-cinema-primary">Contact me</a>
          <a href={withBase('/resume')} class="btn-cinema btn-cinema-ghost">View resume</a>
        </div>
      </div>
    </section>
  </div>
</CinematicLayout>
