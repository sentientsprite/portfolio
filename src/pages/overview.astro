---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import GitHubStats from '../components/GitHubStats.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import { site } from '../config/site';
import { getMergedProjects, fetchGitHubStats } from '../lib/github';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';
import { fetchMediumPosts } from '../lib/medium';

const projects = await getMergedProjects();
const selectedWork = projects.filter((p) => p.featured).slice(0, 3);
const stats = await fetchGitHubStats();

const caseStudies = (await getCollection('caseStudies', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const mediumPosts = (await fetchMediumPosts(3)).slice(0, 3);
---

<BaseLayout title="Overview" description="Portfolio overview — case studies, selected work, writing, and GitHub activity.">
  <!-- 1. Hero -->
  <section class="mx-auto max-w-6xl px-4 py-24 text-center">
    <p class="eyebrow justify-center" data-animate>Digital Marketing &amp; Web Development</p>
    <h1
      class="mt-4 text-5xl font-bold tracking-tight sm:text-6xl"
      data-animate
    >
      <span class="bg-gradient-to-r from-neutral-100 via-neutral-100 to-emerald-300 bg-clip-text text-transparent">
        {site.name}
      </span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-400" data-animate>
      {site.title}. I build fast, SEO-focused sites and growth systems that drive measurable results.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4" data-animate>
      <a href={withBase('/case-studies')} class="btn btn-primary">See Results</a>
      <a href={withBase('/work')} class="btn btn-ghost">View Work</a>
      <a href={withBase('/contact')} class="btn btn-ghost">Get in Touch</a>
    </div>
  </section>

  <!-- 2. About -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="About" title="Who I am and what I do" />
    <p class="max-w-3xl leading-relaxed text-neutral-400" data-animate>{site.bio}</p>
    <div class="mt-6 flex flex-wrap gap-2" data-animate>
      {site.skills.map((skill) => (
        <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-sm text-emerald-400">{skill}</span>
      ))}
    </div>
  </section>

  <!-- 3. Proof: Case Studies -->
  {
    caseStudies.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16">
        <SectionHeading eyebrow="Proof of results" title="Case studies with measurable outcomes" />
        <div class="grid gap-6 sm:grid-cols-2">
          {caseStudies.map((study) => (
            <BlogCard
              title={study.data.title}
              description={study.data.description}
              href={`case-studies/${study.id}`}
              date={study.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              tags={study.data.tags}
              type="case-study"
            />
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={withBase('/case-studies')} class="text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
            All case studies &rarr;
          </a>
        </div>
      </section>
    )
  }

  <!-- 4. Selected Work -->
  {
    selectedWork.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16">
        <SectionHeading eyebrow="Selected work" title="Builds, templates, and systems" />
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {selectedWork.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={withBase('/work')} class="text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
            Browse the full showroom &rarr;
          </a>
        </div>
      </section>
    )
  }

  <!-- 5. Thought Leadership -->
  {
    mediumPosts.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16">
        <SectionHeading eyebrow="Writing" title="Latest essays and articles on Medium" />
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {mediumPosts.map((post) => (
            <BlogCard
              title={post.title}
              description={post.snippet}
              href={post.link}
              date={post.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              tags={post.categories}
              image={post.thumbnail}
              external={true}
              source="Medium"
            />
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={withBase('/blog')} class="text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
            Read the blog &rarr;
          </a>
        </div>
      </section>
    )
  }

  <!-- 6. GitHub Activity -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="GitHub activity" title="Open source and ongoing builds" />
    <GitHubStats stats={stats} />
    <div class="mt-8">
      <ContributionGraph />
    </div>
  </section>

  <!-- 7. CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div
      class="relative overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/10 via-neutral-900/40 to-neutral-950 p-12 text-center backdrop-blur-sm sm:p-16"
      data-animate
    >
      <h2 class="text-3xl font-bold tracking-tight text-neutral-100 sm:text-4xl">Let's work together</h2>
      <p class="mx-auto mt-3 max-w-xl text-neutral-400">
        Need a site, funnel, or growth system? Let's talk.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={withBase('/contact')} class="btn btn-primary">Contact Me</a>
        <a href={withBase('/resume')} class="btn btn-ghost">View Resume</a>
      </div>
    </div>
  </section>
</BaseLayout>
