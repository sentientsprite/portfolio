---
import CinematicLayout from '../layouts/CinematicLayout.astro';
import ResumeDownload from '../components/ResumeDownload.astro';
import LogoTile from '../components/LogoTile.astro';
import { site } from '../config/site';
import { withBase } from '../lib/url';
import {
  education,
  certifications,
  experience,
  skillGroups,
  portfolioHighlights,
} from '../data/resume';
---

<CinematicLayout title="Resume" description="Professional experience, education, and skills.">
  <div class="work-catalog max-w-3xl">
    <header class="work-catalog-header" data-animate>
      <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-5">
          <img
            src={withBase('/images/me.png')}
            data-fallback={withBase(`/${site.photo}`)}
            alt={`Portrait of ${site.name}`}
            width="96"
            height="96"
            class="h-24 w-24 shrink-0 object-cover ring-1 ring-[#333]"
            loading="eager"
            onerror="this.onerror=null;this.src=this.dataset.fallback"
          />
          <div>
            <p class="cinema-section-label mb-2">Career</p>
            <h1 class="font-display text-4xl font-extrabold tracking-tight text-neutral-100">Resume</h1>
            <p class="mt-1 font-medium text-[#d4a853]">{site.name}</p>
            <p class="mt-2 text-neutral-500">Experience, education, and certifications</p>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href={site.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-cinema btn-cinema-ghost"
          >
            LinkedIn
          </a>
          <ResumeDownload />
        </div>
      </div>
    </header>

    <section class="border-t border-[#1a1a1a] py-12">
      <h3 class="font-display text-xl font-bold text-neutral-100">Experience</h3>
      <div class="mt-6 space-y-8">
        {
          experience.map((job) => (
            <div class="relative border-l border-[#333] pl-6">
              <div class="flex items-start gap-3">
                <LogoTile domain={job.domain} monogram={job.monogram} label={job.company} />
                <div>
                  <h4 class="text-lg font-medium text-neutral-100">{job.role}</h4>
                  <p class="text-sm text-[#d4a853]">{job.company}</p>
                  <p class="text-sm text-neutral-600">
                    {job.location} · {job.period}
                  </p>
                </div>
              </div>
              <ul class="mt-3 space-y-2">
                {job.highlights.map((item) => (
                  <li class="text-sm leading-relaxed text-neutral-500">• {item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-[#1a1a1a] py-12">
      <h3 class="font-display text-xl font-bold text-neutral-100">Education</h3>
      <div class="mt-4 space-y-4">
        {
          education.map((edu) => (
            <div class="flex items-start gap-3 border border-[#1a1a1a] bg-[#0a0a0a] p-4">
              <LogoTile domain={edu.domain} monogram={edu.monogram} label={edu.school} />
              <div>
                <h4 class="font-medium text-neutral-200">{edu.degree}</h4>
                <p class="text-sm text-neutral-500">
                  {edu.school}, {edu.location}
                </p>
                <p class="text-sm text-neutral-600">Graduated: {edu.graduated}</p>
                <p class="mt-1 text-sm text-neutral-500">{edu.details}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-[#1a1a1a] py-12">
      <h3 class="font-display text-xl font-bold text-neutral-100">Certifications</h3>
      <div class="mt-4 space-y-3">
        {
          certifications.map((cert) => (
            <div class="flex items-center gap-3 border border-[#1a1a1a] bg-[#0a0a0a] p-4">
              <LogoTile domain={cert.domain} monogram={cert.monogram} label={cert.issuer} size={40} />
              <div>
                <h4 class="font-medium text-neutral-200">{cert.name}</h4>
                <p class="text-sm text-neutral-600">
                  {cert.issuer} · Issued: {cert.issued}
                  {cert.renewed && ` · Renewed: ${cert.renewed}`}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-[#1a1a1a] py-12">
      <h3 class="font-display text-xl font-bold text-neutral-100">Skills</h3>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          skillGroups.map((group) => (
            <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-4">
              <h4 class="font-medium text-[#d4a853]">{group.category}</h4>
              <div class="mt-2 flex flex-wrap gap-1.5">
                {group.skills.map((skill) => (
                  <span class="tech-pill">{skill}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-[#1a1a1a] py-12">
      <h3 class="font-display text-xl font-bold text-neutral-100">Portfolio highlights</h3>
      <div class="mt-4 space-y-4">
        {
          portfolioHighlights.map((item) => (
            <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-4">
              <h4 class="font-medium text-neutral-200">{item.title}</h4>
              <p class="mt-1 text-sm text-neutral-500">{item.description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</CinematicLayout>
