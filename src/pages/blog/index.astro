---
import CinematicLayout from '../../layouts/CinematicLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BlogCard from '../../components/BlogCard.astro';
import { fetchMediumPosts, mediumProfileUrl } from '../../lib/medium';

const posts = await fetchMediumPosts(12);
const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<CinematicLayout title="Blog" description="Articles and essays by Raymond King on Medium.">
  <div class="work-catalog">
    <header class="work-catalog-header flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="cinema-section-label mb-0">Writing</p>
        <h1 class="work-catalog-title">Blog</h1>
        <p class="mt-3 max-w-xl text-neutral-500">Latest essays — published on Medium.</p>
      </div>
      <a
        href={mediumProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cinema btn-cinema-ghost shrink-0"
      >
        Follow on Medium &nearr;
      </a>
    </header>

    {
      posts.length > 0 ? (
        <div class="grid gap-6 border-t border-[#1a1a1a] pt-12 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard
              title={post.title}
              description={post.snippet}
              href={post.link}
              date={dateFmt(post.pubDate)}
              tags={post.categories}
              image={post.thumbnail}
              external={true}
              source="Medium"
            />
          ))}
        </div>
      ) : (
        <div class="border border-[#1a1a1a] bg-[#0a0a0a] p-10 text-center">
          <p class="text-neutral-500">Posts are published on Medium.</p>
          <a
            href={mediumProfileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-cinema btn-cinema-primary mt-6 inline-flex"
          >
            Read on Medium &nearr;
          </a>
        </div>
      )
    }
  </div>
</CinematicLayout>
