---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="Articles on digital marketing, SEO, and web development.">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading title="Blog" subtitle="Thoughts on marketing, development, and growth" />
    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          href={`blog/${post.id}`}
          date={post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>
