---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BlogCard from '../../components/BlogCard.astro';
import { fetchMediumPosts, mediumProfileUrl } from '../../lib/medium';

const posts = await fetchMediumPosts(12);
const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Blog" description="Articles and essays by Raymond King on Medium.">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <SectionHeading title="Blog" subtitle="Latest writing, published on Medium" />
      <a
        href={mediumProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-neutral-700 px-4 py-2 text-sm font-medium text-neutral-300 transition-colors hover:border-emerald-500/30 hover:text-emerald-400"
      >
        Follow on Medium &nearr;
      </a>
    </div>

    {
      posts.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard
              title={post.title}
              description={post.snippet}
              href={post.link}
              date={dateFmt(post.pubDate)}
              tags={post.categories}
              image={post.thumbnail}
              external={true}
              source="Medium"
            />
          ))}
        </div>
      ) : (
        <div class="mt-8 rounded-xl border border-neutral-800 bg-neutral-900/50 p-8 text-center">
          <p class="text-neutral-400">
            Posts are published on Medium. Visit the profile to read the latest.
          </p>
          <a
            href={mediumProfileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-neutral-950 transition-colors hover:bg-emerald-400"
          >
            Read on Medium &nearr;
          </a>
        </div>
      )
    }
  </div>
</BaseLayout>
