---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getMergedProjects } from '../lib/github';

const projects = await getMergedProjects();
---

<BaseLayout title="Projects" description="Portfolio projects and open source work.">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading
      title="Projects"
      subtitle="A mix of GitHub repositories and curated work"
    />
    {
      projects.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <p class="text-neutral-400">
          No projects found. Update your GitHub username in <code>src/config/site.ts</code> to pull repositories automatically.
        </p>
      )
    }
  </div>
</BaseLayout>
