---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SocialLinks from '../components/SocialLinks.astro';
import GrowthIntakeForm from '../components/GrowthIntakeForm.astro';
import JellyButton from '../components/JellyButton.astro';
import { site } from '../config/site';
---

<BaseLayout
  title="Contact"
  description="Start a marketing systems project with Raymond King. Share your goals through the quick intake form, or reach out by email and social."
>
  <div class="mx-auto max-w-4xl px-4 py-16">
    <SectionHeading
      eyebrow="Free consult"
      title="Let's find the gaps in your marketing system"
      subtitle="Book a free, no-obligation hour. Answer a few quick questions below and I'll follow up by email to schedule a consult, review the current bottleneck, and suggest the clearest next step."
    />

    <div class="mt-10" data-animate>
      <GrowthIntakeForm showIntro={false} />
    </div>

    <div
      class="glow-card mt-10 overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 text-center backdrop-blur-sm sm:p-10"
      data-animate
    >
      <h3 class="text-lg font-semibold text-neutral-100">Prefer to reach out directly?</h3>
      <p class="mx-auto mt-2 max-w-md text-sm text-neutral-400">Email is the fastest way to get me for project inquiries.</p>
      <JellyButton href={`mailto:${site.email}`} label={site.email} class="mt-6" />
      <div class="mt-8">
        <SocialLinks />
      </div>
    </div>
  </div>
</BaseLayout>
