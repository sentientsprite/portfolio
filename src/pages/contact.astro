---
import CinematicLayout from '../layouts/CinematicLayout.astro';
import GrowthIntakeForm from '../components/GrowthIntakeForm.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { site } from '../config/site';
---

<CinematicLayout
  title="Contact"
  description="Start a marketing systems project with Raymond King. Share your goals through the quick intake form, or reach out by email and social."
>
  <div class="work-catalog">
    <header class="work-catalog-header" data-animate>
      <p class="cinema-section-label mb-0">Free consult</p>
      <h1 class="work-catalog-title">Where are leads leaking?</h1>
      <p class="max-w-xl font-body text-neutral-500">
        One hour, no obligation. Tell me what's broken — I'll reply with a clear next step.
      </p>
    </header>

    <div data-animate>
      <GrowthIntakeForm variant="cinematic" />
    </div>

    <div class="mt-12 border border-[#1a1a1a] bg-[#0a0a0a] p-8 text-center sm:p-10" data-animate>
      <h3 class="font-display text-lg font-bold text-neutral-100">Prefer email?</h3>
      <p class="mx-auto mt-2 max-w-md text-sm text-neutral-500">
        Fastest path for project inquiries.
      </p>
      <a href={`mailto:${site.email}`} class="btn-cinema btn-cinema-primary mt-6 inline-flex">
        {site.email}
      </a>
      <div class="mt-8 flex justify-center">
        <SocialLinks />
      </div>
    </div>
  </div>
</CinematicLayout>
