---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GrowthSystemShowcase from '../components/GrowthSystemShowcase.astro';
import { getMergedProjects } from '../lib/github';
import { categoryLabels, type WorkCategory } from '../data/projects';

const projects = await getMergedProjects();
const growthSystemProject = projects.find((p) => p.slug === 'growth-system');
const growthModules = projects.filter((p) => p.growthSystemId === 'lead-to-revenue');
const growthModuleSlugs = new Set(growthModules.map((p) => p.slug));
const marketingSystems = [
  ...growthModules,
  ...projects.filter((p) => p.slug === 'seo-dashboard'),
];

const productSystems = projects
  .filter(
    (p) =>
      p.category === 'product' &&
      p.slug !== 'growth-system' &&
      !growthModuleSlugs.has(p.slug) &&
      !p.hidden,
  )
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return 0;
  });

const showroom = projects.filter(
  (p) =>
    !p.growthSystemId &&
    p.category !== 'meta' &&
    p.category !== 'product' &&
    p.slug !== 'seo-dashboard' &&
    !p.hidden,
);

const meta = projects.filter((p) => p.category === 'meta');

const grouped = showroom.reduce<Record<string, typeof showroom>>((acc, project) => {
  const key = project.category;
  acc[key] = acc[key] ?? [];
  acc[key].push(project);
  return acc;
}, {});

const categoryOrder: WorkCategory[] = ['automation', 'fun'];

const siteOrigin = 'https://sentientsprite.github.io/portfolio';
const catalogProjects = projects.filter((p) => p.category !== 'meta');
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Raymond King — Work & Live Demos',
  description:
    'Growth automation systems and live demos: websites, CRM workflows, booking flows, follow-up automation, and ROI dashboards.',
  itemListElement: catalogProjects.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: p.displayName,
      description: p.description,
      url: `${siteOrigin}/work/${p.slug}`,
      keywords: (p.techStack ?? []).join(', '),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />

<BaseLayout
  title="Work"
  description="Live demos and growth automation systems from Raymond King: websites, CRM workflows, booking flows, automation, and ROI dashboards for business owners."
>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading
      eyebrow="Portfolio"
      title="Work"
      subtitle="It's one connected system: a click becomes a tracked lead, books an appointment, gets automated follow-up, and shows up as measured ROI. Explore each live module below."
    />

  {
    growthSystemProject && (
      <GrowthSystemShowcase
        systemId="lead-to-revenue"
        systemProject={growthSystemProject}
        modules={marketingSystems}
      />
    )
  }

    {
      productSystems.length > 0 && (
        <section class="mb-16">
          <h3 class="mb-6 text-xl font-semibold text-neutral-100" data-animate>Product Systems</h3>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {productSystems.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </section>
      )
    }

    {
      categoryOrder.map((category) => {
        const items = grouped[category];
        if (!items?.length) return null;
        return (
          <section class="mb-16">
            <h3 class="mb-6 text-xl font-semibold text-neutral-100" data-animate>{categoryLabels[category]}</h3>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {items.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </section>
        );
      })
    }

    {
      meta.length > 0 && (
        <section class="border-t border-neutral-800 pt-12">
          <h3 class="mb-2 text-lg font-semibold text-neutral-100">Web Design</h3>
          <p class="mb-6 text-sm text-neutral-500">
            Reusable UI patterns and interactive features built into this site — open a card for details, then try the live icons on any page.
          </p>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {meta.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </section>
      )
    }

    {
      projects.length === 0 && (
        <p class="text-neutral-400">
          No work items found yet. Add curated entries in <code>src/data/projects.ts</code>.
        </p>
      )
    }
  </div>
</BaseLayout>
