---
import CinematicLayout from '../layouts/CinematicLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GrowthSystemShowcase from '../components/GrowthSystemShowcase.astro';
import { getMergedProjects } from '../lib/github';
import { categoryLabels } from '../data/projects';
import { withBase } from '../lib/url';

const projects = await getMergedProjects();
const growthSystemProject = projects.find((p) => p.slug === 'growth-system');
const growthModules = projects.filter((p) => p.growthSystemId === 'lead-to-revenue');
const growthModuleSlugs = new Set(growthModules.map((p) => p.slug));
const marketingSystems = [
  ...growthModules,
  ...projects.filter((p) => p.slug === 'seo-dashboard'),
];

const productSystems = projects
  .filter(
    (p) =>
      p.category === 'product' &&
      p.slug !== 'growth-system' &&
      !growthModuleSlugs.has(p.slug) &&
      !p.hidden,
  )
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return 0;
  });

const showroom = projects.filter(
  (p) =>
    !p.growthSystemId &&
    p.category !== 'meta' &&
    p.category !== 'product' &&
    p.slug !== 'seo-dashboard' &&
    !p.hidden,
);

const meta = projects.filter((p) => p.category === 'meta');

const allCatalog = [
  ...marketingSystems,
  ...productSystems.filter((p) => p.slug !== 'growth-system'),
  ...showroom,
];

const siteOrigin = 'https://sentientsprite.github.io/portfolio';
const catalogProjects = projects.filter((p) => p.category !== 'meta');
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Raymond King — Work & Live Demos',
  description:
    'Marketing systems and live demos: websites, CRM workflows, booking flows, follow-up automation, and attribution dashboards.',
  itemListElement: catalogProjects.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: p.displayName,
      description: p.description,
      url: `${siteOrigin}/work/${p.slug}`,
      keywords: (p.techStack ?? []).join(', '),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />

<CinematicLayout
  title="Work"
  description="Live demos and marketing systems from Raymond King: websites, CRM workflows, booking flows, automation, and attribution dashboards for business owners."
>
  <div class="work-catalog">
    <header class="work-catalog-header" data-animate>
      <p class="cinema-section-label mb-0">Index</p>
      <h1 class="work-catalog-title">Work</h1>
      <p class="max-w-2xl font-body text-neutral-500">
        Click any row — each one is a live demo or deep-dive into the stack.
      </p>
    </header>

    {
      growthSystemProject && (
        <div class="mb-16" data-animate>
          <GrowthSystemShowcase
            systemId="lead-to-revenue"
            systemProject={growthSystemProject}
            modules={marketingSystems}
          />
        </div>
      )
    }

    <div class="divide-y divide-[#1a1a1a]">
      {
        allCatalog.map((project, i) => (
          <a
            href={withBase(`/work/${project.slug}`)}
            class="work-row group"
            data-animate
          >
            <span class="work-row-index">{String(i + 1).padStart(2, '0')}</span>
            <div class="work-row-body">
              <h3>{project.displayName}</h3>
              <p class="work-row-meta">
                {project.growthSystemStage ?? categoryLabels[project.category]}
              </p>
            </div>
            <div class="work-row-thumb">
              {project.screenshot ? (
                <img
                  src={withBase(project.screenshot)}
                  alt=""
                  loading="lazy"
                />
              ) : (
                <div class="media-placeholder h-full">
                  <span>{project.displayName.charAt(0)}</span>
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>

    {
      meta.length > 0 && (
        <section class="mt-20 border-t border-[#1a1a1a] pt-16">
          <p class="cinema-section-label" data-animate>Web design</p>
          <p class="mb-8 max-w-xl text-sm text-neutral-500" data-animate>
            Patterns built into this site — every one is live right now.
          </p>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {meta.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</CinematicLayout>
