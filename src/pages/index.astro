    <!-- ===================== SCRIPT (Three.js + GSAP + Lenis) — deferred ===================== -->
    <script>
      function idle(delay = 2000): Promise<void> {
        return new Promise((resolve) => {
          if ('requestIdleCallback' in window) {
            requestIdleCallback(() => resolve(), { timeout: delay });
          } else {
            setTimeout(resolve, 120);
          }
        });
      }

      async function bootStudioHome() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isMobile = window.matchMedia('(max-width: 768px)').matches;
        const isTouch = window.matchMedia('(hover: none)').matches;
        const motionReduced =
          prefersReduced || document.documentElement.getAttribute('data-motion') === 'reduce';
        const skip3D = motionReduced;

        await idle(motionReduced ? 800 : isMobile ? 1200 : 2000);

        const { initMagneticButtons } = await import('../lib/magnetic-buttons');
        initMagneticButtons();

        const [{ gsap }, { ScrollTrigger }, lenisMod] = await Promise.all([
          import('gsap'),
          import('gsap/ScrollTrigger'),
          prefersReduced ? Promise.resolve({ default: null }) : import('lenis'),
        ]);
        gsap.registerPlugin(ScrollTrigger);

        let lenis: import('lenis').default | null = null;
        if (!prefersReduced && lenisMod.default) {
          lenis = new lenisMod.default({ lerp: 0.1, smoothWheel: true });
          lenis.on('scroll', ScrollTrigger.update);
          gsap.ticker.add((time) => lenis!.raf(time * 1000));
          gsap.ticker.lagSmoothing(0);
        }

        const canvas = document.getElementById('scene') as HTMLCanvasElement | null;
        const pointer = { x: 0, y: 0, tx: 0, ty: 0 };
        window.addEventListener('pointermove', (e) => {
          pointer.tx = e.clientX / window.innerWidth - 0.5;
          pointer.ty = e.clientY / window.innerHeight - 0.5;
        });

        function hideLoader() {
          const loader = document.getElementById('loader');
          if (loader) loader.classList.add('is-hidden');
          ScrollTrigger.refresh();
        }

        async function initScene() {
          if (skip3D || !canvas) {
            canvas?.classList.add('hidden');
            hideLoader();
            return;
          }

          const THREE = await import('three');

        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x0a0a0a, 0.028);

        const camera = new THREE.PerspectiveCamera(
          45,
          window.innerWidth / window.innerHeight,
          0.1,
          100,
        );
        camera.position.set(0, 0.5, 11.5);

        const renderer = new THREE.WebGLRenderer({
          canvas,
          antialias: !isMobile,
          alpha: true,
          powerPreference: 'high-performance',
        });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));

        /* --- Neural-net sales pipeline --- */
        // Parallax pivot holds the whole network. Node counts swell then taper
        // into a single "won" node — leads funneling down the pipeline.
        const pivot = new THREE.Group();
        const net = new THREE.Group();
        pivot.add(net);
        scene.add(pivot);

        const layerCounts = isMobile ? [1, 4, 6, 4, 1] : [1, 6, 9, 10, 9, 6, 1];
        const layerGap = 2.3;
        const vSpread = isMobile ? 4.4 : 6.6;
        const startX = -((layerCounts.length - 1) * layerGap) / 2;
        const endX = startX + (layerCounts.length - 1) * layerGap;
        // Layer 0 (entry) is placed at +X so +90° Z rotation puts it at the top of the screen.
        const layerX = (li: number) => endX - li * layerGap;

        // Shared node geometry with a baked-in vertical blue → purple gradient
        const nodeGeo = new THREE.IcosahedronGeometry(0.15, 0);
        {
          const top = new THREE.Color(0x3b82f6); // blue
          const bottom = new THREE.Color(0xa855f7); // purple
          const posAttr = nodeGeo.attributes.position;
          const cols = new Float32Array(posAttr.count * 3);
          let minY = Infinity;
          let maxY = -Infinity;
          for (let i = 0; i < posAttr.count; i++) {
            const y = posAttr.getY(i);
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
          const cc = new THREE.Color();
          for (let i = 0; i < posAttr.count; i++) {
            cc.copy(top).lerp(bottom, (posAttr.getY(i) - minY) / (maxY - minY || 1));
            cols[i * 3] = cc.r;
            cols[i * 3 + 1] = cc.g;
            cols[i * 3 + 2] = cc.b;
          }
          nodeGeo.setAttribute('color', new THREE.Float32BufferAttribute(cols, 3));
        }
        const layers: { mesh: THREE.Mesh; pos: THREE.Vector3 }[][] = [];
        const nodeData: { mesh: THREE.Mesh; phase: number; base: number }[] = [];

        layerCounts.forEach((count, li) => {
          const isFirst = li === 0;
          const isLast = li === layerCounts.length - 1;
          const isTerminal = isFirst || isLast;
          const layer: { mesh: THREE.Mesh; pos: THREE.Vector3 }[] = [];
          for (let n = 0; n < count; n++) {
            // Diamond profile: narrow at both ends, widest at the center layers.
            const bow = Math.sin((li / (layerCounts.length - 1)) * Math.PI) * 0.6;
            const x = layerX(li) + (Math.random() - 0.5) * 0.5;
            const y =
              count === 1
                ? 0
                : (n / (count - 1) - 0.5) * vSpread * (0.85 + bow * 0.15) +
                  (Math.random() - 0.5) * 0.7;
            const z = (Math.random() - 0.5) * 2.6;
            const base = isTerminal ? 1.9 : 0.85 + Math.random() * 0.5;
            const mesh = new THREE.Mesh(
              nodeGeo,
              new THREE.MeshStandardMaterial({
                vertexColors: true,
                emissive: isFirst ? 0x22d3ee : isLast ? 0x7c3aed : 0x4f46e5,
                emissiveIntensity: isTerminal ? 1.3 : 0.55,
                metalness: 0.1,
                roughness: 0.45,
                flatShading: true,
              }),
            );
            const pos = new THREE.Vector3(x, y, z);
            mesh.position.copy(pos);
            mesh.scale.setScalar(base);
            net.add(mesh);
            layer.push({ mesh, pos });
            nodeData.push({ mesh, phase: Math.random() * Math.PI * 2, base });
          }
          layers.push(layer);
        });

        // Gradient: cyan at the top entry node → emerald at the bottom won node
        const colA = new THREE.Color(0x22d3ee);
        const colB = new THREE.Color(0x34d399);
        const colorAt = (x: number, target: THREE.Color) =>
          target.copy(colA).lerp(colB, THREE.MathUtils.clamp((endX - x) / (endX - startX), 0, 1));

        // Edges: fully connect adjacent layers with organic bezier curves.
        // Each curve is sampled into segments with a per-vertex gradient color.
        const curveSegs = isMobile ? 7 : 12;
        const edgePos: number[] = [];
        const edgeCol: number[] = [];
        const edgesMeta: {
          pts: THREE.Vector3[];
          fromLayer: number;
          fromNodeIdx: number;
          toLayer: number;
          toNodeIdx: number;
        }[] = [];
        const outgoingByNode = new Map<string, number[]>();
        const cTmp = new THREE.Color();
        for (let li = 0; li < layers.length - 1; li++) {
          layers[li].forEach((from, fromIdx) => {
            layers[li + 1].forEach((to, toIdx) => {
              const mid = from.pos.clone().lerp(to.pos, 0.5);
              // Keep bends subtle so flow reads vertically after the net is rotated.
              mid.x += (Math.random() - 0.5) * 0.2;
              mid.y += (Math.random() - 0.5) * 0.45;
              mid.z += (Math.random() - 0.5) * 0.55;
              const curve = new THREE.QuadraticBezierCurve3(from.pos.clone(), mid, to.pos.clone());
              const pts = curve.getPoints(curveSegs);
              const ei = edgesMeta.length;
              edgesMeta.push({ pts, fromLayer: li, fromNodeIdx: fromIdx, toLayer: li + 1, toNodeIdx: toIdx });
              const startKey = `${li}-${fromIdx}`;
              if (!outgoingByNode.has(startKey)) outgoingByNode.set(startKey, []);
              outgoingByNode.get(startKey)!.push(ei);
              for (let s = 0; s < pts.length - 1; s++) {
                const p0 = pts[s];
                const p1 = pts[s + 1];
                edgePos.push(p0.x, p0.y, p0.z, p1.x, p1.y, p1.z);
                colorAt(p0.x, cTmp);
                edgeCol.push(cTmp.r, cTmp.g, cTmp.b);
                colorAt(p1.x, cTmp);
                edgeCol.push(cTmp.r, cTmp.g, cTmp.b);
              }
            });
          });
        }
        const edgeGeo = new THREE.BufferGeometry();
        edgeGeo.setAttribute('position', new THREE.Float32BufferAttribute(edgePos, 3));
        edgeGeo.setAttribute('color', new THREE.Float32BufferAttribute(edgeCol, 3));
        const edges = new THREE.LineSegments(
          edgeGeo,
          new THREE.LineBasicMaterial({
            vertexColors: true,
            transparent: true,
            opacity: 0.28,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
          }),
        );
        net.add(edges);

        // Data packets: enter at the top node and chain edge-to-edge down the diamond
        const topEdgeIndices = edgesMeta
          .map((edge, ei) => (edge.fromLayer === 0 ? ei : -1))
          .filter((ei) => ei >= 0);
        const pickTopEdge = () => topEdgeIndices[(Math.random() * topEdgeIndices.length) | 0];
        const pickNextEdge = (fromLayer: number, fromNodeIdx: number) => {
          const next = outgoingByNode.get(`${fromLayer}-${fromNodeIdx}`);
          return next && next.length
            ? next[(Math.random() * next.length) | 0]
            : pickTopEdge();
        };

        const packetCount = isMobile ? 12 : 34;
        const packets: { edge: number; t: number; speed: number }[] = [];
        for (let i = 0; i < packetCount; i++) {
          packets.push({
            edge: topEdgeIndices[i % topEdgeIndices.length] ?? 0,
            t: (i / packetCount) * 0.85,
            speed: 0.14 + Math.random() * 0.12,
          });
        }
        const packetDotGeo = new THREE.SphereGeometry(0.09, 8, 8);
        const packetDotMat = new THREE.MeshBasicMaterial({
          color: 0xffffff,
          transparent: true,
          opacity: 0.95,
          blending: THREE.AdditiveBlending,
          depthWrite: false,
          depthTest: false,
        });
        const packetDots: THREE.Mesh[] = [];
        for (let i = 0; i < packetCount; i++) {
          const dot = new THREE.Mesh(packetDotGeo, packetDotMat);
          dot.renderOrder = 5;
          net.add(dot);
          packetDots.push(dot);
        }

        function placePacket(i: number, p: (typeof packets)[0]) {
          const pts = edgesMeta[p.edge].pts;
          const f = p.t * (pts.length - 1);
          const idx = Math.min(Math.floor(f), pts.length - 2);
          tmp.copy(pts[idx]).lerp(pts[idx + 1], f - idx);
          packetDots[i].position.copy(tmp);
        }
        for (let i = 0; i < packets.length; i++) placePacket(i, packets[i]);

        /* --- Lights (tuned to keep nodes reading blue/purple) --- */
        scene.add(new THREE.AmbientLight(0x55608a, 0.95));
        const key = new THREE.DirectionalLight(0xffffff, 1.05);
        key.position.set(4, 6, 8);
        scene.add(key);
        const rim = new THREE.DirectionalLight(0x8b5cf6, 0.9); // violet rim
        rim.position.set(-6, -2, -4);
        scene.add(rim);
        // Payoff glows at both diamond tips (entry + won), parented to the net
        const glowTop = new THREE.PointLight(0x22d3ee, 4, 16, 2);
        glowTop.position.set(endX, 0, 1.5);
        net.add(glowTop);
        const glowBottom = new THREE.PointLight(0x6366f1, 5, 18, 2);
        glowBottom.position.set(startX, 0, 1.5);
        net.add(glowBottom);

        /* --- Scale to viewport width; pull camera back so the full diamond fits --- */
        const pipelineLength = (layerCounts.length - 1) * layerGap;
        const maxLayerCount = Math.max(...layerCounts);
        const diamondWidth = vSpread * 1.08 + maxLayerCount * 0.06;
        const baseCameraZ = 11.5;

        function recomputeScales() {
          net.rotation.z = Math.PI / 2;

          const halfFov = THREE.MathUtils.degToRad(45) / 2;
          camera.position.z = baseCameraZ;

          let halfH = Math.tan(halfFov) * camera.position.z;
          let visW = 2 * halfH * camera.aspect;
          let scale = (visW * 0.98) / diamondWidth;
          const scaledHeight = pipelineLength * scale;

          // Width-first scaling can make the diamond taller than the viewport — dolly back.
          if (scaledHeight > halfH * 2 * 0.9) {
            const targetHalfH = scaledHeight / (2 * 0.9);
            camera.position.z = targetHalfH / Math.tan(halfFov);
            camera.updateProjectionMatrix();
            halfH = Math.tan(halfFov) * camera.position.z;
            visW = 2 * halfH * camera.aspect;
            scale = (visW * 0.98) / diamondWidth;
          }

          net.scale.setScalar(scale);
        }
        recomputeScales();

        /* --- Render loop --- */
        const clock = new THREE.Clock();
        const tmp = new THREE.Vector3();
        let frameId = 0;
        let lastT = 0;

        function animate() {
          frameId = requestAnimationFrame(animate);
          const t = clock.getElapsedTime();
          const dt = Math.min(t - lastT, 0.05);
          lastT = t;

          // Nodes breathe softly
          nodeData.forEach((nd) => {
            nd.mesh.scale.setScalar(nd.base * (1 + Math.sin(t * 2 + nd.phase) * 0.12));
          });

          // Flow data packets from the top layer down through the full diamond
          for (let i = 0; i < packets.length; i++) {
            const p = packets[i];
            p.t += p.speed * dt;
            if (p.t >= 1) {
              const finished = edgesMeta[p.edge];
              if (finished.toLayer >= layerCounts.length - 1) {
                p.edge = pickTopEdge();
              } else {
                p.edge = pickNextEdge(finished.toLayer, finished.toNodeIdx);
              }
              p.t = 0;
            }
            placePacket(i, p);
          }

          // Subtle idle sway
          net.rotation.y = Math.sin(t * 0.25) * 0.12;
          net.position.y = Math.sin(t * 0.6) * 0.08;

          // Mouse parallax (lerped) — pivot tilt + camera drift
          if (!prefersReduced) {
            pointer.x += (pointer.tx - pointer.x) * 0.05;
            pointer.y += (pointer.ty - pointer.y) * 0.05;
            pivot.rotation.y += (pointer.x * 0.45 - pivot.rotation.y) * 0.05;
            pivot.rotation.x += (pointer.y * 0.28 - pivot.rotation.x) * 0.05;
            camera.position.x += (pointer.x * 1.4 - camera.position.x) * 0.05;
          }
          camera.lookAt(0, 0, 0);

          renderer.render(scene, camera);
        }
        animate();

        /* --- Resize --- */
        window.addEventListener('resize', () => {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
          recomputeScales();
        });

        // Pause rendering when tab is hidden (saves battery/CPU)
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) cancelAnimationFrame(frameId);
          else animate();
        });

        requestAnimationFrame(hideLoader);
        }

        function initAnimations() {
          if (prefersReduced) {
            gsap.set('[data-hero="line"], [data-reveal]', { opacity: 1, y: 0 });
            return;
          }
        gsap.from('[data-hero="line"]', {
          y: 40,
          opacity: 0,
          duration: 1,
          stagger: 0.12,
          ease: 'power3.out',
          delay: 0.2,
        });

        // Scroll-triggered reveals
        gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
          gsap.from(el, {
            y: 50,
            opacity: 0,
            duration: 1,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 88%' },
          });
        });
      }

      /* ----------------------------------------------------------------------
       * 4. UI INTERACTIONS — navbar, mobile menu, 3D tilt cards
       * -------------------------------------------------------------------- */
      function initUI() {
        const navbar = document.getElementById('navbar');
        const onScroll = (y: number) => {
          if (navbar) navbar.classList.toggle('scrolled', y > 40);
        };
        if (lenis) lenis.on('scroll', ({ scroll }: { scroll: number }) => onScroll(scroll));
        else window.addEventListener('scroll', () => onScroll(window.scrollY));
        onScroll(window.scrollY);

        // Mobile menu
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
        menu?.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => menu.classList.add('hidden')),
        );

        // Smooth-scroll anchor links via Lenis
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (!target) return;
            e.preventDefault();
            if (lenis) lenis.scrollTo(target as HTMLElement, { offset: -20 });
            else target.scrollIntoView({ behavior: 'smooth' });
          });
        });

        // 3D tilt cards (disabled on touch devices)
        if (!isTouch && !prefersReduced) {
          document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
            card.addEventListener('pointermove', (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width - 0.5;
              const py = (e.clientY - r.top) / r.height - 0.5;
              card.style.transform = `perspective(900px) rotateY(${px * 8}deg) rotateX(${-py * 8}deg)`;
              card.style.setProperty('--mx', `${(px + 0.5) * 100}%`);
              card.style.setProperty('--my', `${(py + 0.5) * 100}%`);
            });
            card.addEventListener('pointerleave', () => {
              card.style.transform = '';
            });
          });
        }
      }

        await initScene();
        initAnimations();
        initUI();
      }

      bootStudioHome().catch((err) => console.error('Studio home boot failed', err));
      document.addEventListener('astro:page-load', () => {
        import('../lib/magnetic-buttons').then(({ initMagneticButtons }) => initMagneticButtons());
      });
    </script>
  </body>
</html>
