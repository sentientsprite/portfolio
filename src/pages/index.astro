---
/**
 * index.astro — Site home: immersive 3D agency/portfolio landing page.
 *
 * Stack: Astro (static) + Tailwind v4 + Three.js + GSAP (ScrollTrigger) + Lenis.
 * Self-contained layout (own nav/footer) for a full-bleed cinematic experience.
 * Self-contained layout (own nav/footer) for a full-bleed cinematic experience.
 */
import '../styles/global.css';
import FoxAssistant from '../components/FoxAssistant.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import SpeedReader from '../components/SpeedReader.astro';
import VaultSuggestionForm from '../components/VaultSuggestionForm.astro';
import JellyButton from '../components/JellyButton.astro';
import BlogCard from '../components/BlogCard.astro';
import GitHubStats from '../components/GitHubStats.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import { site } from '../config/site';
import { withBase } from '../lib/url';
import { resolveDemoUrl, slugify } from '../lib/url';
import { projectOverrides } from '../data/projects';
import { growthSystemById } from '../data/growth-systems';
import { fetchGitHubStats } from '../lib/github';
import { fetchMediumPosts } from '../lib/medium';

const pageTitle = site.name;
const description = site.description;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImage = `${site.url}/${site.photo}`;

// Visible FAQ — also emitted as FAQPage structured data for AI Overviews / Gemini.
const faqs = [
  {
    q: 'What does Raymond King do?',
    a: 'Raymond King is a Marketing Systems Builder. He builds practical systems for business owners — conversion websites, CRM workflows, automated email and SMS follow-up, booking flows, and reporting dashboards — connected into one lead-to-revenue workflow.',
  },
  {
    q: 'What is the Lead-to-Revenue Growth System?',
    a: 'It is a connected 5-step demo stack: capture intent on a conversion landing page, support appointment booking, sync and score leads in a CRM, nurture automatically with email and SMS, and report channel performance with an attribution dashboard.',
  },
  {
    q: 'Who is this for?',
    a: 'Business owners, founders, agencies, and local service operators who get traffic but lose leads to manual follow-up, missed bookings, or unclear reporting.',
  },
  {
    q: 'How do projects start?',
    a: 'Through a short intake form on the contact page. You share your goals, current bottleneck, timeline, and budget, and Raymond follows up with a clear next step. There is no obligation.',
  },
  {
    q: 'Can Raymond help track which marketing channels are working?',
    a: 'Yes. The attribution dashboard demo shows how Google Analytics, CRM revenue, and ad spend can be brought into one reporting view for cost per lead, ROAS, and attributed revenue by channel. Demo data is simulated; production builds require access to the client tools.',
  },
];

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Products & launches — three flagship products, in order.
const showcaseOrder = ['fieldsync-scheduler', 'spryte', 'prana'];
const showcase = showcaseOrder
  .map((repoName) => projectOverrides.find((p) => p.repoName === repoName && !p.hidden))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map((p) => ({
    name: p.displayName ?? p.repoName,
    description: p.description ?? '',
    tech: p.techStack ?? [],
    href:
      resolveDemoUrl({ demoPath: p.demoPath, demoUrl: p.demoUrl }) ??
      withBase(`/work/${slugify(p.displayName ?? p.repoName)}`),
  }));

// Lead-to-Revenue Growth System — compact home strip.
const growthSystem = growthSystemById['lead-to-revenue'];
const growthProject = projectOverrides.find((p) => p.repoName === 'growth-system');
const displayNameByRepo = new Map(
  projectOverrides.map((p) => [p.repoName, p.displayName ?? p.repoName]),
);
const growthModules = growthSystem.modules.map((mod) => ({
  stageLabel: mod.stageLabel,
  product: displayNameByRepo.get(mod.repoName) ?? mod.repoName,
}));
const growthDemoUrl = growthProject
  ? resolveDemoUrl({ demoPath: growthProject.demoPath, demoUrl: growthProject.demoUrl })
  : null;
const growthDetailUrl = withBase('/work/growth-system');

const githubStats = await fetchGitHubStats();
const mediumPosts = (await fetchMediumPosts(3)).slice(0, 3);

const services = [
  {
    title: 'Lead-to-Revenue Systems',
    body: 'Landing pages, CRM capture, booking flows, nurture automation, and reporting dashboards connected into one practical marketing stack.',
    icon: 'M21 21l-4.35-4.35M11 19a8 8 0 110-16 8 8 0 010 16z',
  },
  {
    title: 'Conversion Websites',
    body: 'Fast, accessible websites and landing pages built around the action that matters: inquiry, booking, purchase, or qualified lead.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'AI-Assisted Workflows',
    body: 'Practical workflow support for forms, CRM updates, lead scoring, follow-up, reminders, and handoffs that would otherwise eat the day.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'CRM & Follow-Up',
    body: 'Lead routing, email and SMS nurture, appointment reminders, and pipeline hygiene so interested buyers do not fall through cracks.',
    icon: 'M3 17l6-6 4 4 8-8M21 7v6h-6',
  },
  {
    title: 'Interactive Tools & Demos',
    body: 'Small products, dashboards, and proof-of-concept tools that help founders and business owners test ideas before overbuilding.',
    icon: 'M12 2a10 10 0 100 20 10 10 0 000-20zM12 8v4l3 3',
  },
  {
    title: 'Analytics & Attribution',
    body: 'Dashboards that connect traffic, leads, booked appointments, ad spend, and CRM revenue into clearer channel reporting.',
    icon: 'M4 19h16M7 16V8m5 8V4m5 12v-6',
  },
];

const stats = [
  { value: '45%', label: 'Case-study lift' },
  { value: '80%', label: 'Case-study automation' },
  { value: '5', label: 'Growth-system modules' },
  { value: 'Demo', label: 'Attribution view' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${site.url}/#raymond-king`,
  name: 'Raymond King - Marketing Systems Builder',
  url: site.url,
  description,
  email: site.email,
  image: `${site.url}/${site.photo}`,
  founder: {
    '@type': 'Person',
    name: site.name,
    jobTitle: site.title,
    email: site.email,
    sameAs: [site.social.github, site.social.linkedin, site.social.x],
    knowsAbout: site.skills,
  },
  areaServed: 'United States',
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Business owners who need lead capture, automation, booking flows, CRM follow-up, and clearer marketing reporting',
  },
  serviceType: [
    'Lead-to-revenue growth systems',
    'Conversion websites and landing pages',
    'AI-assisted workflow support',
    'CRM and follow-up automation',
    'Analytics and attribution dashboards',
  ],
  makesOffer: [
    {
      '@type': 'Offer',
      name: 'Lead-to-Revenue Growth System',
      description:
        'A connected marketing stack that captures leads, syncs CRM data, supports booking, automates follow-up, and reports channel performance.',
      url: `${site.url}/work/growth-system`,
    },
    {
      '@type': 'Offer',
      name: 'Conversion Website and Automation Build',
      description:
        'A conversion-focused website or landing page connected to forms, CRM workflows, and follow-up automation.',
      url: `${site.url}/contact`,
    },
  ],
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
    <!-- Apply saved accessibility settings before first paint (no flash). -->
    <script is:inline>
      (function () {
        var de = document.documentElement;
        de.classList.add('js');
        try {
          var raw = sessionStorage.getItem('rk-a11y');
          if (!raw) return;
          var s = JSON.parse(raw);
          if (s.theme === 'light') de.setAttribute('data-theme', 'light');
          if (s.contrast) de.setAttribute('data-contrast', 'high');
          if (s.font) de.setAttribute('data-font', 'readable');
          if (s.links) de.setAttribute('data-links', 'underline');
          if (s.motion) de.setAttribute('data-motion', 'reduce');
          if (s.colorblind && s.colorblind !== 'none') de.setAttribute('data-colorblind', s.colorblind);
          if (s.textScale) de.style.setProperty('--a11y-text-scale', String(s.textScale));
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="studio-body min-h-screen overflow-x-hidden bg-neutral-950 text-neutral-100 antialiased">
    <!-- Loading overlay: removed once the 3D scene's first frame is painted -->
    <div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-neutral-950">
      <div class="flex flex-col items-center gap-5">
        <div class="loader-ring"></div>
        <p class="text-xs uppercase tracking-[0.4em] text-emerald-400/80">Loading…</p>
      </div>
    </div>

    <!-- Fixed full-viewport 3D canvas (sits behind all content) -->
    <canvas id="scene" class="pointer-events-none fixed inset-0 z-0 h-full w-full"></canvas>
    <!-- Atmospheric gradient layer behind the canvas -->
    <div class="bg-atmosphere pointer-events-none fixed inset-0 z-[-1]"></div>

    <!-- ===================== NAVBAR (glassmorphism, scroll-aware) ===================== -->
    <header
      id="navbar"
      class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
    >
      <div
        class="nav-shell mx-auto mt-4 flex max-w-6xl items-center justify-between rounded-2xl px-5 py-3 transition-all duration-500"
      >
        <a href="#hero" class="group flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-emerald-500/15 text-emerald-400 ring-1 ring-emerald-400/30 transition group-hover:bg-emerald-500/25">RK</span>
          <span class="hidden text-sm text-neutral-200 sm:inline">{site.name} · Marketing Systems</span>
        </a>

        <nav class="hidden items-center gap-7 md:flex" aria-label="Main">
          <a href={withBase('/work')} class="nav-link">Work</a>
          <a href={withBase('/case-studies')} class="nav-link">Case Studies</a>
          <a href={withBase('/resume')} class="nav-link">Resume</a>
          <a href={withBase('/blog')} class="nav-link">Blog</a>
          <a href={withBase('/contact')} class="nav-link">Contact</a>
        </nav>

        <div class="flex items-center gap-3">
          <span class="hidden sm:inline-block">
            <JellyButton href={withBase('/contact#intake')} label="Build my system" size="sm" />
          </span>
          <button
            id="menu-toggle"
            aria-label="Toggle menu"
            class="grid h-9 w-9 place-items-center rounded-lg ring-1 ring-neutral-700 text-neutral-300 md:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div
        id="mobile-menu"
        class="mx-auto mt-2 hidden max-w-6xl flex-col gap-1 rounded-2xl border border-neutral-800 bg-neutral-900/90 p-3 backdrop-blur-xl md:hidden"
        role="navigation"
        aria-label="Main"
      >
        <a href={withBase('/work')} class="mobile-link">Work</a>
        <a href={withBase('/case-studies')} class="mobile-link">Case Studies</a>
        <a href={withBase('/resume')} class="mobile-link">Resume</a>
        <a href={withBase('/blog')} class="mobile-link">Blog</a>
        <a href={withBase('/contact')} class="mobile-link">Contact</a>
        <a href={withBase('/contact#intake')} class="mobile-link text-emerald-400">Build my system</a>
      </div>
    </header>

    <main class="relative z-10">
      <!-- ===================== HERO ===================== -->
      <section id="hero" class="relative flex min-h-screen items-center justify-center px-4">
        <div class="mx-auto max-w-4xl text-center">
          <p
            data-hero="line"
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/5 px-4 py-1.5 text-xs uppercase tracking-[0.3em] text-emerald-300"
          >
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
            Marketing Systems Builder
          </p>

          <h1 class="text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-7xl md:text-8xl">
            <span data-hero="line" class="block">Turn traffic into</span>
            <span data-hero="line" class="block bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-300 bg-clip-text text-transparent">
              booked leads
            </span>
          </h1>

          <p
            data-hero="line"
            class="mx-auto mt-7 max-w-2xl text-pretty text-base text-neutral-400 sm:text-lg"
          >
            I build practical marketing systems — conversion sites, automated follow-up,
            booking flows, and reporting dashboards — that help more leads get captured,
            followed up with, and understood.
          </p>

          <div data-hero="line" class="mt-10 flex flex-wrap items-center justify-center gap-5">
            <JellyButton
              href={withBase('/contact#intake')}
              eyebrow="Free consult"
              label="Let's Build"
            />
            <a
              href="#growth"
              data-magnetic
              class="rounded-full border border-emerald-400/60 px-7 py-3 text-sm font-semibold text-emerald-300 transition hover:border-emerald-400 hover:bg-emerald-500 hover:text-neutral-950"
            >
              See the growth system
            </a>
          </div>

          <section class="sr-only" aria-label="AI-readable portfolio summary">
            Raymond King is a Marketing Systems Builder who helps business owners
            capture leads, automate follow-up, support appointment booking, and improve
            marketing reporting.
            Services include conversion websites, lead-to-revenue growth systems,
            AI-assisted workflows, CRM workflows, email and SMS follow-up, and
            analytics dashboards. Contact Raymond King at {site.email}.
          </section>
        </div>

        <!-- Scroll cue -->
        <div data-hero="line" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-neutral-500">
          <div class="flex flex-col items-center gap-2">
            <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
            <span class="scroll-dot"></span>
          </div>
        </div>
      </section>

      <!-- Frosted glass sheet over the fixed 3D backdrop: spans the full page width
           and runs the whole length of the content below the hero. -->
      <div class="relative bg-neutral-950/40 backdrop-blur-sm">
      <!-- ===================== STATS STRIP ===================== -->
      <section class="border-y border-neutral-900/80">
        <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px md:grid-cols-4">
          {stats.map((s) => (
            <div data-reveal class="px-6 py-10 text-center">
              <div class="bg-gradient-to-b from-emerald-200 to-emerald-500 bg-clip-text text-4xl font-semibold text-transparent sm:text-5xl">
                {s.value}
              </div>
              <div class="mt-2 text-xs uppercase tracking-widest text-neutral-500">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ===================== INTEGRATED GROWTH STACK (compact) — primary offer ===================== -->
      <section id="growth" class="relative mx-auto max-w-6xl px-4 py-28">
        <div
          data-reveal
          class="overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/[0.07] via-neutral-900/50 to-neutral-950 p-7 sm:p-9"
        >
          <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
            <!-- Left: pitch + flow -->
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-400">Integrated growth stack</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-neutral-100 sm:text-3xl">
                {growthSystem.name}
              </h2>
              <p class="mt-3 max-w-xl text-sm leading-relaxed text-neutral-400">{growthSystem.pitch}</p>

              <div class="mt-6 flex flex-wrap items-center gap-y-2">
                {growthModules.map((m, i) => (
                  <div class="flex items-center gap-2">
                    {i > 0 && <span class="px-1 text-emerald-500/50">&rarr;</span>}
                    <div class="flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-950/60 py-1.5 pl-1.5 pr-3">
                      <span class="grid h-5 w-5 place-items-center rounded-full bg-emerald-500/15 text-[11px] font-bold text-emerald-400">{i + 1}</span>
                      <span class="text-xs font-semibold text-neutral-200">{m.stageLabel}</span>
                      <span class="hidden text-[11px] text-neutral-500 sm:inline">{m.product}</span>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-7 flex flex-wrap items-center gap-4">
                {growthDemoUrl && <JellyButton href={growthDemoUrl} label="Open benefit showcase" size="sm" external />}
                <a
                  href={growthDetailUrl}
                  class="inline-flex items-center gap-2 rounded-full border border-emerald-400/60 px-6 py-2.5 text-sm font-semibold text-emerald-300 transition hover:border-emerald-400 hover:bg-emerald-500 hover:text-neutral-950"
                >
                  System overview
                </a>
              </div>
            </div>

            <!-- Right: outcomes + tracked pipeline -->
            <div class="rounded-2xl border border-neutral-800 bg-neutral-950/50 p-5">
              <div class="grid grid-cols-4 gap-2 text-center">
                {growthSystem.outcomes.map((o) => (
                  <div>
                    <b class="block text-lg font-bold text-emerald-400 sm:text-xl">{o.value}</b>
                    <span class="mt-0.5 block text-[10px] leading-tight text-neutral-500">{o.label}</span>
                  </div>
                ))}
              </div>
              <div class="mt-5 border-t border-neutral-800 pt-4">
                <p class="mb-2.5 text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-500">Tracked pipeline</p>
                <div class="flex flex-wrap items-center gap-x-1.5 gap-y-1.5 text-[11px] text-neutral-400">
                  <span class="rounded bg-neutral-900 px-2 py-1">Traffic</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/10 px-2 py-1 text-emerald-300">Capture</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/10 px-2 py-1 text-emerald-300">CRM + score</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-neutral-900 px-2 py-1">Book / nurture</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/20 px-2 py-1 font-medium text-emerald-300">ROI attribution</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== SHOWCASE / GALLERY (live demos) ===================== -->
      <section id="showcase" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="mb-16 flex flex-wrap items-end justify-between gap-6">
          <div class="max-w-2xl">
            <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">Selected work</p>
            <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
              Live demos that show how the tools work.
            </h2>
          </div>
          <div data-reveal>
            <JellyButton href={withBase('/work')} label="All work" />
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {showcase.map((proj, i) => (
            <a
              href={proj.href}
              target="_blank"
              rel="noopener noreferrer"
              data-reveal
              data-tilt
              class="tilt-card group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 backdrop-blur-sm"
            >
              <div class="tilt-inner">
                <div class="mb-6 flex aspect-video items-center justify-center overflow-hidden rounded-xl border border-neutral-800 bg-gradient-to-br from-neutral-900 to-neutral-950">
                  <span class="showcase-orb" style={`--hue:${150 + i * 18}`}></span>
                </div>
                <h3 class="mb-2 text-xl font-medium text-neutral-100 transition group-hover:text-emerald-300">
                  {proj.name}
                </h3>
                <p class="mb-5 line-clamp-2 text-sm leading-relaxed text-neutral-400">{proj.description}</p>
                <div class="flex flex-wrap gap-2">
                  {proj.tech.slice(0, 4).map((t) => (
                    <span class="rounded-full border border-neutral-800 bg-neutral-950/60 px-2.5 py-1 text-[11px] text-neutral-400">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
              <div class="card-glow"></div>
            </a>
          ))}
        </div>
      </section>

      <!-- ===================== SERVICES ===================== -->
      <section id="services" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="mb-16 max-w-2xl">
          <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">What I do</p>
          <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
            Practical systems for getting, booking, and keeping leads.
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((svc) => (
            <article
              data-reveal
              data-tilt
              class="tilt-card group relative rounded-2xl border border-neutral-800 bg-neutral-900/40 p-7 backdrop-blur-sm"
            >
              <div class="tilt-inner">
                <div class="mb-5 grid h-12 w-12 place-items-center rounded-xl bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-400/20 transition group-hover:bg-emerald-500/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={svc.icon} />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-medium text-neutral-100">{svc.title}</h3>
                <p class="text-sm leading-relaxed text-neutral-400">{svc.body}</p>
              </div>
              <div class="card-glow"></div>
            </article>
          ))}
        </div>
      </section>

      <!-- ===================== ABOUT / TESTIMONIALS ===================== -->
      <section id="about" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div>
            <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">About</p>
            <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
              One operator, practical marketing systems.
            </h2>
            <p data-reveal class="mt-6 text-pretty leading-relaxed text-neutral-400">
              {site.bio}
            </p>
            <div data-reveal class="mt-8 flex flex-wrap gap-2">
              {site.skills.map((skill) => (
