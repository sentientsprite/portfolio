---
/**
 * Cinematic home — flashlight hero, featured work strip, selected projects grid.
 */
import CinematicLayout from '../layouts/CinematicLayout.astro';
import FlashlightHero from '../components/cinematic/FlashlightHero.astro';
import WorkMediaStrip from '../components/cinematic/WorkMediaStrip.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config/site';
import { withBase } from '../lib/url';
import { getMergedProjects } from '../lib/github';

const projects = await getMergedProjects();
const featuredSlugs = ['growth-system', 'fieldsync-scheduler', 'landing-page-template'];
const featured = featuredSlugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const headliner = featured[0];
const gridProjects = projects
  .filter((p) => !p.hidden && p.category !== 'meta' && !p.growthSystemId)
  .slice(0, 6);

const faqs = [
  {
    q: 'What does Raymond King do?',
    a: 'I build marketing systems for business owners — conversion websites, CRM workflows, automated follow-up, booking flows, and reporting dashboards connected into one lead-to-revenue workflow.',
  },
  {
    q: 'Who is this for?',
    a: 'Founders, agencies, and local service operators who get traffic but lose leads to manual follow-up, missed bookings, or unclear reporting.',
  },
  {
    q: 'How do projects start?',
    a: 'Short intake on the contact page. You share goals, bottleneck, timeline, and budget — I follow up with a clear next step.',
  },
];

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

<CinematicLayout title={site.name} description={site.description}>
  <FlashlightHero />

  {headliner && <WorkMediaStrip project={headliner} index="01" />}

  {
    featured.length > 1 && (
      <section class="border-t border-[#1a1a1a] bg-[#030303] px-[clamp(1.25rem,4vw,3rem)] py-[clamp(3rem,8vh,5rem)]">
        <div class="mx-auto max-w-6xl">
          <p class="cinema-section-label" data-animate>In the stack</p>
          <div class="divide-y divide-[#1a1a1a]">
            {featured.slice(1).map((project, i) => (
              <a
                href={withBase(`/work/${project.slug}`)}
                class="work-row group block opacity-90 hover:opacity-100"
                data-animate
              >
                <span class="work-row-index">0{i + 2}</span>
                <div class="work-row-body">
                  <h3>{project.displayName}</h3>
                  <p class="work-row-meta">{project.growthSystemStage ?? project.category}</p>
                </div>
                <div class="work-row-thumb">
                  {project.screenshot ? (
                    <img src={withBase(project.screenshot)} alt="" loading="lazy" />
                  ) : (
                    <div class="media-placeholder h-full"><span>RK</span></div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="border-t border-[#1a1a1a] bg-[#030303] px-[clamp(1.25rem,4vw,3rem)] py-[clamp(4rem,10vh,7rem)]">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-4" data-animate>
        <div>
          <p class="cinema-section-label mb-3">Proof, not promises</p>
          <h2 class="font-display text-4xl font-extrabold tracking-tight text-neutral-100 sm:text-5xl">
            Open the demos. Judge the work.
          </h2>
        </div>
        <a href={withBase('/work')} class="btn-cinema btn-cinema-ghost">Full index &rarr;</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {gridProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-[#1a1a1a] bg-[#030303] px-[clamp(1.25rem,4vw,3rem)] py-[clamp(4rem,10vh,7rem)]">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <p class="cinema-section-label justify-center">Start here</p>
      <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl">
        Tell me where leads are leaking.
      </h2>
      <p class="mx-auto mt-4 max-w-md text-neutral-500">
        I’ll map your capture, follow-up, and reporting gaps — then propose a practical build plan.
      </p>
      <a href={withBase('/contact')} class="btn-cinema btn-cinema-primary mt-8 inline-flex">
        Start the intake
      </a>
    </div>
  </section>
</CinematicLayout>
