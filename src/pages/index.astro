---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import GitHubStats from '../components/GitHubStats.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import { site } from '../config/site';
import { getMergedProjects, fetchGitHubStats } from '../lib/github';
import { getCollection } from 'astro:content';

const projects = await getMergedProjects();
const featuredProjects = projects.filter((p) => p.featured).slice(0, 3);
const stats = await fetchGitHubStats();

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const caseStudies = (await getCollection('caseStudies', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);

const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <section class="mx-auto max-w-6xl px-4 py-24 text-center">
    <p class="text-sm font-medium text-emerald-400">Digital Marketing & Web Development</p>
    <h1 class="mt-4 text-5xl font-bold tracking-tight text-neutral-100 sm:text-6xl">
      {site.name}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-400">
      {site.title}. Building fast, SEO-focused sites and growth systems that drive real results.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href={`${base}projects`} class="rounded-lg bg-emerald-500 px-6 py-3 text-sm font-medium text-neutral-950 transition-colors hover:bg-emerald-400">
        View Projects
      </a>
      <a href={`${base}contact`} class="rounded-lg border border-neutral-700 px-6 py-3 text-sm font-medium text-neutral-300 transition-colors hover:border-emerald-500/30 hover:text-emerald-400">
        Get in Touch
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading title="About" subtitle="Background and expertise" />
    <p class="max-w-3xl text-neutral-400 leading-relaxed">{site.bio}</p>
    <div class="mt-6 flex flex-wrap gap-2">
      {site.skills.map((skill) => (
        <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-sm text-emerald-400">{skill}</span>
      ))}
    </div>
  </section>

  {
    featuredProjects.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16">
        <SectionHeading title="Featured Projects" subtitle="Highlighted work" />
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={`${base}projects`} class="text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
            View all projects &rarr;
          </a>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading title="Latest Writing" subtitle="Blog posts and case studies" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {blogPosts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          href={`blog/${post.id}`}
          date={post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          tags={post.data.tags}
        />
      ))}
      {caseStudies.map((study) => (
        <BlogCard
          title={study.data.title}
          description={study.data.description}
          href={`case-studies/${study.id}`}
          date={study.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          tags={study.data.tags}
          type="case-study"
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading title="GitHub Stats" subtitle="Open source activity" />
    <GitHubStats stats={stats} />
    <div class="mt-8">
      <ContributionGraph />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 text-center">
    <h2 class="text-2xl font-bold text-neutral-100">Let's work together</h2>
    <p class="mt-3 text-neutral-400">Interested in a project or collaboration? Reach out.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-4">
      <a href={`${base}contact`} class="rounded-lg bg-emerald-500 px-6 py-3 text-sm font-medium text-neutral-950 transition-colors hover:bg-emerald-400">
        Contact Me
      </a>
      <a href={`${base}resume`} class="rounded-lg border border-neutral-700 px-6 py-3 text-sm font-medium text-neutral-300 transition-colors hover:border-emerald-500/30 hover:text-emerald-400">
        View Resume
      </a>
    </div>
  </section>
</BaseLayout>
