---
/**
 * index.astro — Site home: immersive 3D agency/portfolio landing page.
 *
 * Stack: Astro (static) + Tailwind v4 + Three.js + GSAP (ScrollTrigger) + Lenis.
 * Self-contained layout (own nav/footer) for a full-bleed cinematic experience.
 * Classic portfolio home lives at /overview.
 */
import '../styles/global.css';
import FoxAssistant from '../components/FoxAssistant.astro';
import { site } from '../config/site';
import { withBase } from '../lib/url';
import { resolveDemoUrl, slugify } from '../lib/url';
import { projectOverrides } from '../data/projects';
import { growthSystemById } from '../data/growth-systems';

const pageTitle = site.name;
const description = site.description;

// Products & launches — three flagship products, in order.
const showcaseOrder = ['fieldsync-scheduler', 'spryte', 'prana'];
const showcase = showcaseOrder
  .map((repoName) => projectOverrides.find((p) => p.repoName === repoName && !p.hidden))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map((p) => ({
    name: p.displayName ?? p.repoName,
    description: p.description ?? '',
    tech: p.techStack ?? [],
    href:
      resolveDemoUrl({ demoPath: p.demoPath, demoUrl: p.demoUrl }) ??
      withBase(`/work/${slugify(p.displayName ?? p.repoName)}`),
  }));

// Lead-to-Revenue Growth System — compact home strip.
const growthSystem = growthSystemById['lead-to-revenue'];
const growthProject = projectOverrides.find((p) => p.repoName === 'growth-system');
const displayNameByRepo = new Map(
  projectOverrides.map((p) => [p.repoName, p.displayName ?? p.repoName]),
);
const growthModules = growthSystem.modules.map((mod) => ({
  stageLabel: mod.stageLabel,
  product: displayNameByRepo.get(mod.repoName) ?? mod.repoName,
}));
const growthDemoUrl = growthProject
  ? resolveDemoUrl({ demoPath: growthProject.demoPath, demoUrl: growthProject.demoUrl })
  : null;
const growthDetailUrl = withBase('/work/growth-system');

const services = [
  {
    title: 'Lead-to-Revenue Systems',
    body: 'Landing pages, CRM capture, booking flows, nurture automation, and ROI dashboards connected into one practical growth stack.',
    icon: 'M21 21l-4.35-4.35M11 19a8 8 0 110-16 8 8 0 010 16z',
  },
  {
    title: 'Conversion Websites',
    body: 'Fast, accessible websites and landing pages built around the action that matters: inquiry, booking, purchase, or qualified lead.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'AI-Assisted Automation',
    body: 'Workflow automation for forms, CRM updates, lead scoring, follow-up, reminders, and handoffs that would otherwise eat the day.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'CRM & Follow-Up',
    body: 'Lead routing, email and SMS nurture, appointment reminders, and pipeline hygiene so interested buyers do not fall through cracks.',
    icon: 'M3 17l6-6 4 4 8-8M21 7v6h-6',
  },
  {
    title: 'Interactive Tools & Demos',
    body: 'Small products, dashboards, and proof-of-concept tools that help founders and business owners test ideas before overbuilding.',
    icon: 'M12 2a10 10 0 100 20 10 10 0 000-20zM12 8v4l3 3',
  },
  {
    title: 'Analytics & ROI Tracking',
    body: 'Dashboards that connect traffic, leads, booked appointments, ad spend, and CRM revenue into a clear story of what is working.',
    icon: 'M4 19h16M7 16V8m5 8V4m5 12v-6',
  },
];

const stats = [
  { value: '45%', label: 'Avg. conversion lift' },
  { value: '80%', label: 'Nurture emails automated' },
  { value: '5', label: 'Growth-system modules' },
  { value: 'ROI', label: 'Tracked to revenue' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${site.url}/#raymond-king`,
  name: 'Raymond King - Growth Automation Builder',
  url: site.url,
  description,
  email: site.email,
  image: `${site.url}/${site.photo}`,
  founder: {
    '@type': 'Person',
    name: site.name,
    jobTitle: site.title,
    email: site.email,
    sameAs: [site.social.github, site.social.linkedin, site.social.x],
    knowsAbout: site.skills,
  },
  areaServed: 'United States',
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Business owners who need leads, automation, booking flows, CRM follow-up, and ROI tracking',
  },
  serviceType: [
    'Lead-to-revenue growth systems',
    'Conversion websites and landing pages',
    'AI-assisted workflow automation',
    'CRM and follow-up automation',
    'Analytics and ROI dashboards',
  ],
  makesOffer: [
    {
      '@type': 'Offer',
      name: 'Lead-to-Revenue Growth System',
      description:
        'A connected growth stack that captures leads, syncs CRM data, books appointments, automates follow-up, and measures channel ROI.',
      url: `${site.url}/work/growth-system`,
    },
    {
      '@type': 'Offer',
      name: 'Conversion Website and Automation Build',
      description:
        'A high-converting website or landing page connected to forms, CRM workflows, and follow-up automation.',
      url: `${site.url}/contact`,
    },
  ],
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>

  <body class="studio-body min-h-screen overflow-x-hidden bg-neutral-950 text-neutral-100 antialiased">
    <!-- Loading overlay: removed once the 3D scene's first frame is painted -->
    <div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-neutral-950">
      <div class="flex flex-col items-center gap-5">
        <div class="loader-ring"></div>
        <p class="text-xs uppercase tracking-[0.4em] text-emerald-400/80">Loading…</p>
      </div>
    </div>

    <!-- Fixed full-viewport 3D canvas (sits behind all content) -->
    <canvas id="scene" class="pointer-events-none fixed inset-0 z-0 h-full w-full"></canvas>
    <!-- Atmospheric gradient layer behind the canvas -->
    <div class="bg-atmosphere pointer-events-none fixed inset-0 z-[-1]"></div>

    <!-- ===================== NAVBAR (glassmorphism, scroll-aware) ===================== -->
    <header
      id="navbar"
      class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
    >
      <div
        class="nav-shell mx-auto mt-4 flex max-w-6xl items-center justify-between rounded-2xl px-5 py-3 transition-all duration-500"
      >
        <a href="#hero" class="group flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-emerald-500/15 text-emerald-400 ring-1 ring-emerald-400/30 transition group-hover:bg-emerald-500/25">RK</span>
          <span class="hidden text-sm text-neutral-200 sm:inline">{site.name} · Growth Automation</span>
        </a>

        <nav class="hidden items-center gap-7 md:flex" aria-label="Main">
          <a href={withBase('/overview')} class="nav-link">Overview</a>
          <a href={withBase('/work')} class="nav-link">Work</a>
          <a href={withBase('/case-studies')} class="nav-link">Case Studies</a>
          <a href={withBase('/blog')} class="nav-link">Blog</a>
          <a href={withBase('/contact')} class="nav-link">Contact</a>
        </nav>

        <div class="flex items-center gap-3">
          <a
            href="#contact"
            class="hidden rounded-full bg-emerald-500 px-4 py-2 text-sm font-medium text-neutral-950 transition hover:bg-emerald-400 sm:inline-block"
          >
            Build my system
          </a>
          <button
            id="menu-toggle"
            aria-label="Toggle menu"
            class="grid h-9 w-9 place-items-center rounded-lg ring-1 ring-neutral-700 text-neutral-300 md:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div
        id="mobile-menu"
        class="mx-auto mt-2 hidden max-w-6xl flex-col gap-1 rounded-2xl border border-neutral-800 bg-neutral-900/90 p-3 backdrop-blur-xl md:hidden"
        role="navigation"
        aria-label="Main"
      >
        <a href={withBase('/overview')} class="mobile-link">Overview</a>
        <a href={withBase('/work')} class="mobile-link">Work</a>
        <a href={withBase('/case-studies')} class="mobile-link">Case Studies</a>
        <a href={withBase('/blog')} class="mobile-link">Blog</a>
        <a href={withBase('/contact')} class="mobile-link">Contact</a>
        <a href="#contact" class="mobile-link text-emerald-400">Build my system</a>
      </div>
    </header>

    <main class="relative z-10">
      <!-- ===================== HERO ===================== -->
      <section id="hero" class="relative flex min-h-screen items-center justify-center px-4">
        <div class="mx-auto max-w-4xl text-center">
          <p
            data-hero="line"
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/5 px-4 py-1.5 text-xs uppercase tracking-[0.3em] text-emerald-300"
          >
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
            Growth Automation Builder
          </p>

          <h1 class="text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-7xl md:text-8xl">
            <span data-hero="line" class="block">Turn traffic into</span>
            <span data-hero="line" class="block bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-300 bg-clip-text text-transparent">
              booked revenue
            </span>
          </h1>

          <p
            data-hero="line"
            class="mx-auto mt-7 max-w-2xl text-pretty text-base text-neutral-400 sm:text-lg"
          >
            I build AI-assisted growth systems for business owners: conversion websites,
            CRM workflows, automated follow-up, booking flows, and ROI dashboards that show what is working.
          </p>

          <div data-hero="line" class="mt-10 flex flex-wrap items-center justify-center gap-4">
            <a
              href="#contact"
              class="group relative overflow-hidden rounded-full bg-emerald-500 px-7 py-3 text-sm font-medium text-neutral-950 transition hover:bg-emerald-400"
            >
              <span class="relative z-10">Build my growth system</span>
            </a>
            <a
              href={growthDetailUrl}
              class="rounded-full border border-neutral-700 px-7 py-3 text-sm font-medium text-neutral-200 transition hover:border-emerald-400/50 hover:text-emerald-300"
            >
              See the growth system
            </a>
          </div>

          <section class="sr-only" aria-label="AI-readable portfolio summary">
            Raymond King is a Growth Automation Builder who helps business owners
            capture leads, automate follow-up, book appointments, and measure ROI.
            Services include conversion websites, lead-to-revenue growth systems,
            AI-assisted automation, CRM workflows, email and SMS follow-up, and
            analytics dashboards. Contact Raymond King at {site.email}.
          </section>
        </div>

        <!-- Scroll cue -->
        <div data-hero="line" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-neutral-500">
          <div class="flex flex-col items-center gap-2">
            <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
            <span class="scroll-dot"></span>
          </div>
        </div>
      </section>

      <!-- Frosted glass sheet over the fixed 3D backdrop: spans the full page width
           and runs the whole length of the content below the hero. -->
      <div class="relative bg-neutral-950/40 backdrop-blur-sm">
      <!-- ===================== STATS STRIP ===================== -->
      <section class="border-y border-neutral-900/80">
        <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px md:grid-cols-4">
          {stats.map((s) => (
            <div data-reveal class="px-6 py-10 text-center">
              <div class="bg-gradient-to-b from-emerald-200 to-emerald-500 bg-clip-text text-4xl font-semibold text-transparent sm:text-5xl">
                {s.value}
              </div>
              <div class="mt-2 text-xs uppercase tracking-widest text-neutral-500">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ===================== SERVICES ===================== -->
      <section id="services" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="mb-16 max-w-2xl">
          <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">What I do</p>
          <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
            Practical systems for getting, booking, and keeping leads.
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((svc) => (
            <article
              data-reveal
              data-tilt
              class="tilt-card group relative rounded-2xl border border-neutral-800 bg-neutral-900/40 p-7 backdrop-blur-sm"
            >
              <div class="tilt-inner">
                <div class="mb-5 grid h-12 w-12 place-items-center rounded-xl bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-400/20 transition group-hover:bg-emerald-500/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={svc.icon} />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-medium text-neutral-100">{svc.title}</h3>
                <p class="text-sm leading-relaxed text-neutral-400">{svc.body}</p>
              </div>
              <div class="card-glow"></div>
            </article>
          ))}
        </div>
      </section>

      <!-- ===================== SHOWCASE / GALLERY ===================== -->
      <section id="showcase" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="mb-16 flex flex-wrap items-end justify-between gap-6">
          <div class="max-w-2xl">
            <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">Selected work</p>
            <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
              Live demos that show how the systems work.
            </h2>
          </div>
          <a
            data-reveal
            href={withBase('/work')}
            class="inline-flex items-center gap-3 rounded-full bg-white px-8 py-4 text-lg font-bold text-neutral-950 shadow-lg transition hover:bg-neutral-200"
          >
            All work
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {showcase.map((proj, i) => (
            <a
              href={proj.href}
              target="_blank"
              rel="noopener noreferrer"
              data-reveal
              data-tilt
              class="tilt-card group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 backdrop-blur-sm"
            >
              <div class="tilt-inner">
                <div class="mb-6 flex aspect-video items-center justify-center overflow-hidden rounded-xl border border-neutral-800 bg-gradient-to-br from-neutral-900 to-neutral-950">
                  <span class="showcase-orb" style={`--hue:${150 + i * 18}`}></span>
                </div>
                <h3 class="mb-2 text-xl font-medium text-neutral-100 transition group-hover:text-emerald-300">
                  {proj.name}
                </h3>
                <p class="mb-5 line-clamp-2 text-sm leading-relaxed text-neutral-400">{proj.description}</p>
                <div class="flex flex-wrap gap-2">
                  {proj.tech.slice(0, 4).map((t) => (
                    <span class="rounded-full border border-neutral-800 bg-neutral-950/60 px-2.5 py-1 text-[11px] text-neutral-400">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
              <div class="card-glow"></div>
            </a>
          ))}
        </div>
      </section>

      <!-- ===================== INTEGRATED GROWTH STACK (compact) ===================== -->
      <section class="relative mx-auto max-w-6xl px-4 pb-20">
        <div
          data-reveal
          class="overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/[0.07] via-neutral-900/50 to-neutral-950 p-7 sm:p-9"
        >
          <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
            <!-- Left: pitch + flow -->
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-400">Integrated growth stack</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-neutral-100 sm:text-3xl">
                {growthSystem.name}
              </h2>
              <p class="mt-3 max-w-xl text-sm leading-relaxed text-neutral-400">{growthSystem.pitch}</p>

              <div class="mt-6 flex flex-wrap items-center gap-y-2">
                {growthModules.map((m, i) => (
                  <div class="flex items-center gap-2">
                    {i > 0 && <span class="px-1 text-emerald-500/50">&rarr;</span>}
                    <div class="flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-950/60 py-1.5 pl-1.5 pr-3">
                      <span class="grid h-5 w-5 place-items-center rounded-full bg-emerald-500/15 text-[11px] font-bold text-emerald-400">{i + 1}</span>
                      <span class="text-xs font-semibold text-neutral-200">{m.stageLabel}</span>
                      <span class="hidden text-[11px] text-neutral-500 sm:inline">{m.product}</span>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-7 flex flex-wrap gap-3">
                {
                  growthDemoUrl && (
                    <a
                      href={growthDemoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-full bg-emerald-500 px-6 py-2.5 text-sm font-semibold text-neutral-950 transition hover:bg-emerald-400"
                    >
                      Open benefit showcase &nearr;
                    </a>
                  )
                }
                <a
                  href={growthDetailUrl}
                  class="inline-flex items-center gap-2 rounded-full border border-neutral-700 px-6 py-2.5 text-sm font-medium text-neutral-200 transition hover:border-emerald-400/50 hover:text-emerald-300"
                >
                  System overview
                </a>
              </div>
            </div>

            <!-- Right: outcomes + tracked pipeline -->
            <div class="rounded-2xl border border-neutral-800 bg-neutral-950/50 p-5">
              <div class="grid grid-cols-4 gap-2 text-center">
                {growthSystem.outcomes.map((o) => (
                  <div>
                    <b class="block text-lg font-bold text-emerald-400 sm:text-xl">{o.value}</b>
                    <span class="mt-0.5 block text-[10px] leading-tight text-neutral-500">{o.label}</span>
                  </div>
                ))}
              </div>
              <div class="mt-5 border-t border-neutral-800 pt-4">
                <p class="mb-2.5 text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-500">Tracked pipeline</p>
                <div class="flex flex-wrap items-center gap-x-1.5 gap-y-1.5 text-[11px] text-neutral-400">
                  <span class="rounded bg-neutral-900 px-2 py-1">Traffic</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/10 px-2 py-1 text-emerald-300">Capture</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/10 px-2 py-1 text-emerald-300">CRM + score</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-neutral-900 px-2 py-1">Book / nurture</span>
                  <span class="text-emerald-500/50">&rarr;</span>
                  <span class="rounded bg-emerald-500/20 px-2 py-1 font-medium text-emerald-300">ROI attribution</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== ABOUT / TESTIMONIALS ===================== -->
      <section id="about" class="relative mx-auto max-w-6xl px-4 py-28">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div>
            <p data-reveal class="mb-3 text-xs uppercase tracking-[0.3em] text-emerald-400">About</p>
            <h2 data-reveal class="text-4xl font-semibold tracking-tight sm:text-5xl">
              One operator, full stack of growth.
            </h2>
            <p data-reveal class="mt-6 text-pretty leading-relaxed text-neutral-400">
              {site.bio}
            </p>
            <div data-reveal class="mt-8 flex flex-wrap gap-2">
              {site.skills.map((skill) => (
                <span class="rounded-full border border-neutral-800 bg-neutral-900/50 px-3 py-1.5 text-xs text-neutral-300">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <div class="space-y-5">
            <figure data-reveal class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-7 backdrop-blur-sm">
              <blockquote class="text-pretty leading-relaxed text-neutral-300">
                “Raymond rebuilt our funnel and the conversion lift paid for the project in the first month. Fast, sharp, and genuinely strategic.”
              </blockquote>
              <figcaption class="mt-4 text-sm text-neutral-500">— Founder, DTC wellness brand</figcaption>
            </figure>
            <figure data-reveal class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-7 backdrop-blur-sm">
              <blockquote class="text-pretty leading-relaxed text-neutral-300">
                “The automation he set up quietly handles most of our nurture. It just works — and we finally trust the numbers.”
              </blockquote>
              <figcaption class="mt-4 text-sm text-neutral-500">— Ops lead, B2B SaaS</figcaption>
            </figure>
            <figure data-reveal class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-7 backdrop-blur-sm">
              <blockquote class="text-pretty leading-relaxed text-neutral-300">
                “We hired Raymond to run a $10k/month Google Ads budget. He ended up repairing hacked site issues, wrangling frameworks and sitemaps, and turning the whole web stack into a cleaner growth engine.”
              </blockquote>
              <figcaption class="mt-4 text-sm text-neutral-500">— Brand lead, smart living innovations & DirecTV supplier</figcaption>
            </figure>
          </div>
        </div>
      </section>

      <!-- ===================== CTA ===================== -->
      <section id="contact" class="relative mx-auto max-w-6xl px-4 py-28">
        <div
          data-reveal
          class="relative overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/10 via-neutral-900/40 to-neutral-950 p-12 text-center backdrop-blur-sm sm:p-20"
        >
          <h2 class="mx-auto max-w-2xl text-balance text-4xl font-semibold tracking-tight sm:text-6xl">
            Ready to turn more leads into booked revenue?
          </h2>
          <p class="mx-auto mt-5 max-w-xl text-neutral-400">
            Tell me where leads are getting lost. I will help map the website, automation, CRM follow-up, and ROI tracking needed to close the loop.
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
            <a
              href={`mailto:${site.email}`}
              class="rounded-full bg-emerald-500 px-8 py-3.5 text-sm font-medium text-neutral-950 transition hover:bg-emerald-400"
            >
              Build my growth system
            </a>
            <a
              href={withBase('/contact')}
              class="rounded-full border border-neutral-700 px-8 py-3.5 text-sm font-medium text-neutral-200 transition hover:border-emerald-400/50 hover:text-emerald-300"
            >
              Contact page
            </a>
          </div>
        </div>
      </section>

      <!-- ===================== FOOTER ===================== -->
      <footer class="relative border-t border-neutral-900 px-4 py-12">
        <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 sm:flex-row">
          <p class="text-sm text-neutral-500">© {new Date().getFullYear()} {site.name}. Built with Astro + Three.js.</p>
          <div class="flex items-center gap-6 text-sm">
            <a href={site.social.github} class="nav-link" target="_blank" rel="noopener">GitHub</a>
            <a href={site.social.linkedin} class="nav-link" target="_blank" rel="noopener">LinkedIn</a>
            <a href={site.social.x} class="nav-link" target="_blank" rel="noopener">X</a>
          </div>
        </div>
      </footer>
      </div>
    </main>

    <!-- Persistent chat-assistant mascot (placeholder for the AI-FAQ widget) -->
    <FoxAssistant />

    <!-- ===================== STYLES ===================== -->
    <style>
      /* Atmospheric background: layered radial glows for depth behind the canvas */
      .bg-atmosphere {
        background:
          radial-gradient(60% 50% at 50% 0%, rgba(16, 185, 129, 0.12), transparent 70%),
          radial-gradient(40% 40% at 80% 60%, rgba(20, 184, 166, 0.08), transparent 70%),
          radial-gradient(50% 50% at 15% 80%, rgba(16, 185, 129, 0.06), transparent 70%),
          #0a0a0a;
      }

      /* ---- Loader ---- */
      .loader-ring {
        width: 46px;
        height: 46px;
        border-radius: 9999px;
        border: 2px solid rgba(16, 185, 129, 0.15);
        border-top-color: rgb(16, 185, 129);
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      #loader.is-hidden {
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.6s ease, visibility 0.6s ease;
      }

      /* ---- Navbar glass ---- */
      .nav-shell {
        border: 1px solid transparent;
        background: transparent;
      }
      #navbar.scrolled .nav-shell {
        border-color: rgba(38, 38, 38, 0.9);
        background: rgba(10, 10, 10, 0.6);
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 40px -20px rgba(0, 0, 0, 0.8);
      }
      .nav-link {
        color: rgb(163, 163, 163);
        transition: color 0.2s ease;
      }
      .nav-link:hover { color: rgb(52, 211, 153); }
      .mobile-link {
        display: block;
        border-radius: 0.5rem;
        padding: 0.6rem 0.9rem;
        font-size: 0.9rem;
        color: rgb(212, 212, 212);
      }
      .mobile-link:hover { background: rgba(38, 38, 38, 0.6); }

      /* ---- Scroll cue ---- */
      .scroll-dot {
        position: relative;
        display: block;
        width: 22px;
        height: 36px;
        border: 1px solid rgba(115, 115, 115, 0.6);
        border-radius: 12px;
      }
      .scroll-dot::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 7px;
        width: 3px;
        height: 7px;
        margin-left: -1.5px;
        border-radius: 2px;
        background: rgb(52, 211, 153);
        animation: scroll-bob 1.6s ease-in-out infinite;
      }
      @keyframes scroll-bob {
        0%, 100% { transform: translateY(0); opacity: 1; }
        50% { transform: translateY(10px); opacity: 0.3; }
      }

      /* ---- 3D tilt cards ---- */
      .tilt-card {
        transform-style: preserve-3d;
        transition: transform 0.2s ease, border-color 0.3s ease;
        will-change: transform;
      }
      .tilt-card:hover { border-color: rgba(16, 185, 129, 0.4); }
      .tilt-inner { transform: translateZ(20px); transform-style: preserve-3d; }
      .card-glow {
        pointer-events: none;
        position: absolute;
        inset: 0;
        border-radius: inherit;
        opacity: 0;
        background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(16, 185, 129, 0.15), transparent 45%);
        transition: opacity 0.3s ease;
      }
      .tilt-card:hover .card-glow { opacity: 1; }

      /* ---- Showcase orb preview ---- */
      .showcase-orb {
        width: 110px;
        height: 110px;
        border-radius: 9999px;
        background: radial-gradient(circle at 35% 30%, hsl(var(--hue) 80% 65%), hsl(var(--hue) 70% 30%) 60%, transparent 72%);
        box-shadow: 0 0 60px -10px hsl(var(--hue) 80% 45% / 0.6);
        animation: float-orb 6s ease-in-out infinite;
      }
      .group:hover .showcase-orb { animation-duration: 3s; }
      @keyframes float-orb {
        0%, 100% { transform: translateY(-6px) scale(1); }
        50% { transform: translateY(6px) scale(1.05); }
      }

      /* Respect reduced-motion users */
      @media (prefers-reduced-motion: reduce) {
        .scroll-dot::after,
        .showcase-orb,
        .loader-ring { animation: none; }
      }
    </style>

    <!-- ===================== SCRIPT (Three.js + GSAP + Lenis) ===================== -->
    <script>
      import * as THREE from 'three';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      const isTouch = window.matchMedia('(hover: none)').matches;

      /* ----------------------------------------------------------------------
       * 1. SMOOTH SCROLL (Lenis) + ScrollTrigger sync
       * -------------------------------------------------------------------- */
      let lenis: Lenis | null = null;
      if (!prefersReduced) {
        lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis!.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
      }

      /* ----------------------------------------------------------------------
       * 2. THREE.JS SCENE — neural-net sales pipeline
       * -------------------------------------------------------------------- */
      const canvas = document.getElementById('scene') as HTMLCanvasElement | null;

      // Pointer state (normalized -0.5..0.5), shared by scene + parallax
      const pointer = { x: 0, y: 0, tx: 0, ty: 0 };
      window.addEventListener('pointermove', (e) => {
        pointer.tx = e.clientX / window.innerWidth - 0.5;
        pointer.ty = e.clientY / window.innerHeight - 0.5;
      });

      function initScene() {
        if (!canvas) return hideLoader();

        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x0a0a0a, 0.035);

        const camera = new THREE.PerspectiveCamera(
          45,
          window.innerWidth / window.innerHeight,
          0.1,
          100,
        );
        camera.position.set(0, 0.5, 11.5);

        const renderer = new THREE.WebGLRenderer({
          canvas,
          antialias: !isMobile,
          alpha: true,
          powerPreference: 'high-performance',
        });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));

        /* --- Neural-net sales pipeline --- */
        // Parallax pivot holds the whole network. Node counts swell then taper
        // into a single "won" node — leads funneling down the pipeline.
        const pivot = new THREE.Group();
        const net = new THREE.Group();
        pivot.add(net);
        scene.add(pivot);

        const layerCounts = isMobile ? [4, 6, 6, 4, 2, 1] : [6, 9, 10, 8, 6, 3, 1];
        const layerGap = 2.3;
        const vSpread = isMobile ? 4.4 : 6.6;
        const startX = -((layerCounts.length - 1) * layerGap) / 2;
        const endX = startX + (layerCounts.length - 1) * layerGap;

        // Shared node geometry with a baked-in vertical blue → purple gradient
        const nodeGeo = new THREE.IcosahedronGeometry(0.15, 0);
        {
          const top = new THREE.Color(0x3b82f6); // blue
          const bottom = new THREE.Color(0xa855f7); // purple
          const posAttr = nodeGeo.attributes.position;
          const cols = new Float32Array(posAttr.count * 3);
          let minY = Infinity;
          let maxY = -Infinity;
          for (let i = 0; i < posAttr.count; i++) {
            const y = posAttr.getY(i);
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
          const cc = new THREE.Color();
          for (let i = 0; i < posAttr.count; i++) {
            cc.copy(top).lerp(bottom, (posAttr.getY(i) - minY) / (maxY - minY || 1));
            cols[i * 3] = cc.r;
            cols[i * 3 + 1] = cc.g;
            cols[i * 3 + 2] = cc.b;
          }
          nodeGeo.setAttribute('color', new THREE.Float32BufferAttribute(cols, 3));
        }
        const layers: { mesh: THREE.Mesh; pos: THREE.Vector3 }[][] = [];
        const nodeData: { mesh: THREE.Mesh; phase: number; base: number }[] = [];

        layerCounts.forEach((count, li) => {
          const isLast = li === layerCounts.length - 1;
          const layer: { mesh: THREE.Mesh; pos: THREE.Vector3 }[] = [];
          for (let n = 0; n < count; n++) {
            // Organic placement: jittered columns + a gentle vertical bow + depth
            const bow = Math.sin((li / (layerCounts.length - 1)) * Math.PI) * 0.6;
            const x = startX + li * layerGap + (Math.random() - 0.5) * 0.5;
            const y =
              count === 1
                ? 0
                : (n / (count - 1) - 0.5) * vSpread * (0.85 + bow * 0.15) +
                  (Math.random() - 0.5) * 0.7;
            const z = (Math.random() - 0.5) * 2.6;
            const base = isLast ? 1.9 : 0.85 + Math.random() * 0.5;
            const mesh = new THREE.Mesh(
              nodeGeo,
              new THREE.MeshStandardMaterial({
                vertexColors: true, // blue → purple gradient baked into the geometry
                emissive: isLast ? 0x7c3aed : 0x4f46e5, // violet / indigo glow
                emissiveIntensity: isLast ? 1.3 : 0.55,
                metalness: 0.1,
                roughness: 0.45,
                flatShading: true,
              }),
            );
            const pos = new THREE.Vector3(x, y, z);
            mesh.position.copy(pos);
            mesh.scale.setScalar(base);
            net.add(mesh);
            layer.push({ mesh, pos });
            nodeData.push({ mesh, phase: Math.random() * Math.PI * 2, base });
          }
          layers.push(layer);
        });

        // Gradient endpoints: cyan (leads) flowing to emerald (won)
        const colA = new THREE.Color(0x22d3ee);
        const colB = new THREE.Color(0x34d399);
        const colorAt = (x: number, target: THREE.Color) =>
          target.copy(colA).lerp(colB, THREE.MathUtils.clamp((x - startX) / (endX - startX), 0, 1));

        // Edges: fully connect adjacent layers with organic bezier curves.
        // Each curve is sampled into segments with a per-vertex gradient color.
        const curveSegs = isMobile ? 7 : 12;
        const edgePos: number[] = [];
        const edgeCol: number[] = [];
        const edges3: THREE.Vector3[][] = []; // sampled points per edge (for packets)
        const cTmp = new THREE.Color();
        for (let li = 0; li < layers.length - 1; li++) {
          layers[li].forEach((from) => {
            layers[li + 1].forEach((to) => {
              const mid = from.pos.clone().lerp(to.pos, 0.5);
              mid.x += (Math.random() - 0.5) * 0.6;
              mid.y += (Math.random() - 0.5) * 1.3;
              mid.z += (Math.random() - 0.5) * 1.8;
              const curve = new THREE.QuadraticBezierCurve3(from.pos.clone(), mid, to.pos.clone());
              const pts = curve.getPoints(curveSegs);
              edges3.push(pts);
              // Emit consecutive point pairs as line segments + gradient colors
              for (let s = 0; s < pts.length - 1; s++) {
                const p0 = pts[s];
                const p1 = pts[s + 1];
                edgePos.push(p0.x, p0.y, p0.z, p1.x, p1.y, p1.z);
                colorAt(p0.x, cTmp);
                edgeCol.push(cTmp.r, cTmp.g, cTmp.b);
                colorAt(p1.x, cTmp);
                edgeCol.push(cTmp.r, cTmp.g, cTmp.b);
              }
            });
          });
        }
        const edgeGeo = new THREE.BufferGeometry();
        edgeGeo.setAttribute('position', new THREE.Float32BufferAttribute(edgePos, 3));
        edgeGeo.setAttribute('color', new THREE.Float32BufferAttribute(edgeCol, 3));
        const edges = new THREE.LineSegments(
          edgeGeo,
          new THREE.LineBasicMaterial({
            vertexColors: true,
            transparent: true,
            opacity: 0.28,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
          }),
        );
        net.add(edges);

        // Data packets: bright dots flowing forward along the curved edges
        const packetCount = isMobile ? 12 : 34;
        const packetPos = new Float32Array(packetCount * 3);
        const packets: { edge: number; t: number; speed: number }[] = [];
        for (let i = 0; i < packetCount; i++) {
          packets.push({
            edge: (Math.random() * edges3.length) | 0,
            t: Math.random(),
            speed: 0.1 + Math.random() * 0.18,
          });
        }
        const packetGeo = new THREE.BufferGeometry();
        packetGeo.setAttribute('position', new THREE.BufferAttribute(packetPos, 3));
        const packetMesh = new THREE.Points(
          packetGeo,
          new THREE.PointsMaterial({
            color: 0x99f6e4,
            size: isMobile ? 0.17 : 0.2,
            transparent: true,
            opacity: 0.95,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            sizeAttenuation: true,
          }),
        );
        net.add(packetMesh);

        /* --- Ambient drifting particles (atmosphere) --- */
        const pCount = isMobile ? 900 : 2600;
        const positions = new Float32Array(pCount * 3);
        for (let i = 0; i < pCount; i++) {
          positions[i * 3] = (Math.random() - 0.5) * 40;
          positions[i * 3 + 1] = (Math.random() - 0.5) * 28;
          positions[i * 3 + 2] = (Math.random() - 0.5) * 30;
        }
        const pGeo = new THREE.BufferGeometry();
        pGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const particles = new THREE.Points(
          pGeo,
          new THREE.PointsMaterial({
            color: 0x34d399,
            size: 0.04,
            transparent: true,
            opacity: 0.5,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            sizeAttenuation: true,
          }),
        );
        scene.add(particles);

        /* --- Lights (tuned to keep nodes reading blue/purple) --- */
        scene.add(new THREE.AmbientLight(0x55608a, 0.95));
        const key = new THREE.DirectionalLight(0xffffff, 1.05);
        key.position.set(4, 6, 8);
        scene.add(key);
        const rim = new THREE.DirectionalLight(0x8b5cf6, 0.9); // violet rim
        rim.position.set(-6, -2, -4);
        scene.add(rim);
        // Bright glow sits at the "won" node so conversions feel like the payoff
        const glow = new THREE.PointLight(0x6366f1, 5, 18, 2); // indigo payoff glow
        glow.position.set(endX, 0, 1.5);
        scene.add(glow);

        /* --- Stable size: upright pipeline held at content width on every viewport --- */
        const netW = (layers.length - 1) * layerGap || 1;

        function recomputeScales() {
          // Stand the pipeline upright (90° CCW) on every viewport so it reads
          // bottom-to-top (Leads → Won); the long axis runs vertically.
          net.rotation.z = Math.PI / 2;
          glow.position.set(0, netW * 0.42, 1.5); // payoff glow at the top (Won)

          const halfH = Math.tan(THREE.MathUtils.degToRad(45) / 2) * camera.position.z;
          const visH = 2 * halfH; // visible world height at the net's depth

          // Fit the long axis (netW) to ~content height and keep it there — no
          // full-bleed or scroll-driven contraction.
          const contentPx = Math.min(window.innerHeight * 0.92, 1180);
          net.scale.setScalar((visH * (contentPx / window.innerHeight)) / netW);
        }
        recomputeScales();

        /* --- Render loop --- */
        const clock = new THREE.Clock();
        const tmp = new THREE.Vector3();
        let frameId = 0;
        let lastT = 0;

        function animate() {
          frameId = requestAnimationFrame(animate);
          const t = clock.getElapsedTime();
          const dt = Math.min(t - lastT, 0.05);
          lastT = t;

          // Nodes breathe softly
          nodeData.forEach((nd) => {
            nd.mesh.scale.setScalar(nd.base * (1 + Math.sin(t * 2 + nd.phase) * 0.12));
          });

          // Flow data packets forward along the curved edges; recycle at the end
          for (let i = 0; i < packets.length; i++) {
            const p = packets[i];
            p.t += p.speed * dt;
            if (p.t >= 1) {
              p.t -= 1;
              p.edge = (Math.random() * edges3.length) | 0;
            }
            const pts = edges3[p.edge];
            const f = p.t * (pts.length - 1);
            const idx = Math.min(Math.floor(f), pts.length - 2);
            tmp.copy(pts[idx]).lerp(pts[idx + 1], f - idx);
            packetPos[i * 3] = tmp.x;
            packetPos[i * 3 + 1] = tmp.y;
            packetPos[i * 3 + 2] = tmp.z;
          }
          packetGeo.attributes.position.needsUpdate = true;

          // Subtle idle sway (no full revolve) + slow particle drift
          net.rotation.y = Math.sin(t * 0.25) * 0.12;
          net.position.y = Math.sin(t * 0.6) * 0.08;
          particles.rotation.y = t * 0.015;

          // Mouse parallax (lerped) — pivot tilt + camera drift
          if (!prefersReduced) {
            pointer.x += (pointer.tx - pointer.x) * 0.05;
            pointer.y += (pointer.ty - pointer.y) * 0.05;
            pivot.rotation.y += (pointer.x * 0.45 - pivot.rotation.y) * 0.05;
            pivot.rotation.x += (pointer.y * 0.28 - pivot.rotation.x) * 0.05;
            camera.position.x += (pointer.x * 1.4 - camera.position.x) * 0.05;
          }
          camera.lookAt(0, 0, 0);

          renderer.render(scene, camera);
        }
        animate();

        /* --- Resize --- */
        window.addEventListener('resize', () => {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
          recomputeScales();
        });

        // Pause rendering when tab is hidden (saves battery/CPU)
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) cancelAnimationFrame(frameId);
          else animate();
        });

        // Hide loader once the first frame is on screen
        requestAnimationFrame(hideLoader);
      }

      function hideLoader() {
        const loader = document.getElementById('loader');
        if (loader) loader.classList.add('is-hidden');
        // Recalculate scroll positions once layout is final
        ScrollTrigger.refresh();
      }

      /* ----------------------------------------------------------------------
       * 3. GSAP ENTRANCE + SCROLL REVEALS
       * -------------------------------------------------------------------- */
      function initAnimations() {
        // Hero entrance
        gsap.from('[data-hero="line"]', {
          y: 40,
          opacity: 0,
          duration: 1,
          stagger: 0.12,
          ease: 'power3.out',
          delay: 0.2,
        });

        // Scroll-triggered reveals
        gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
          gsap.from(el, {
            y: 50,
            opacity: 0,
            duration: 1,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 88%' },
          });
        });
      }

      /* ----------------------------------------------------------------------
       * 4. UI INTERACTIONS — navbar, mobile menu, 3D tilt cards
       * -------------------------------------------------------------------- */
      function initUI() {
        const navbar = document.getElementById('navbar');
        const onScroll = (y: number) => {
          if (navbar) navbar.classList.toggle('scrolled', y > 40);
        };
        if (lenis) lenis.on('scroll', ({ scroll }: { scroll: number }) => onScroll(scroll));
        else window.addEventListener('scroll', () => onScroll(window.scrollY));
        onScroll(window.scrollY);

        // Mobile menu
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
        menu?.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => menu.classList.add('hidden')),
        );

        // Smooth-scroll anchor links via Lenis
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (!target) return;
            e.preventDefault();
            if (lenis) lenis.scrollTo(target as HTMLElement, { offset: -20 });
            else target.scrollIntoView({ behavior: 'smooth' });
          });
        });

        // 3D tilt cards (disabled on touch devices)
        if (!isTouch && !prefersReduced) {
          document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
            card.addEventListener('pointermove', (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width - 0.5;
              const py = (e.clientY - r.top) / r.height - 0.5;
              card.style.transform = `perspective(900px) rotateY(${px * 8}deg) rotateX(${-py * 8}deg)`;
              card.style.setProperty('--mx', `${(px + 0.5) * 100}%`);
              card.style.setProperty('--my', `${(py + 0.5) * 100}%`);
            });
            card.addEventListener('pointerleave', () => {
              card.style.transform = '';
            });
          });
        }
      }

      /* ---- Boot ---- */
      initScene();
      initAnimations();
      initUI();
    </script>
  </body>
</html>
