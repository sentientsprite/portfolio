---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/url';

interface Props {
  entry: CollectionEntry<'caseStudies'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, tags, outcome, heroImage } = entry.data;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-4 py-16">
    <header class="mb-10">
      <span class="text-sm font-medium text-emerald-400">Case Study</span>
      <time class="mt-1 block text-sm text-neutral-500" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-neutral-100">
        {title}
      </h1>
      <p class="mt-3 text-lg text-neutral-400">{description}</p>
      {
        heroImage && (
          <img
            src={withBase(heroImage)}
            alt={`${title} — results overview`}
            class="mt-6 w-full rounded-xl border border-neutral-800"
            loading="eager"
          />
        )
      }
      {
        outcome && (
          <div class="mt-4 rounded-lg border border-emerald-500/20 bg-emerald-500/5 px-4 py-3">
            <span class="text-sm font-medium text-emerald-400">Outcome: </span>
            <span class="text-sm text-neutral-300">{outcome}</span>
          </div>
        )
      }
      {
        tags && tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs text-emerald-400">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
