---
import CinematicLayout from './CinematicLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/url';
import { site } from '../config/site';

interface Props {
  entry: CollectionEntry<'caseStudies'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, tags, outcome, heroImage } = entry.data;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  keywords: (tags ?? []).join(', '),
  ...(heroImage ? { image: `${site.url}${heroImage.startsWith('/') ? '' : '/'}${heroImage}` } : {}),
  author: { '@type': 'Person', name: site.name, url: site.url },
  publisher: { '@type': 'Person', name: site.name, url: site.url },
  about: outcome ? `Outcome: ${outcome}` : undefined,
};
---

<CinematicLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} is:inline />
  <article>
    <header class="project-hero" data-animate>
      <a
        href={withBase('/case-studies')}
        class="mb-8 inline-block font-body text-xs uppercase tracking-[0.2em] text-neutral-600 transition hover:text-neutral-300"
      >
        &larr; All case studies
      </a>
      <p class="project-hero-label">Case study · {formattedDate}</p>
      <h1 class="project-hero-title max-w-none">{title}</h1>
      <p class="project-hero-desc">{description}</p>
      {
        heroImage && (
          <img
            src={withBase(heroImage)}
            alt={`${title} — results overview`}
            class="mt-8 w-full border border-[#1a1a1a] object-cover"
            loading="eager"
          />
        )
      }
      {
        outcome && (
          <div class="mt-6 border border-[#d4a853]/25 bg-[#d4a853]/5 px-4 py-3">
            <span class="text-sm font-medium text-[#d4a853]">Outcome: </span>
            <span class="text-sm text-neutral-300">{outcome}</span>
          </div>
        )
      }
      {
        tags && tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="tech-pill">{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="project-detail-body prose mx-auto max-w-3xl">
      <slot />
    </div>
  </article>
</CinematicLayout>
