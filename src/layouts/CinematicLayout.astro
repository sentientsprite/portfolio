---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CinematicNav from '../components/cinematic/CinematicNav.astro';
import CinematicLoader from '../components/cinematic/CinematicLoader.astro';
import FoxAssistant from '../components/FoxAssistant.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import { site } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImage = `${site.url}/${site.photo}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{pageTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      (function () {
        var de = document.documentElement;
        de.classList.add('js');
        try {
          var raw = sessionStorage.getItem('rk-a11y');
          if (!raw) return;
          var s = JSON.parse(raw);
          if (s.theme === 'light') de.setAttribute('data-theme', 'light');
          if (s.contrast) de.setAttribute('data-contrast', 'high');
          if (s.font) de.setAttribute('data-font', 'readable');
          if (s.links) de.setAttribute('data-links', 'underline');
          if (s.motion) de.setAttribute('data-motion', 'reduce');
          if (s.colorblind && s.colorblind !== 'none') de.setAttribute('data-colorblind', s.colorblind);
          if (s.textScale) de.style.setProperty('--a11y-text-scale', String(s.textScale));
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-[#030303] font-body text-neutral-100 antialiased">
    <CinematicLoader />
    <CinematicNav />

    <main>
      <slot />
    </main>

    <footer class="cinema-footer">
      <span>&copy; {new Date().getFullYear()} {site.name}</span>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href={withBase('/work')}>Work</a>
        <a href={withBase('/overview')}>Overview</a>
        <a href={withBase('/case-studies')}>Case Studies</a>
        <a href={withBase('/blog')}>Blog</a>
        <a href={withBase('/resume')}>Resume</a>
        <a href={withBase('/contact')}>Contact</a>
        <a href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </footer>

    <FoxAssistant />
    <AccessibilityWidget />

    <script>
      import { initCinematicLoader } from '../lib/cinematic/cinematic-loader';
      import { initLenisSmooth, refreshLenis } from '../lib/cinematic/lenis-smooth';
      import { initFlashlightHero } from '../lib/cinematic/flashlight-hero';
      import { initLazyDemoFrames } from '../lib/cinematic/lazy-demo-frame';

      function bootCinematic() {
        initCinematicLoader();
        initLenisSmooth();
        refreshLenis();
        initFlashlightHero();
        initLazyDemoFrames();
        initScrollReveal();
      }

      function initScrollReveal() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const revealEls = document.querySelectorAll('[data-animate]');
        if (prefersReduced || !('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry, i) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              el.style.transitionDelay = `${Math.min(i * 70, 280)}ms`;
              el.classList.add('is-visible');
              io.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
        );
        revealEls.forEach((el) => {
          el.classList.remove('is-visible');
          io.observe(el);
        });
      }

      bootCinematic();
      document.addEventListener('astro:page-load', bootCinematic);
    </script>
  </body>
</html>
